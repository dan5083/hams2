<%# app/views/shared/_ai_assistant.html.erb %>

<div data-controller="ai-assistant" class="fixed bottom-0 right-0 z-50">

  <%# ── Chat Panel — full-width bottom dock ────────────────────────── %>
  <div data-ai-assistant-target="panel"
       class="hidden flex-col
              fixed bottom-0 left-0 right-0 h-[360px] sm:h-[400px]
              bg-gray-50 shadow-[0_-4px_24px_rgba(0,0,0,0.12)] border-t border-gray-200 overflow-hidden
              transition-transform duration-200 ease-out">

    <%# Header %>
    <div class="flex items-center justify-between px-5 py-2.5 bg-blue-600 text-white shrink-0">
      <div class="flex items-center gap-2">
        <div class="w-7 h-7 rounded-full bg-white/20 flex items-center justify-center">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"/>
          </svg>
        </div>
        <div>
          <p class="font-semibold text-sm leading-none">HAMS Assistant</p>
          <p class="text-xs text-blue-200 mt-0.5">Live data access</p>
        </div>
      </div>
      <div class="flex items-center gap-2">
        <button data-action="click->ai-assistant#clearHistory"
                title="Clear conversation"
                class="p-1 rounded hover:bg-white/10 transition-colors text-blue-200 hover:text-white">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
          </svg>
        </button>
        <button data-action="click->ai-assistant#close"
                title="Minimise"
                class="p-1 rounded hover:bg-white/10 transition-colors text-blue-200 hover:text-white">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7"/>
          </svg>
        </button>
      </div>
    </div>

    <%# Messages area — max-width for readability on wide screens %>
    <div data-ai-assistant-target="messages"
         class="flex-1 overflow-y-auto px-4 py-3 mx-auto w-full max-w-4xl">
      <div data-placeholder class="flex flex-col items-center justify-center h-full text-gray-400 text-sm gap-2">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8 opacity-40" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/>
        </svg>
        <p>Ask me anything about HAMS data</p>
      </div>
    </div>

    <%# File preview badges %>
    <div data-ai-assistant-target="filePreview"
         class="hidden shrink-0 mx-auto w-full max-w-4xl px-4 mb-1 flex flex-wrap gap-1">
    </div>

    <%# Input area %>
    <div class="shrink-0 border-t border-gray-200 bg-white px-4 py-3">
      <%# Hidden file input %>
      <input type="file"
             data-ai-assistant-target="fileInput"
             data-action="change->ai-assistant#handleFileChange"
             accept="image/jpeg,image/png,image/gif,image/webp,application/pdf"
             multiple
             class="hidden">

      <div class="flex items-end gap-2 mx-auto max-w-4xl">
        <%# Paperclip button %>
        <button data-action="click->ai-assistant#triggerFileUpload"
                title="Attach image or PDF"
                class="shrink-0 w-9 h-9 rounded-xl border border-gray-200 hover:bg-gray-50 transition-colors flex items-center justify-center text-gray-400 hover:text-gray-600">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.172 7l-6.586 6.586a2 2 0 102.828 2.828l6.414-6.586a4 4 0 00-5.656-5.656l-6.415 6.585a6 6 0 108.486 8.486L20.5 13"/>
          </svg>
        </button>

        <textarea data-ai-assistant-target="input"
                  data-action="keydown->ai-assistant#handleKeydown"
                  placeholder="Ask about orders, parts, customers…"
                  rows="1"
                  class="flex-1 resize-none rounded-xl border border-gray-200 px-3 py-2 text-sm text-gray-800 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent leading-relaxed"
                  style="min-height:38px; max-height:120px;"></textarea>

        <button data-ai-assistant-target="sendBtn"
                data-action="click->ai-assistant#send"
                class="shrink-0 w-9 h-9 rounded-xl bg-blue-600 hover:bg-blue-700 disabled:opacity-40 disabled:cursor-not-allowed transition-colors flex items-center justify-center">
          <svg data-ai-assistant-target="spinner" class="hidden w-4 h-4 animate-spin text-white" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
            <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
            <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path>
          </svg>
          <svg class="w-4 h-4 text-white" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8"/>
          </svg>
        </button>
      </div>
      <p class="text-xs text-gray-400 mt-1.5 px-1 max-w-4xl mx-auto">Enter to send · Shift+Enter for new line · 📎 for images/PDFs</p>
    </div>
  </div>

  <%# ── Floating Button (bottom-right) ───────────────────────────────── %>
  <button data-ai-assistant-target="button"
          data-action="click->ai-assistant#toggle"
          class="fixed bottom-6 right-6 w-14 h-14 rounded-full bg-blue-600 hover:bg-blue-700 shadow-lg hover:shadow-xl transition-all flex items-center justify-center text-white"
          title="Open HAMS Assistant">
    <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"/>
    </svg>
  </button>

</div>
