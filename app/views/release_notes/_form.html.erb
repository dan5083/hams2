                                    <% batch_readings.each do |reading| %>
                                      <span class="inline-block px-2 py-1 bg-blue-100 text-blue-800 rounded text-sm mr-2 mb-1">
                                        <%= reading %> µm
                                      </span>
                                    <% end %>
                                  <% else %>
                                    <span class="text-gray-400 text-sm">No readings yet...</span>
                                  <% end %>
                                </div>
                              </div>

                              <!-- Manual Entry - 8 fields -->
                              <div>
                                <label class="block text-xs font-medium text-gray-500 mb-1">Manual Entry (µm):</label>
