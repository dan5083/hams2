            </div>
          </div>
        <% end %>
        <!-- /Thickness Measurements Section -->

        <!-- Statement (using remarks field) -->
        <div class="sm:col-span-6">
          <%= form.label :remarks, "Statement", class: "block text-sm font-medium text-gray-700" %>
