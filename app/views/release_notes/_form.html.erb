<%= form_with(model: @release_note.persisted? ? @release_note : [@works_order, @release_note], local: true) do |form| %>
  <% if @release_note.errors.any? %>
    <div class="bg-red-50 border border-red-200 rounded-md p-4 mb-6">
      <div class="flex">
        <div class="flex-shrink-0">
          <svg class="h-5 w-5 text-red-400" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd" />
          </svg>
        </div>
        <div class="ml-3">
          <h3 class="text-sm font-medium text-red-800">
            There were <%= pluralize(@release_note.errors.count, "error") %> with your submission:
          </h3>
          <div class="mt-2 text-sm text-red-700">
            <ul class="list-disc list-inside">
              <% @release_note.errors.full_messages.each do |message| %>
                <li><%= message %></li>
              <% end %>
            </ul>
          </div>
        </div>
      </div>
    </div>
  <% end %>

  <!-- Invoice Warning for Editing Invoiced Release Notes -->
  <% if @release_note.invoiced? %>
    <div class="bg-amber-50 border border-amber-200 rounded-md p-4 mb-6">
      <div class="flex">
        <div class="flex-shrink-0">
          <svg class="h-5 w-5 text-amber-400" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M8.257 3.099c.765-1.36 2.722-1.36 3.486 0l5.58 9.92c.75 1.334-.213 2.98-1.742 2.98H4.42c-1.53 0-2.493-1.646-1.743-2.98l5.58-9.92zM11 13a1 1 0 11-2 0 1 1 0 012 0zm-1-8a1 1 0 00-1 1v3a1 1 0 002 0V6a1 1 0 00-1-1z" clip-rule="evenodd" />
          </svg>
        </div>
        <div class="ml-3">
          <h3 class="text-sm font-medium text-amber-800">Invoiced Release Note</h3>
          <div class="mt-2 text-sm text-amber-700">
            <p><strong>Important:</strong> This release note has been invoiced
              (<%= link_to @release_note.invoice_item.invoice.display_name, @release_note.invoice_item.invoice,
                  class: "font-medium underline hover:no-underline" %>).
            </p>
            <ul class="mt-2 list-disc list-inside">
              <li><strong>Remarks:</strong> Can be updated freely - will appear in updated PDFs</li>
              <li><strong>Quantities:</strong> Can be updated for record accuracy, but <strong>will not affect the invoice amounts</strong></li>
              <li><strong>Other fields:</strong> Specification, customer details, etc. are pulled from the part/works order and will update automatically in PDFs</li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  <% end %>

  <!-- Shipping Charges Warning for All Deliveries (excluding Lufthansa) -->
  <%
    is_lufthansa = @works_order&.customer&.name&.downcase&.include?('lufthansa')
    show_shipping_warning = !@release_note.persisted? && !is_lufthansa
  %>
  <% if show_shipping_warning %>
    <% selected_charges = @works_order.get_selected_additional_charges %>
    <% has_charges = selected_charges.any? %>

    <div class="<%= has_charges ? 'bg-blue-50 border-blue-200' : 'bg-amber-50 border-amber-200' %> border rounded-md p-4 mb-6">
      <div class="flex">
        <div class="flex-shrink-0">
          <% if has_charges %>
            <svg class="h-5 w-5 text-blue-400" viewBox="0 0 20 20" fill="currentColor">
              <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7-4a1 1 0 11-2 0 1 1 0 012 0zM9 9a1 1 0 000 2v3a1 1 0 001 1h1a1 1 0 100-2v-3a1 1 0 00-1-1H9z" clip-rule="evenodd" />
            </svg>
          <% else %>
            <svg class="h-5 w-5 text-amber-400" viewBox="0 0 20 20" fill="currentColor">
              <path fill-rule="evenodd" d="M8.257 3.099c.765-1.36 2.722-1.36 3.486 0l5.58 9.92c.75 1.334-.213 2.98-1.742 2.98H4.42c-1.53 0-2.493-1.646-1.743-2.98l5.58-9.92zM11 13a1 1 0 11-2 0 1 1 0 012 0zm-1-8a1 1 0 00-1 1v3a1 1 0 002 0V6a1 1 0 00-1-1z" clip-rule="evenodd" />
            </svg>
          <% end %>
        </div>
        <div class="ml-3">
          <h3 class="text-sm font-medium <%= has_charges ? 'text-blue-800' : 'text-amber-800' %>">
            <%= has_charges ? 'Shipping Charges Configured' : 'Shipping Charges - Check Required' %>
          </h3>
          <div class="mt-2 text-sm <%= has_charges ? 'text-blue-700' : 'text-amber-700' %>">
            <% if has_charges %>
              <p class="mb-2">The following shipping charges are configured for this order:</p>
              <ul class="list-disc list-inside mb-2">
                <% selected_charges.each do |charge| %>
                  <%
                    custom_amount = @works_order.get_custom_amount(charge.id)
                    amount = (charge.is_variable? && custom_amount.present? ? custom_amount.to_f : (charge.amount || 0).to_f)
                  %>
                  <li><strong><%= charge.name %></strong>: £<%= sprintf("%.2f", amount) %></li>
                <% end %>
              </ul>
              <p class="text-xs">
                Total additional charges: <strong>£<%= sprintf("%.2f", @works_order.calculate_additional_charges_total(@works_order.selected_charge_ids, @works_order.custom_amounts || {})) %></strong>
              </p>
              <p class="mt-2 text-xs">
                Need to modify charges?
                <%= link_to "Edit works order charges", edit_works_order_path(@works_order),
                    target: "_blank",
                    class: "font-medium underline hover:no-underline" %>
                (opens in new tab - won't lose your measurements)
              </p>
            <% else %>
              <p class="mb-2"><strong>Check shipping charges:</strong> No shipping charges are currently configured for this works order.</p>
              <p class="mb-2">
                If this order needs shipping charges (DPD, courier, special handling, etc.):
                <%= link_to "Add charges to the works order →", edit_works_order_path(@works_order),
                    target: "_blank",
                    class: "font-medium underline hover:no-underline inline-flex items-center" %>
                <span class="ml-1 text-xs">(opens in new tab - won't lose your measurements)</span>
              </p>
              <p class="text-xs">If the customer is collecting or no charges apply, just tick the confirmation box below.</p>
            <% end %>

            <div class="mt-4 pt-4 border-t <%= has_charges ? 'border-blue-200' : 'border-amber-200' %>">
              <label class="flex items-start">
                <input type="checkbox"
                       id="shipping_charges_acknowledged"
                       required
                       class="rounded border-gray-300 text-blue-600 shadow-sm focus:border-blue-300 focus:ring focus:ring-offset-0 focus:ring-blue-200 focus:ring-opacity-50 mt-0.5 flex-shrink-0">
                <span class="ml-2 text-sm <%= has_charges ? 'text-blue-800' : 'text-amber-800' %>">
                  <% if has_charges %>
                    <strong>I confirm</strong> the shipping charges shown above are correct for this delivery.
                  <% else %>
                    <strong>I confirm</strong> I have checked whether shipping charges are needed, and either added them or confirmed none apply (customer collecting, etc.).
                  <% end %>
                </span>
              </label>
            </div>
          </div>
        </div>
      </div>
    </div>
  <% end %>

  <div class="bg-white shadow-sm rounded-lg">
    <div class="px-4 py-5 sm:p-6">
      <div class="grid grid-cols-1 gap-y-6 gap-x-4 sm:grid-cols-6">

        <!-- Date Field -->
        <div class="sm:col-span-2">
          <%= form.label :date, class: "block text-sm font-medium text-gray-700" %>
          <%= form.date_field :date, class: "mt-1 block w-full border-gray-300 rounded-md shadow-sm focus:ring-blue-500 focus:border-blue-500 sm:text-sm" %>
        </div>

        <!-- Quantity Accepted with Invoice Warning -->
        <div class="sm:col-span-2">
          <%= form.label :quantity_accepted, class: "block text-sm font-medium text-gray-700" %>
          <%= form.number_field :quantity_accepted,
                                id: "release_note_quantity_accepted",
                                min: 0,
                                max: @release_note.invoiced? ? nil : @works_order&.unreleased_quantity,
                                class: "mt-1 block w-full border-gray-300 rounded-md shadow-sm focus:ring-blue-500 focus:border-blue-500 sm:text-sm" %>
          <% if @release_note.invoiced? %>
            <p class="mt-1 text-xs text-amber-600">
              <strong>Invoice Impact:</strong> Changes will not affect
              <%= link_to @release_note.invoice_item.invoice.display_name, @release_note.invoice_item.invoice,
                  class: "font-medium underline hover:no-underline" %>
              (£<%= sprintf("%.2f", @release_note.invoice_item.line_amount_inc_tax) %>)
            </p>
            <% if defined?(@original_quantity_accepted) && @original_quantity_accepted != @release_note.quantity_accepted %>
              <p class="mt-1 text-xs text-amber-600">
                Original invoiced quantity: <%= @original_quantity_accepted %>
              </p>
            <% end %>
          <% else %>
            <p class="mt-1 text-xs text-gray-500">
              Maximum: <%= @works_order&.unreleased_quantity || 0 %> (remaining unreleased)
            </p>
          <% end %>
        </div>

        <!-- Quantity Rejected with Invoice Warning -->
        <div class="sm:col-span-2">
          <%= form.label :quantity_rejected, class: "block text-sm font-medium text-gray-700" %>
          <%= form.number_field :quantity_rejected,
                                min: 0,
                                max: @release_note.invoiced? ? nil : @works_order&.unreleased_quantity,
                                class: "mt-1 block w-full border-gray-300 rounded-md shadow-sm focus:ring-blue-500 focus:border-blue-500 sm:text-sm" %>
          <% if @release_note.invoiced? %>
            <p class="mt-1 text-xs text-amber-600">
              <strong>Note:</strong> Rejected quantity changes are for record keeping only
            </p>
            <% if defined?(@original_quantity_rejected) && @original_quantity_rejected != @release_note.quantity_rejected %>
              <p class="mt-1 text-xs text-amber-600">
                Original quantity: <%= @original_quantity_rejected %>
              </p>
            <% end %>
          <% end %>
        </div>

        <!-- ================================================================
             Thickness Measurements Section
             Supports multiple batches per treatment.
             Standard anodic: 8 readings per batch.
             MIL-PRF-8625F Type III: NADCAP sample plan based on parts per batch.
             ENP: A-F (6 points) per batch.
             ================================================================ -->
        <% if @release_note.requires_thickness_measurements? %>
          <div class="sm:col-span-6">
            <div class="border-t border-gray-200 pt-6">
              <h3 class="text-lg font-medium text-gray-900 mb-1">
                Thickness Measurements
                <span class="text-sm font-normal text-gray-500">(Required for Aerospace/Defense)</span>
              </h3>
              <p class="text-xs text-gray-500 mb-4">
                Audit requirement: <strong>8 readings per sampled part</strong>.
                Standard anodic films use 1 part per batch; MIL-PRF-8625F Type III follows the NADCAP sample plan based on parts per batch.
                Use "Number of Batches" to record measurements from multiple production batches on a single release.
              </p>

              <div class="space-y-8">
                <% @release_note.get_required_treatments.each do |treatment| %>
                  <%
                    treatment_id  = treatment[:treatment_id]
                    display_name  = treatment[:display_name]
                    process_type  = treatment[:process_type]
                    is_enp        = @release_note.treatment_is_enp?(process_type)
                    is_nadcap     = treatment[:requires_nadcap_sampling]
                    target_thickness = treatment[:target_thickness]
                    max_batches   = 20
                    saved_batch_count = @release_note.persisted? ? @release_note.get_batch_count(treatment_id) : 1
                  %>

                  <!-- Treatment outer card -->
                  <div class="border border-gray-300 rounded-lg overflow-hidden"
                       data-treatment-section="<%= treatment_id %>">

                    <!-- Treatment title bar -->
                    <div class="bg-gray-100 border-b border-gray-300 px-4 py-3 flex items-center justify-between">
                      <div>
                        <span class="text-sm font-semibold text-gray-800"><%= display_name %></span>
                        <% unless is_enp %>
                          <span class="ml-2 text-xs text-gray-500">Target: <%= target_thickness %> µm</span>
                        <% end %>
                        <% if is_nadcap %>
                          <span class="ml-2 inline-flex items-center px-2 py-0.5 rounded-full text-xs font-semibold bg-amber-100 text-amber-800">
                            MIL-PRF-8625F Type III · NADCAP sample plan
                          </span>
                        <% end %>
                        <span class="text-red-500 ml-1">*</span>
                      </div>

                      <!-- Batch count selector -->
                      <div class="flex items-center gap-2">
                        <label for="batch_count_<%= treatment_id %>"
                               class="text-xs font-medium text-gray-600 whitespace-nowrap">
                          Number of Batches:
                        </label>
                        <select id="batch_count_<%= treatment_id %>"
                                class="text-sm border-gray-300 rounded-md shadow-sm focus:ring-blue-500 focus:border-blue-500 py-1"
                                onchange="setBatchCount('<%= treatment_id %>', this.value, '<%= is_enp ? 'enp' : 'anodic' %>')">
                          <% (1..max_batches).each do |n| %>
                            <option value="<%= n %>" <%= 'selected' if n == saved_batch_count %>><%= n %></option>
                          <% end %>
                        </select>
                      </div>
                    </div>

                    <!-- Batch containers -->
                    <div class="divide-y divide-gray-200">
                      <% max_batches.times do |batch_idx| %>
                        <% batch_number     = batch_idx + 1 %>
                        <% batch_tid        = "#{treatment_id}_b#{batch_number}" %>

                        <div id="batch_container_<%= treatment_id %>_<%= batch_number %>"
                             class="p-4"
                             style="<%= 'display:none;' if batch_number > saved_batch_count %>">

                          <!-- Batch label (visible only when >1 batch selected) -->
                          <div id="batch_label_<%= treatment_id %>_<%= batch_number %>"
                               class="flex items-center gap-3 mb-3"
                               style="<%= 'display:none;' if saved_batch_count == 1 %>">
                            <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-semibold bg-blue-100 text-blue-800">
                              Batch <%= batch_number %>
                            </span>
                            <div class="flex-1 h-px bg-blue-100"></div>
                          </div>

                          <% if is_enp %>
                            <%#
                              ---- ENP batch container ----
                              Each batch gets its own data-enp-section keyed as treatment_id_b{n}.
                              The ENP JS functions all route through that key so they work independently.
                            %>
                            <%
                              existing_enp = @release_note.get_enp_measurements_for_batch(treatment_id, batch_number)
                            %>

                            <div data-enp-section="<%= batch_tid %>"
                                 class="bg-gray-50 rounded-md">

                              <!-- ENP header row -->
                              <div class="flex items-center justify-between mb-3">
                                <p class="text-xs text-gray-500">6 measurement points (A–F) · before &amp; after</p>
                                <div class="flex gap-2">
                                  <span class="enp-progress text-sm text-gray-500">0/6 complete</span>
                                  <button type="button"
                                          onclick="clearENPMeasurements('<%= batch_tid %>')"
                                          class="inline-flex items-center px-2 py-1 border border-gray-300 rounded text-xs font-medium text-gray-600 bg-white hover:bg-gray-50">
                                    <svg class="h-3 w-3 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
                                    </svg>
                                    Clear
                                  </button>
                                </div>
                              </div>

                              <!-- Statistics display -->
                              <div class="enp-statistics mb-3"></div>

                              <!-- A-F table -->
                              <div class="overflow-hidden border border-gray-200 rounded-md mb-3">
                                <table class="min-w-full divide-y divide-gray-200">
                                  <thead class="bg-gray-100">
                                    <tr>
                                      <th class="px-3 py-2 text-left text-xs font-medium text-gray-700 uppercase">Point</th>
                                      <th class="px-3 py-2 text-left text-xs font-medium text-gray-700 uppercase">Before (mm)</th>
                                      <th class="px-3 py-2 text-left text-xs font-medium text-gray-700 uppercase">After (mm)</th>
                                      <th class="px-3 py-2 text-left text-xs font-medium text-gray-700 uppercase">Film Thickness (µm)</th>
                                    </tr>
                                  </thead>
                                  <tbody class="bg-white divide-y divide-gray-200">
                                    <% ['A', 'B', 'C', 'D', 'E', 'F'].each_with_index do |point, index| %>
                                      <%
                                        existing_point = existing_enp.find { |m| m['point'] == point }
                                        start_value    = existing_point ? existing_point['start_mm'] : nil
                                        finish_value   = existing_point ? existing_point['finish_mm'] : nil
                                      %>
                                      <tr>
                                        <td class="px-3 py-2 text-sm font-medium text-gray-900"><%= point %></td>
                                        <td class="px-3 py-2">
                                          <input type="number"
                                                 class="enp-start block w-full text-sm border-gray-300 rounded-md shadow-sm focus:ring-blue-500 focus:border-blue-500"
                                                 data-treatment="<%= batch_tid %>"
                                                 data-index="<%= index %>"
                                                 step="0.001" min="0"
                                                 value="<%= start_value %>"
                                                 onblur="updateENPMeasurement(this)"
                                                 placeholder="10.500" />
                                        </td>
                                        <td class="px-3 py-2">
                                          <input type="number"
                                                 class="enp-finish block w-full text-sm border-gray-300 rounded-md shadow-sm focus:ring-blue-500 focus:border-blue-500"
                                                 data-treatment="<%= batch_tid %>"
                                                 data-index="<%= index %>"
                                                 step="0.001" min="0"
                                                 value="<%= finish_value %>"
                                                 onblur="updateENPMeasurement(this)"
                                                 placeholder="10.525" />
                                        </td>
                                        <td class="px-3 py-2">
                                          <span class="enp-growth text-sm text-gray-500" data-index="<%= index %>">—</span>
                                        </td>
                                      </tr>
                                    <% end %>
                                  </tbody>
                                </table>
                              </div>
                              <p class="text-xs text-gray-500">
                                <strong>Auto-fill:</strong> Enter "Before" for point A and press TAB – all points copy automatically.<br>
                                <strong>Calculation:</strong> Film thickness (µm) = (After − Before) × 1000 ÷ 2 (plated both sides).
                              </p>

                              <!-- Hidden field stores ENP data for this batch -->
                              <%= hidden_field_tag "enp_measurements_#{batch_tid}",
                                                  existing_enp.to_json,
                                                  class: "enp-data" %>
                            </div>

                          <% elsif is_nadcap %>
                            <%#
                              ---- NADCAP sample-plan batch container ----
                              For MIL-PRF-8625F Type III hard anodise. User enters parts-in-batch,
                              JS computes sample size, renders sample_size × 8 inputs labelled
                              B{n}p{m}. Hidden field carries a JSON object payload.
                            %>
                            <%
                              nadcap_data = @release_note.get_nadcap_data_for_batch(treatment_id, batch_number)
                            %>

                            <div data-controller="nadcap-sampling"
                                 data-nadcap-sampling-treatment-id-value="<%= batch_tid %>"
                                 data-nadcap-sampling-batch-number-value="<%= batch_number %>"
                                 data-nadcap-sampling-batch-label-value="B<%= batch_number %>"
                                 data-nadcap-sampling-process-type-value="<%= process_type %>"
                                 data-nadcap-sampling-target-thickness-value="<%= target_thickness %>"
                                 data-nadcap-sampling-display-name-value="<%= display_name %>"
                                 class="bg-gray-50 rounded-md p-3">

                              <!-- Header: parts-per-batch input + Elcometer / Clear buttons -->
                              <div class="flex items-center justify-between mb-3 flex-wrap gap-3">
                                <div class="flex items-center gap-2">
                                  <label class="text-xs font-medium text-gray-700 whitespace-nowrap">
                                    Parts in this batch:
                                  </label>
                                  <input type="number" min="1"
                                         data-nadcap-sampling-target="partsPerBatchInput"
                                         data-action="change->nadcap-sampling#updateSampleSize"
                                         value="<%= nadcap_data[:parts_per_batch] %>"
                                         class="w-24 text-sm border-gray-300 rounded-md shadow-sm focus:ring-blue-500 focus:border-blue-500" />
                                  <span data-nadcap-sampling-target="sampleSizeDisplay"
                                        class="text-xs text-gray-600 ml-2"></span>
                                </div>

                                <div class="flex gap-2">
                                  <!-- Connect Button -->
                                  <button type="button"
                                          data-nadcap-sampling-target="connectButton"
                                          data-action="click->nadcap-sampling#connectElcometer"
                                          class="inline-flex items-center px-3 py-1.5 border border-blue-600 rounded text-xs font-medium text-blue-600 bg-white hover:bg-blue-50 focus:outline-none focus:ring-2 focus:ring-offset-1 focus:ring-blue-500">
                                    <svg class="h-3.5 w-3.5 mr-1.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/>
                                    </svg>
                                    Connect Elcometer
                                  </button>

                                  <!-- Stop Button (hidden initially) -->
                                  <button type="button"
                                          data-nadcap-sampling-target="stopButton"
                                          data-action="click->nadcap-sampling#stopReading"
                                          class="hidden inline-flex items-center px-3 py-1.5 border border-red-600 rounded text-xs font-medium text-red-600 bg-white hover:bg-red-50">
                                    <svg class="h-3.5 w-3.5 mr-1.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
                                    </svg>
                                    Stop
                                  </button>

                                  <!-- Clear Button -->
                                  <button type="button"
                                          data-action="click->nadcap-sampling#clearReadings"
                                          class="inline-flex items-center px-3 py-1.5 border border-gray-300 rounded text-xs font-medium text-gray-700 bg-white hover:bg-gray-50">
                                    <svg class="h-3.5 w-3.5 mr-1.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
                                    </svg>
                                    Clear
                                  </button>
                                </div>
                              </div>

                              <!-- Batch-level statistics (rendered by the controller) -->
                              <div data-nadcap-sampling-target="statistics" class="mb-3"></div>

                              <!-- Parts grid: B{n}p1, B{n}p2, ... (rendered by the controller) -->
                              <div data-nadcap-sampling-target="partsContainer" class="space-y-2"></div>

                              <p class="mt-2 text-xs text-gray-500">
                                MIL-PRF-8625F Type III · 8 readings per sampled part · Enter readings and press TAB, or connect the Elcometer.
                              </p>

                              <!-- Hidden field carries the NADCAP JSON payload -->
                              <%= hidden_field_tag "thickness_readings_#{batch_tid}",
                                                   @release_note.get_nadcap_json_for_batch(treatment_id, batch_number),
                                                   data: { nadcap_sampling_target: "readingsData" } %>
                            </div>

                          <% else %>
                            <%#
                              ---- Anodic / Elcometer batch container ----
                              Each batch gets its own data-controller="elcometer" so Stimulus
                              manages it independently. The treatment-id value is batch_tid
                              (e.g. "abc123_b1") so the hidden field becomes
                              thickness_readings_abc123_b1, which the submit handler groups back
                              into the batches payload.
                            %>
                            <%
                              batch_readings = @release_note.get_thickness_readings_for_batch(treatment_id, batch_number)
