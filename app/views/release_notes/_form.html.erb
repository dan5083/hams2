                                    <svg class="h-3.5 w-3.5 mr-1.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
                                    </svg>
                                    Clear
                                  </button>
                                </div>
                              </div>

                              <!-- Statistics Display -->
                              <div data-elcometer-target="statistics" class="mb-3"></div>

                              <!-- Readings Display -->
                              <div class="mb-3">
                                <label class="block text-xs font-medium text-gray-500 mb-1">Readings:</label>
                                <div data-elcometer-target="readingsList"
