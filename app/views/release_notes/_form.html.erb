    <!-- Form Actions -->
    <div class="px-4 py-3 bg-gray-50 text-right sm:px-6">
      <%= link_to 'Cancel', @release_note.persisted? ? @release_note : @works_order,
                  class: "bg-white py-2 px-4 border border-gray-300 rounded-md shadow-sm text-sm font-medium text-gray-700 hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 mr-3" %>
      <%= form.submit (@release_note.persisted? ? "Update Release Note" : "Create Release Note"),
                      class: "inline-flex justify-center py-2 px-4 border border-transparent shadow-sm text-sm font-medium rounded-md text-white bg-blue-600 hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500" %>
    </div>
  </div>

  <!-- JavaScript for auto-populating quantity accepted -->
  <% unless @release_note.invoiced? %>
    <script>
      (function() {
        function autoPopulateQuantity() {
          const quantityField = document.getElementById('release_note_quantity_accepted');
          if (!quantityField) { setTimeout(autoPopulateQuantity, 100); return; }

          const currentValue = parseInt(quantityField.value) || 0;
          const maxQuantity  = parseInt(quantityField.getAttribute('max')) || 0;

          if (currentValue === 0 && maxQuantity > 0) {
            quantityField.value = maxQuantity;
            quantityField.classList.add('ring-2', 'ring-amber-400', 'bg-amber-50');
            setTimeout(() => quantityField.classList.remove('ring-2', 'ring-amber-400', 'bg-amber-50'), 2000);

            const notification = document.createElement('div');
            notification.className = 'fixed top-4 right-4 z-50 bg-amber-50 border border-amber-200 text-amber-800 rounded-md p-4 shadow-lg max-w-md';
            notification.innerHTML = `
              <div class="flex items-start">
                <div class="flex-shrink-0">
                  <svg class="h-5 w-5 text-amber-400" viewBox="0 0 20 20" fill="currentColor">
                    <path fill-rule="evenodd" d="M8.257 3.099c.765-1.36 2.722-1.36 3.486 0l5.58 9.92c.75 1.334-.213 2.98-1.742 2.98H4.42c-1.53 0-2.493-1.646-1.743-2.98l5.58-9.92zM11 13a1 1 0 11-2 0 1 1 0 012 0zm-1-8a1 1 0 00-1 1v3a1 1 0 002 0V6a1 1 0 00-1-1z" clip-rule="evenodd"/>
                  </svg>
                </div>
                <div class="ml-3 flex-1">
                  <p class="text-sm font-medium">Quantity Accepted Auto-Populated</p>
                  <p class="mt-1 text-sm">Set to ${maxQuantity} (all unreleased parts). Please adjust if you're releasing fewer parts or have rejections.</p>
                </div>
                <button class="ml-3 text-amber-400 hover:text-amber-600" onclick="this.parentElement.parentElement.remove()">
                  <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z" clip-rule="evenodd"/>
                  </svg>
                </button>
              </div>
            `;
            document.body.appendChild(notification);
            setTimeout(() => notification.remove(), 8000);
          }
        }
        autoPopulateQuantity();
        if (document.readyState === 'loading') {
          document.addEventListener('DOMContentLoaded', autoPopulateQuantity);
        }
      })();
    </script>
  <% end %>

  <!-- ========================================================================
       JavaScript for thickness measurements - batch-aware submit handler
       and batch count switcher.
       ======================================================================== -->
  <% if @release_note.requires_thickness_measurements? %>
    <script>
      // --------------------------------------------------------------------
      // setBatchCount – show/hide batch containers and their labels
      // Called by the "Number of Batches" dropdown for each treatment.
      // --------------------------------------------------------------------
      function setBatchCount(treatmentId, newCountStr, type) {
        const newCount  = parseInt(newCountStr);
        const maxBatches = 20;

        for (let batch = 1; batch <= maxBatches; batch++) {
          const container = document.getElementById(`batch_container_${treatmentId}_${batch}`);
          const label     = document.getElementById(`batch_label_${treatmentId}_${batch}`);

          if (container) {
            container.style.display = (batch <= newCount) ? '' : 'none';
          }
          if (label) {
            // Show batch labels only when there's more than one batch
            label.style.display = (newCount > 1) ? '' : 'none';
          }
        }
      }

      // --------------------------------------------------------------------
      // Submit handler – collects per-batch readings and ENP measurements,
      // groups them by treatment_id (stripping the _b{n} suffix), and
      // builds the batches JSON payload for release_note[measured_thicknesses].
      //
      // Anodic hidden fields hold one of two shapes:
      //   Legacy/standard: a JSON array of readings  [70.5, 70.7, ...]
      //   NADCAP:          a JSON object             {parts_per_batch, parts: [...]}
      // The handler detects which and assembles the batches accordingly.
      // --------------------------------------------------------------------
      document.addEventListener('DOMContentLoaded', function() {
        const form = document.querySelector('form');
        if (!form) return;

        form.addEventListener('submit', function() {
          // --- Anodic readings ---
          // Field names: thickness_readings_<treatment_id>_b<n>
          const treatmentBatches = {};  // pure_treatment_id -> { batch_number -> batchValue }
          const treatmentMeta    = {};  // pure_treatment_id -> { process_type, target_thickness, display_name }

          document.querySelectorAll('[name^="thickness_readings_"]').forEach(function(field) {
            const nameBody = field.name.replace('thickness_readings_', '');
            let treatmentId, batchNumber;

            const m = nameBody.match(/^(.+)_b(\d+)$/);
            if (m) {
              treatmentId  = m[1];
              batchNumber  = parseInt(m[2]);
            } else {
              treatmentId  = nameBody;
              batchNumber  = 1;
            }

            let parsed = null;
            try { parsed = JSON.parse(field.value || '[]'); } catch(e) {}
            if (parsed == null) return;

            // Detect NADCAP shape vs flat readings array
            const isNadcap = typeof parsed === 'object'
                             && !Array.isArray(parsed)
                             && Array.isArray(parsed.parts);

            if (isNadcap && parsed.parts.length > 0) {
              if (!treatmentBatches[treatmentId]) treatmentBatches[treatmentId] = {};
              treatmentBatches[treatmentId][batchNumber] = {
                parts_per_batch: parsed.parts_per_batch,
                parts:           parsed.parts,
                readings:        parsed.parts.flatMap(p => p.readings || [])
              };

              if (!treatmentMeta[treatmentId]) {
                const ctrl = field.closest('[data-controller="nadcap-sampling"]');
                if (ctrl) {
                  treatmentMeta[treatmentId] = {
                    process_type:     ctrl.dataset.nadcapSamplingProcessTypeValue,
                    target_thickness: parseFloat(ctrl.dataset.nadcapSamplingTargetThicknessValue) || 0,
                    display_name:     ctrl.dataset.nadcapSamplingDisplayNameValue
                  };
                }
              }
            } else if (Array.isArray(parsed) && parsed.length > 0) {
              // Standard anodic: flat readings array
              if (!treatmentBatches[treatmentId]) treatmentBatches[treatmentId] = {};
              treatmentBatches[treatmentId][batchNumber] = { readings: parsed };

              if (!treatmentMeta[treatmentId]) {
                const ctrl = field.closest('[data-controller="elcometer"]');
                if (ctrl) {
                  treatmentMeta[treatmentId] = {
                    process_type:     ctrl.dataset.elcometerProcessTypeValue,
                    target_thickness: parseFloat(ctrl.dataset.elcometerTargetThicknessValue) || 0,
                    display_name:     ctrl.dataset.elcometerDisplayNameValue
                  };
                }
              }
            }
          });

          // --- ENP measurements ---
          // Field names: enp_measurements_<treatment_id>_b<n>
          const enpBatches = {};  // pure_treatment_id -> { batch_number -> enp_measurements[] }

          document.querySelectorAll('[name^="enp_measurements_"]').forEach(function(field) {
            const nameBody = field.name.replace('enp_measurements_', '');
            let treatmentId, batchNumber;

            const m = nameBody.match(/^(.+)_b(\d+)$/);
            if (m) {
              treatmentId = m[1];
              batchNumber = parseInt(m[2]);
            } else {
              treatmentId = nameBody;
              batchNumber = 1;
            }

            let enp = [];
            try { enp = JSON.parse(field.value || '[]'); } catch(e) {}

            if (enp.length > 0) {
              if (!enpBatches[treatmentId]) enpBatches[treatmentId] = {};
              enpBatches[treatmentId][batchNumber] = enp;
            }
          });

          // --- Build final measurements array ---
          const measurements = [];

          // Anodic
          Object.entries(treatmentBatches).forEach(([treatmentId, batchesObj]) => {
            const batches = Object.entries(batchesObj)
              .map(([bNum, val]) => {
                const batch = { batch_number: parseInt(bNum), readings: val.readings || [] };
                if (val.parts_per_batch != null) batch.parts_per_batch = val.parts_per_batch;
                if (val.parts != null)           batch.parts           = val.parts;
                return batch;
              })
              .sort((a, b) => a.batch_number - b.batch_number);

            measurements.push({
              treatment_id: treatmentId,
              ...(treatmentMeta[treatmentId] || {}),
              batches
            });
          });

          // ENP
          Object.entries(enpBatches).forEach(([treatmentId, batchesObj]) => {
            const existing = measurements.find(m => m.treatment_id === treatmentId);
            const batches = Object.entries(batchesObj)
              .map(([bNum, enp]) => ({ batch_number: parseInt(bNum), enp_measurements: enp }))
              .sort((a, b) => a.batch_number - b.batch_number);

            if (existing) {
              existing.batches = batches;
            } else {
              measurements.push({ treatment_id: treatmentId, batches });
            }
          });

          if (measurements.length > 0) {
            const hiddenField = document.createElement('input');
            hiddenField.type  = 'hidden';
            hiddenField.name  = 'release_note[measured_thicknesses]';
            hiddenField.value = JSON.stringify({ measurements });
            form.appendChild(hiddenField);
          }
        });
      });
    </script>

    <!-- ====================================================================
         ENP JavaScript
         Keys in enpData are now batch_tid values (e.g. "abc123_b1")
         so each batch maintains independent state.
         ==================================================================== -->
    <script>
      const enpData = {};

      function updateENPMeasurement(input) {
        const treatmentId = input.dataset.treatment; // e.g. "abc123_b1"
        const index       = parseInt(input.dataset.index);
        const isStart     = input.classList.contains('enp-start');

        if (!enpData[treatmentId]) {
          enpData[treatmentId] = [{}, {}, {}, {}, {}, {}];
        }

        const value = parseFloat(input.value);

        if (isStart) {
          if (!isNaN(value) && value > 0) {
            enpData[treatmentId][index].start_mm = value;
            enpData[treatmentId][index].point    = String.fromCharCode(65 + index);

            // Auto-fill: copy point A's before-value to all other points
            if (index === 0) {
              for (let i = 1; i < 6; i++) {
                enpData[treatmentId][i].start_mm = value;
                enpData[treatmentId][i].point    = String.fromCharCode(65 + i);

                const section      = document.querySelector(`[data-enp-section="${treatmentId}"]`);
                const startInputs  = section.querySelectorAll('.enp-start');
                startInputs[i].value = value;
                startInputs[i].classList.add('ring-2', 'ring-blue-400', 'bg-blue-50');
                setTimeout(() => startInputs[i].classList.remove('ring-2', 'ring-blue-400', 'bg-blue-50'), 800);

                if (enpData[treatmentId][i].finish_mm) {
                  const diff = enpData[treatmentId][i].finish_mm - value;
                  enpData[treatmentId][i].growth_um = Math.round((diff * 1000 / 2) * 10) / 10;
                }
              }
              showENPNotification('Initial size copied to all measurement points', 'success');
            }
          } else if (input.value === '') {
            delete enpData[treatmentId][index].start_mm;
          }
        } else {
          if (!isNaN(value) && value > 0) {
            enpData[treatmentId][index].finish_mm = value;
            enpData[treatmentId][index].point     = String.fromCharCode(65 + index);
          } else if (input.value === '') {
            delete enpData[treatmentId][index].finish_mm;
          }
        }

        // Calculate growth (divide by 2 for dual-sided plating)
        const measurement = enpData[treatmentId][index];
        if (measurement.start_mm && measurement.finish_mm) {
          const diff = measurement.finish_mm - measurement.start_mm;
          measurement.growth_um = Math.round((diff * 1000 / 2) * 10) / 10;
        } else {
          measurement.growth_um = null;
        }

        updateENPDisplay(treatmentId);
        saveENPToHiddenField(treatmentId);
      }

      function updateENPDisplay(treatmentId) {
        const section = document.querySelector(`[data-enp-section="${treatmentId}"]`);
        if (!section) return;

        // Update growth displays
        section.querySelectorAll('.enp-growth').forEach((display, index) => {
          const measurement = enpData[treatmentId][index];
          if (measurement && measurement.growth_um !== null && measurement.growth_um !== undefined) {
            display.textContent = `${measurement.growth_um} µm`;
            display.classList.remove('text-gray-500');
            display.classList.add('text-gray-900', 'font-medium');
          } else {
            display.textContent = '—';
            display.classList.remove('text-gray-900', 'font-medium');
            display.classList.add('text-gray-500');
          }
        });

        // Update statistics
        const validMeasurements = enpData[treatmentId].filter(m =>
          m && m.growth_um !== null && m.growth_um !== undefined && m.growth_um >= 0
        );

        const statsDiv = section.querySelector('.enp-statistics');
        if (validMeasurements.length > 0) {
          const growths = validMeasurements.map(m => m.growth_um);
          const count   = growths.length;
          const mean    = Math.round((growths.reduce((a, b) => a + b, 0) / count) * 10) / 10;
          const min     = Math.min(...growths);
          const max     = Math.max(...growths);

          statsDiv.innerHTML = `
            <div class="grid grid-cols-4 gap-4 p-3 bg-gray-50 rounded-md">
              <div><div class="text-xs text-gray-500">Count</div><div class="text-lg font-semibold text-gray-900">${count}</div></div>
              <div><div class="text-xs text-gray-500">Mean Film Thickness</div><div class="text-lg font-semibold text-blue-600">${mean} µm</div></div>
              <div><div class="text-xs text-gray-500">Min</div><div class="text-lg font-semibold text-gray-900">${min} µm</div></div>
              <div><div class="text-xs text-gray-500">Max</div><div class="text-lg font-semibold text-gray-900">${max} µm</div></div>
            </div>
          `;
        } else {
          statsDiv.innerHTML = '';
        }

        // Update progress counter
        const progressSpan = section.querySelector('.enp-progress');
        if (progressSpan) {
          const completedCount = enpData[treatmentId].filter(m =>
            m && m.growth_um !== null && m.growth_um !== undefined
          ).length;
          progressSpan.textContent = `${completedCount}/6 complete`;
        }
      }

      function saveENPToHiddenField(treatmentId) {
        // Field name: enp_measurements_<treatmentId>  where treatmentId is already the batch_tid
        const hiddenField = document.querySelector(`[name="enp_measurements_${treatmentId}"]`);
        if (!hiddenField) return;

        const validMeasurements = enpData[treatmentId]
          .map((m, index) => {
            if (!m || (!m.start_mm && !m.finish_mm)) return null;
            return {
              point:      String.fromCharCode(65 + index),
              start_mm:   m.start_mm  || null,
              finish_mm:  m.finish_mm || null,
              growth_um:  m.growth_um || null
            };
          })
          .filter(m => m !== null);

        hiddenField.value = JSON.stringify(validMeasurements);
      }

      function clearENPMeasurements(treatmentId) {
        if (!confirm('Clear all ENP measurements for this batch?')) return;
        enpData[treatmentId] = [{}, {}, {}, {}, {}, {}];

        const section = document.querySelector(`[data-enp-section="${treatmentId}"]`);
        section.querySelectorAll('.enp-start').forEach(i => i.value = '');
        section.querySelectorAll('.enp-finish').forEach(i => i.value = '');

        updateENPDisplay(treatmentId);
        saveENPToHiddenField(treatmentId);
        showENPNotification('ENP measurements cleared', 'success');
      }

      function showENPNotification(message, type) {
        let container = document.getElementById('enp-notifications');
        if (!container) {
          container = document.createElement('div');
          container.id = 'enp-notifications';
          container.className = 'fixed top-4 right-4 z-50 space-y-2';
          document.body.appendChild(container);
        }

        const colors = {
          success: 'bg-green-50 border-green-200 text-green-800',
          error:   'bg-red-50 border-red-200 text-red-800'
        };

        const notification = document.createElement('div');
        notification.className = `${colors[type]} border rounded-md p-3 shadow-lg max-w-sm`;
        notification.innerHTML = `
          <div class="flex items-start">
            <div class="flex-1 text-sm">${message}</div>
            <button class="ml-3 text-gray-400 hover:text-gray-600" onclick="this.parentElement.parentElement.remove()">
              <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z" clip-rule="evenodd"/>
              </svg>
            </button>
          </div>
        `;
        container.appendChild(notification);
        setTimeout(() => notification.remove(), 4000);
      }

      // Initialise ENP data from existing values on page load
      // Iterates ALL data-enp-section elements (covers all batch containers)
      document.addEventListener('DOMContentLoaded', function() {
        document.querySelectorAll('[data-enp-section]').forEach(section => {
          const treatmentId = section.getAttribute('data-enp-section');
          const hiddenField = section.querySelector('.enp-data');

          enpData[treatmentId] = [{}, {}, {}, {}, {}, {}];

          if (hiddenField && hiddenField.value) {
            try {
              const data = JSON.parse(hiddenField.value);
              if (Array.isArray(data)) {
                data.forEach(m => {
                  const index = m.point.charCodeAt(0) - 65;
                  if (index >= 0 && index < 6) {
                    enpData[treatmentId][index] = {
                      point:     m.point,
                      start_mm:  m.start_mm,
                      finish_mm: m.finish_mm,
                      growth_um: m.growth_um
                    };
                  }
                });
              }
              updateENPDisplay(treatmentId);
            } catch (err) {
              console.error('Error loading ENP measurements for', treatmentId, err);
            }
          }
        });
      });
    </script>
  <% end %>

<% end %>
