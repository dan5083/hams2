                                </div>
                                <p class="mt-1 text-xs text-gray-500">
                                  Enter readings and press TAB. Values are added automatically.
                                </p>
                              </div>

                              <!-- Hidden field for this batch's readings -->
                              <%= hidden_field_tag "thickness_readings_#{batch_tid}",
                                                  batch_readings.to_json,
                                                  data: { elcometer_target: "readingsData" } %>
                            </div>
                          <% end %>
                        </div><!-- /batch container -->
                      <% end %><!-- /max_batches.times -->
                    </div><!-- /divide-y -->
