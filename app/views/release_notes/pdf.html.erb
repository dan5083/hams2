<!DOCTYPE html>
<html>
  <head>
    <meta charset="utf-8">
    <style>
      body {
        font-family: sans-serif;
        font-size: 9pt;
        margin: 0;
        padding: 1cm;
        --standard-border-width: 1pt;
        --standard-border-color: black;
        --standard-border-style: solid;
        box-sizing: border-box;
      }

      @page {
        size: A4 portrait;
        margin: 1cm;
      }

      /* ----------------------------------------------------------------
         Advice Note — single page, always starts on right/odd side
         ---------------------------------------------------------------- */
      .advice-note {
        page-break-before: right;
        page-break-after: always;
        padding: 0;
      }

      /* ----------------------------------------------------------------
         Certificate — starts on next sheet.
         body padding does not re-apply after a page break, so we add
         padding-top here to stop the logo sitting flush against the
         @page top margin.
         ---------------------------------------------------------------- */
      .certificate-page {
        page-break-before: always;
        padding: 0.8cm 0 0 0;
      }

      /* ----------------------------------------------------------------
         General layout
         ---------------------------------------------------------------- */
      .logo-header         { text-align: left; margin-bottom: 0.75rem; }
      .logo-header img     { max-width: 240px; height: auto; }

      .company-contact     { text-align: right; font-size: 7.5pt; color: #555; line-height: 1.2; }
      .company-contact a   { color: #555; text-decoration: none; }

      h1 { text-align: center; margin: 0.6rem 0; font-size: 1.2em; }
      h2 { font-size: 0.9em; margin: 0.6rem 0 0.3rem 0; font-weight: bold; }

      table { width: 100%; border-collapse: collapse; margin-bottom: 0.6rem; }
      th, td {
        border: var(--standard-border-width) var(--standard-border-style) var(--standard-border-color);
        padding: 0.3rem 0.4rem;
        vertical-align: top;
      }
      th { background-color: #f8f9fa; font-weight: bold; text-align: left; width: 30%; }

      .addresses          { table-layout: fixed; margin-bottom: 0.75rem; }
      .address            { width: 50%; vertical-align: top; padding: 0.4rem; }
      .address h2         { font-size: 0.85em; margin: 0 0 0.3rem 0; text-decoration: underline; }
      .address p          { margin: 0; line-height: 1.3; }

      .header-table       { margin-bottom: 0.75rem; }
      .detail-table       { margin-top: 0.5rem; margin-bottom: 0.75rem; }

      /* ----------------------------------------------------------------
         Advice-note order summary — one row per release note on the order
         ---------------------------------------------------------------- */
      .summary-table {
        width: 100%;
        border-collapse: collapse;
        margin-bottom: 0.75rem;
        font-size: 8pt;
      }
      .summary-table th {
        width: auto;                 /* override global th { width: 30% } */
        text-align: left;
        background-color: #f1f5f9;
        font-weight: bold;
        padding: 0.3rem 0.4rem;
        border: 1pt solid #94a3b8;
        white-space: nowrap;
      }
      .summary-table td {
        padding: 0.3rem 0.4rem;
        border: 1pt solid #cbd5e1;
        vertical-align: top;
      }
      .summary-table th.num,
      .summary-table td.num { text-align: right; white-space: nowrap; }
      .summary-table tfoot th,
      .summary-table tfoot td {
        background-color: #f8f9fa;
        font-weight: bold;
      }

      .signature-table    { table-layout: fixed; margin-top: 0.75rem; }
      .signature-table th { width: 25%; }
      .signature-table td { height: 2.5rem; }

      .signature-name {
        font-family: 'Times New Roman', serif;
        font-size: 1.1em;
        font-style: italic;
        font-weight: bold;
      }

      /* ----------------------------------------------------------------
         Thickness section header
         ---------------------------------------------------------------- */
      .thickness-group-header {
        background-color: #e9ecef;
        font-weight: bold;
        font-size: 9pt;
        padding: 0.2rem 0.4rem;
        border: 1pt solid #ccc;
        margin-bottom: 0.3rem;
      }

      /* Overall combined stats bar (multi-batch only) */
      .overall-stats {
        background-color: #eff6ff;
        border: 1pt solid #bfdbfe;
        padding: 0.25rem 0.4rem;
        margin-bottom: 0.35rem;
        font-size: 8pt;
        color: #1e40af;
      }
      .overall-stats strong { color: #1d4ed8; }

      /* ----------------------------------------------------------------
         Anodic compact table
         One row per batch: Batch | Mean | Min | Max | R1...R8
         ---------------------------------------------------------------- */
      .anodic-table {
        width: 100%;
        border-collapse: collapse;
        font-size: 8pt;
        margin-bottom: 0.5rem;
      }
      .anodic-table th {
        background-color: #f1f5f9;
        text-align: center;
        padding: 0.25rem 0.2rem;
        border: 1pt solid #94a3b8;
        font-size: 7.5pt;
        width: auto;
      }
      .anodic-table th.stat-col   { width: 6%; }
      .anodic-table th.reading-col { width: 6.5%; }
      .anodic-table td {
        text-align: center;
        padding: 0.25rem 0.2rem;
        border: 1pt solid #cbd5e1;
        vertical-align: middle;
      }
      .anodic-table td.batch-label {
        font-weight: bold;
        background-color: #eff6ff;
        color: #1d4ed8;
        white-space: nowrap;
      }
      .anodic-table td.stat-mean { font-weight: bold; color: #1d4ed8; }

      /* ----------------------------------------------------------------
         NADCAP sample-plan: batch sub-header above per-part table
         ---------------------------------------------------------------- */
      .nadcap-batch-label {
        font-size: 8pt;
        font-weight: bold;
        color: #1d4ed8;
        background-color: #eff6ff;
        border: 1pt solid #bfdbfe;
        padding: 0.25rem 0.4rem;
        margin: 0.4rem 0 0.2rem 0;
      }
      .nadcap-batch-label .stat {
        font-weight: normal;
        color: #1e3a8a;
        margin-left: 0.5rem;
      }

      /* ----------------------------------------------------------------
         ENP compact table (before / after / growth per point, per batch)
         ---------------------------------------------------------------- */
      .enp-batch-label {
        font-size: 8pt;
        font-weight: bold;
        color: #1d4ed8;
        padding: 0.15rem 0;
        margin: 0.3rem 0 0.15rem 0;
      }
      .enp-table {
        width: 100%;
        border-collapse: collapse;
        font-size: 8pt;
        margin-bottom: 0.35rem;
      }
      .enp-table thead th {
        background-color: #f1f5f9;
        font-weight: bold;
        text-align: center;
        padding: 0.25rem 0.3rem;
        border: 1pt solid #94a3b8;
        width: auto;
      }
      .enp-table tbody td {
        text-align: center;
        padding: 0.25rem 0.3rem;
        border: 1pt solid #cbd5e1;
      }
      .enp-table tbody tr:nth-child(even) { background-color: #f8fafc; }
      .enp-growth-positive { color: #16a34a; font-weight: bold; }
      .enp-growth-negative { color: #dc2626; font-weight: bold; }

      /* Gauge info box (Lufthansa) */
      .gauge-info {
        background-color: #fffbeb;
        border: 1pt solid #fbbf24;
        padding: 0.35rem;
        margin-bottom: 0.4rem;
        font-size: 8pt;
        line-height: 1.4;
      }
      .gauge-info strong { color: #92400e; }

      /* Customer reference highlight row */
      .customer-reference-row {
        padding: 0.4rem;
        background-color: #f0f9ff;
        border: 1pt solid #bae6fd;
        margin-bottom: 0.6rem;
        font-weight: bold;
        text-align: center;
        font-size: 8.5pt;
      }

      /* ----------------------------------------------------------------
         Adhesion bend test panels
         ---------------------------------------------------------------- */
      .bend-test-table {
        width: 100%;
        border-collapse: collapse;
        margin-bottom: 0.6rem;
        font-size: 9pt;
      }
      .bend-test-table th {
        background-color: #f1f5f9;
        text-align: center;
        width: 25%;
        padding: 0.3rem 0.4rem;
        border: 1pt solid #94a3b8;
        font-size: 8.5pt;
      }
      .bend-test-table td {
        text-align: center;
        padding: 0.4rem;
        border: 1pt solid #cbd5e1;
        font-weight: bold;
        font-size: 1.05em;
        color: #16a34a;
      }

      /* ----------------------------------------------------------------
         Certificate footer — statement + signature + accreditation.
         In normal flow (no fixed positioning).
         page-break-inside: avoid keeps it on one page.
         ---------------------------------------------------------------- */
      .cert-footer {
        margin-top: 0.75rem;
        page-break-inside: avoid;
      }
      .statement {
        padding: 0.6rem 0.75rem;
        border: 1pt solid #ccc;
        background-color: #f8f9fa;
        margin-bottom: 0.5rem;
        font-size: 8.5pt;
      }
      .statement p { margin: 0; }
      .signature-block { text-align: center; margin-top: 0.5rem; margin-bottom: 0.5rem; }
      .company-footer {
        text-align: center;
        font-size: 8pt;
        color: #555;
        line-height: 1.4;
        border-top: 1pt solid #ddd;
        padding-top: 0.4rem;
        margin-top: 0.4rem;
      }

      /* ----------------------------------------------------------------
         Operator copy — NADCAP (MIL-PRF-8625F Type III) sample plan.
         Appended as its own final page. The outer box is a fixed single
         A4 content height with overflow hidden so it can never spill onto
         a second sheet; the inner block is scaled down by script (see end
         of body) to fit when there are a lot of readings. Each @page still
         supplies its own 1cm margin after the break, so no padding needed.
         ---------------------------------------------------------------- */
      .nadcap-operator-copy {
        page-break-before: always;
        height: 270mm;            /* A4 content area (297mm − 2×1cm) with safety margin */
        overflow: hidden;
        position: relative;
        box-sizing: border-box;
      }
      .nadcap-operator-fit {
        transform-origin: top left;
        width: 100%;
      }
      .nadcap-staple-banner {
        border: 1.5pt dashed #475569;
        background-color: #f1f5f9;
        color: #0f172a;
        font-weight: bold;
        font-size: 9pt;
        text-align: center;
        padding: 0.35rem 0.5rem;
        margin-bottom: 0.5rem;
        letter-spacing: 0.02em;
      }
    </style>
  </head>
  <body>
    <%
      is_special_customer = @release_note.works_order.customer_order.customer.name.include?('Lufthansa')

      cs_order  = nil
      serial_no = nil
      if @release_note.works_order.customer_reference.present?
        ref       = @release_note.works_order.customer_reference
        cs_order  = ref.match(/CS-?Order[:\s]+([^\s\/]+)/i)&.captures&.first
        serial_no = ref.match(/(?:S\/N|SerialNo\.)[:\s]+(.+)/i)&.captures&.first&.strip
      end
    %>

    <!-- ================================================================
         Page 1: Advice Note (consolidated, one per collection)
         Rendered ONLY on the "lead" release note for the customer order
         (the lowest-numbered active one). That single advice note
         summarises every release note on the order, so the driver signs
         once per collection instead of once per release note.
         On every other release note this whole block is skipped and the
         Certificate of Conformity becomes the first page.
         ================================================================ -->
    <%
      customer_order = @release_note.works_order.customer_order
      is_advice_lead = customer_order.lead_release_note&.id == @release_note.id
    %>
    <% if is_advice_lead %>
      <div class="advice-note">
        <div class="logo-header">
          <%= image_tag("logo-with-company-name.png", alt: "Hard Anodising Surface Treatments Ltd") %>
          <div class="company-contact">
            Firs Industrial Estate, Rickets Close, Kidderminster DY11 7QN<br/>
            Tel: 01562 747100 | <a href="https://www.hard-anodising.co.uk/">www.hard-anodising.co.uk</a>
          </div>
        </div>

        <h1>Proof of Collection RN<%= @release_note.number %></h1>

        <table class="header-table">
          <tbody>
            <tr><th>Customer Order</th><td><%= customer_order.number %></td></tr>
            <tr><th>Date</th><td><%= @release_note.date.strftime("%d/%m/%Y") %></td></tr>
          </tbody>
        </table>

        <table class="addresses">
          <tbody>
            <tr>
              <td class="address">
                <h2>Invoice To</h2>
                <p>
                  <%= customer_order.customer.display_name %><br/>
                  <%= simple_format(customer_order.customer.pdf_address) %>
                </p>
              </td>
              <td class="address">
                <h2>Deliver To</h2>
                <p>
                  <%= customer_order.customer.display_name %><br/>
                  <%= simple_format(customer_order.customer.pdf_address) %>
                </p>
              </td>
            </tr>
          </tbody>
        </table>

        <h2>Customer Order Summary</h2>
        <%# ---- One row per works order on this customer order. Driven from
            works orders (not release notes) so the document is complete even
            when later release notes haven't been raised yet at print time. ---- %>
        <% order_works_orders = customer_order.works_orders.active.includes(:part).order(:number).to_a %>
        <table class="summary-table">
          <thead>
            <tr>
              <th>Works Order</th>
              <th>Part Number</th>
              <th>Issue</th>
              <th>Description</th>
              <th>Specification</th>
              <th class="num">Quantity</th>
            </tr>
          </thead>
          <tbody>
            <% order_works_orders.each do |wo| %>
              <tr>
                <td>WO<%= wo.number %></td>
                <td><%= wo.part_number %></td>
                <td><%= wo.part_issue %></td>
                <td><%= wo.part_description %></td>
                <td><%= wo.specification %></td>
                <td class="num"><%= wo.quantity %></td>
              </tr>
            <% end %>
          </tbody>
          <tfoot>
            <tr>
              <th colspan="5" style="text-align:right;">Total Quantity</th>
              <td class="num"><%= order_works_orders.sum(&:quantity) %></td>
            </tr>
          </tfoot>
        </table>

        <table class="signature-table">
          <tbody>
            <tr><th>Name</th><td></td></tr>
            <tr><th>Signature</th><td></td></tr>
            <tr><th>Date</th><td></td></tr>
          </tbody>
        </table>
      </div>
    <% end %>

    <!-- ================================================================
         Certificate of Conformity
         ================================================================ -->
    <div class="certificate-page">
      <div class="logo-header">
        <%= image_tag("logo-with-company-name.png", alt: "Hard Anodising Surface Treatments Ltd") %>
        <div class="company-contact">
          Firs Industrial Estate, Rickets Close, Kidderminster DY11 7QN<br/>
          Tel: 01562 747100 | <a href="https://www.hard-anodising.co.uk/">www.hard-anodising.co.uk</a>
        </div>
      </div>

      <% if @release_note.works_order.part.aerospace_defense? %>
        <h1>Certificate of Conformity - NADCAP Accredited</h1>
      <% else %>
        <h1>Certificate of Conformity</h1>
      <% end %>

      <table class="header-table">
        <tbody>
          <tr><th>Release Note Number</th><td>RN<%= @release_note.number %></td></tr>
          <tr><th>Date</th><td><%= @release_note.date.strftime("%d/%m/%Y") %></td></tr>
        </tbody>
      </table>

      <table class="addresses">
        <tbody>
          <tr>
            <td class="address">
              <h2>Invoice To</h2>
              <p>
                <%= @release_note.works_order.customer_order.customer.display_name %><br/>
                <%= simple_format(@release_note.works_order.customer_order.customer.pdf_address) %>
              </p>
            </td>
            <td class="address">
              <h2>From</h2>
              <p>
                <strong>Hard Anodising Surface Treatments Ltd</strong><br/>
                Firs Industrial Estate, Rickets Close<br/>
                Kidderminster DY11 7QN
              </p>
            </td>
          </tr>
        </tbody>
      </table>

      <% if @release_note.works_order.customer_reference.present? && !is_special_customer %>
        <div class="customer-reference-row">
          <%= @release_note.works_order.customer_reference %>
        </div>
      <% end %>

      <table class="detail-table" style="table-layout: fixed;">
        <colgroup>
          <col style="width: 20%;">
          <col style="width: 30%;">
          <col style="width: 20%;">
          <col style="width: 30%;">
        </colgroup>
        <tbody>
          <tr>
            <th>Customer Order</th>
            <td>
              <%= @release_note.works_order.customer_order.number %>
              <% if @release_note.works_order.respond_to?(:customer_order_line) && @release_note.works_order.customer_order_line.present? %>
                (line <%= @release_note.works_order.customer_order_line %>)
              <% end %>
              <% if cs_order.present? %>
                / CS-Order: <%= cs_order %>
              <% end %>
            </td>
            <th>Our Works Order</th>
            <td>WO<%= @release_note.works_order.number %></td>
          </tr>
          <tr>
            <th>Part Number</th>
            <td>
              <%= @release_note.works_order.part_number %>
              <% if serial_no.present? %>
                / S/N: <%= serial_no %>
              <% end %>
            </td>
            <% unless is_special_customer %>
              <th>Issue</th>
              <td><%= @release_note.works_order.part_issue %></td>
            <% else %>
              <td colspan="2"></td>
            <% end %>
          </tr>
          <tr>
            <th>Description</th>
            <td colspan="3"><%= @release_note.works_order.part_description %></td>
          </tr>
          <tr>
            <th>Specification</th>
            <td colspan="3"><%= @release_note.specification %></td>
          </tr>
          <tr>
            <th>Quantity Accepted</th>
            <td><%= @release_note.quantity_accepted %></td>
            <th>Quantity Rejected</th>
            <td><%= @release_note.quantity_rejected %></td>
          </tr>
        </tbody>
      </table>

      <!-- ============================================================
           Calibrated Thickness Measurements
           ============================================================ -->
      <% if @release_note.has_thickness_measurements? %>
        <h2>Calibrated Thickness Measurements</h2>

        <% if is_special_customer %>
          <div class="gauge-info">
            <strong>Gauge Type:</strong> Elcometer 456/4, Serial # BD10146&nbsp;&nbsp;
            <strong>Probe Type:</strong> N1, Serial # BE23306
          </div>
        <% end %>

        <% @release_note.thickness_measurements_by_type.each do |process_type, measurements| %>
          <% measurements.each do |measurement| %>
            <%
              is_enp       = @release_note.treatment_is_enp?(measurement['process_type'])
              display_name = measurement['display_name'] || measurement['process_type'].humanize.titleize
              raw_batches  = measurement['batches']
              has_batches  = raw_batches.is_a?(Array) && raw_batches.any?
            %>

            <div style="margin-bottom: 0.5rem;">
              <div class="thickness-group-header"><%= display_name %></div>

              <% if is_enp %>
                <%# ============================================================
                    ENP: single transposed table — points as rows, batches as
                    column groups (Before / After / Growth per batch).
                    Works for 1–5 batches; all fit horizontally at 8pt on A4.
                    ============================================================ %>
                <%
                  enp_batches = if has_batches
                    raw_batches.select { |b| b.key?('enp_measurements') }
                  else
                    legacy = measurement['enp_measurements'] || []
                    legacy.any? ? [{ 'batch_number' => 1, 'enp_measurements' => legacy }] : []
                  end
                  next if enp_batches.empty?
                  multi_batch = enp_batches.count > 1
                  all_growths = enp_batches.flat_map { |b|
                    (b['enp_measurements'] || []).map { |m| m['growth_um'] }.compact.select { |g| g >= 0 }
                  }
                  all_points = enp_batches.flat_map { |b| (b['enp_measurements'] || []).map { |m| m['point'] } }.uniq.sort
                %>

                <% if multi_batch && all_growths.any? %>
                  <div class="overall-stats">
                    <strong>Overall (<%= enp_batches.count %> batches):</strong>
                    Mean growth: <strong><%= (all_growths.sum / all_growths.count.to_f).round(1) %> µm</strong> |
                    Min: <%= all_growths.min %> µm | Max: <%= all_growths.max %> µm |
                    Total points: <%= all_growths.count %>
                  </div>
                <% end %>

                <table class="enp-table">
                  <thead>
                    <tr>
                      <th rowspan="2" style="width:6%; vertical-align:middle;">Point</th>
                      <% enp_batches.each do |batch| %>
                        <% label = multi_batch ? "Batch #{batch['batch_number']}" : "Measurements" %>
                        <th colspan="3" style="text-align:center; background-color:#dbeafe; color:#1d4ed8;"><%= label %></th>
                      <% end %>
                    </tr>
                    <tr>
                      <% enp_batches.each do %>
                        <th style="width:<%=  multi_batch ? '10' : '28' %>%;">Before (mm)</th>
                        <th style="width:<%=  multi_batch ? '10' : '28' %>%;">After (mm)</th>
                        <th style="width:<%=  multi_batch ? '8'  : '28' %>%;">Growth (µm)</th>
                      <% end %>
                    </tr>
                  </thead>
                  <tbody>
                    <% all_points.each do |point| %>
                      <tr>
                        <td style="font-weight:bold; text-align:center;"><%= point %></td>
                        <% enp_batches.each do |batch| %>
                          <% m = (batch['enp_measurements'] || []).find { |x| x['point'] == point } %>
                          <td><%= m && m['start_mm']  ? sprintf('%.3f', m['start_mm'])  : '—' %></td>
                          <td><%= m && m['finish_mm'] ? sprintf('%.3f', m['finish_mm']) : '—' %></td>
                          <td class="<%= m && m['growth_um'] && m['growth_um'] < 0 ? 'enp-growth-negative' : 'enp-growth-positive' %>">
                            <%= m && m['growth_um'] ? sprintf('%.1f', m['growth_um']) : '—' %>
                          </td>
                        <% end %>
                      </tr>
                    <% end %>
                  </tbody>
                </table>

              <% else %>
                <%# ============================================================
                    Anodic. Two rendering modes:
                      1. Standard - one row per batch, R1..Rn columns
                      2. NADCAP sample-plan - per batch, one row per sampled part
                         with R1..R8 columns plus batch sub-header
                    Mode detected from data: any batch with 'parts' → NADCAP.
                    ============================================================ %>
                <%
                  anodic_batches = if has_batches
                    raw_batches.select { |b| b.key?('readings') || b.key?('parts') }
                  else
                    legacy = measurement['readings'] || []
                    legacy.any? ? [{ 'batch_number' => 1, 'readings' => legacy }] : []
                  end
                  next if anodic_batches.empty?

                  is_nadcap    = anodic_batches.any? { |b| b['parts'].is_a?(Array) && b['parts'].any? }
                  multi_batch  = anodic_batches.count > 1
                  all_readings = anodic_batches.flat_map { |b| b['readings'] || [] }
                  next if all_readings.empty?
                %>

                <% if multi_batch || is_nadcap %>
                  <%
                    total_parts = anodic_batches.sum { |b| (b['parts'] || []).count }
                  %>
                  <div class="overall-stats">
                    <strong>Overall (<%= anodic_batches.count %> batch<%= anodic_batches.count == 1 ? '' : 'es' %>):</strong>
                    Mean: <strong><%= (all_readings.sum / all_readings.count.to_f).round(1) %> µm</strong> |
                    Min: <%= all_readings.min %> µm | Max: <%= all_readings.max %> µm |
                    Total: <%= all_readings.count %> reading<%= all_readings.count == 1 ? '' : 's' %>
                    <% if is_nadcap %>
                      from <%= total_parts %> sampled part<%= total_parts == 1 ? '' : 's' %>
                    <% end %>
                  </div>
                <% end %>

                <% if is_nadcap %>
                  <%# ---------- NADCAP: per-part rows, grouped by batch ---------- %>
                  <% anodic_batches.each do |batch| %>
                    <%
                      parts          = batch['parts'] || []
                      batch_number   = batch['batch_number']
                      next if parts.empty?
                      batch_readings = parts.flat_map { |p| p['readings'] || [] }
                      next if batch_readings.empty?
                      bmean          = (batch_readings.sum / batch_readings.count.to_f).round(1)
                    %>

                    <div class="nadcap-batch-label">
                      Batch <%= batch_number %> — <%= parts.count %> sampled part<%= parts.count == 1 ? '' : 's' %>
                      <span class="stat">Mean: <%= bmean %> µm</span>
                      <span class="stat">Min: <%= batch_readings.min %> µm</span>
                      <span class="stat">Max: <%= batch_readings.max %> µm</span>
                    </div>

                    <table class="anodic-table">
                      <thead>
                        <tr>
                          <th class="stat-col">Part</th>
                          <th class="stat-col">Mean</th>
                          <th class="stat-col">Min</th>
                          <th class="stat-col">Max</th>
                          <% 8.times do |i| %>
                            <th class="reading-col">R<%= i + 1 %></th>
                          <% end %>
                        </tr>
                      </thead>
                      <tbody>
                        <% parts.each_with_index do |part, idx| %>
                          <%
                            readings = part['readings'] || []
                            next if readings.empty?
                            pmean = (readings.sum / readings.count.to_f).round(1)
                            label = part['part_label'].presence || "B#{batch_number}p#{idx + 1}"
                          %>
                          <tr>
                            <td class="batch-label"><%= label %></td>
                            <td class="stat-mean"><%= pmean %> µm</td>
                            <td><%= readings.min %> µm</td>
                            <td><%= readings.max %> µm</td>
                            <% readings.first(8).each do |r| %>
                              <td><%= r %> µm</td>
                            <% end %>
                            <% (8 - [readings.count, 8].min).times do %><td></td><% end %>
                          </tr>
                        <% end %>
                      </tbody>
                    </table>
                  <% end %>

                <% else %>
                  <%# ---------- Standard anodic: one row per batch ---------- %>
                  <%
                    max_readings = anodic_batches.map { |b| (b['readings'] || []).count }.max
                  %>
                  <table class="anodic-table">
                    <thead>
                      <tr>
                        <% if multi_batch %><th class="stat-col">Batch</th><% end %>
                        <th class="stat-col">Mean</th>
                        <th class="stat-col">Min</th>
                        <th class="stat-col">Max</th>
                        <% max_readings.times do |i| %>
                          <th class="reading-col">R<%= i + 1 %></th>
                        <% end %>
                      </tr>
                    </thead>
                    <tbody>
                      <% anodic_batches.each do |batch| %>
                        <%
                          readings     = batch['readings'] || []
                          batch_number = batch['batch_number']
                          next if readings.empty?
                          bmean = (readings.sum / readings.count.to_f).round(1)
                        %>
                        <tr>
                          <% if multi_batch %>
                            <td class="batch-label">B<%= batch_number %></td>
                          <% end %>
                          <td class="stat-mean"><%= bmean %> µm</td>
                          <td><%= readings.min %> µm</td>
                          <td><%= readings.max %> µm</td>
                          <% readings.each do |r| %>
                            <td><%= r %> µm</td>
                          <% end %>
                          <% (max_readings - readings.count).times do %><td></td><% end %>
                        </tr>
                      <% end %>
                    </tbody>
                  </table>
                <% end %>

              <% end %><!-- /is_enp else -->
            </div>
          <% end %><!-- /measurements.each -->
        <% end %><!-- /measurements_by_type.each -->
      <% end %><!-- /has_thickness_measurements? -->

      <!-- ============================================================
           Adhesion Bend Test Panels
           Shown when: ENP + aerospace/defense + aluminium or steel alloy
           ============================================================ -->
      <% if @release_note.works_order.part&.requires_adhesion_bend_test? %>
        <h2>Adhesion Bend Test</h2>
        <table class="bend-test-table">
          <thead>
            <tr>
              <th>Panel 1</th>
              <th>Panel 2</th>
              <th>Panel 3</th>
              <th>Panel 4</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td>PASS</td>
              <td>PASS</td>
              <td>PASS</td>
              <td>PASS</td>
            </tr>
          </tbody>
        </table>
      <% end %>

      <!-- ============================================================
           Statement / Signature / Accreditation
           page-break-inside: avoid keeps this block together.
           ============================================================ -->
      <div class="cert-footer">
        <h2>Statement</h2>
        <div class="statement">
          <p><%= @release_note.remarks.present? ? @release_note.remarks : 'Certificate of conformity &ndash; We certify that the above work has been processed and inspected according to the terms of your order.' %></p>
        </div>
        <div class="signature-block">
          <span class="signature-name"><%= @release_note.issued_by.display_name %></span><br/>
          For and on behalf of Hard Anodising Surface Treatments Ltd
        </div>
        <div class="company-footer">
          <strong>HARD ANODISING SURFACE TREATMENTS LTD</strong> has been assessed and registered by NQA against the provisions of: AS9100D &amp; BS EN ISO 9001:2015. Certificate No: 22732<br/>
          Hard Anodising Surface Treatments Limited has NADCAP accreditation for Chemical Processing Certificate Number 7426237911
        </div>
      </div>

    </div><!-- /certificate-page -->

    <!-- ============================================================
         Operator copy — NADCAP (MIL-PRF-8625F Type III) sample plan.
         Appended as a final page ONLY when sample-plan (per-part)
         readings exist on this release note. It restates every reading
         and is scaled to fit a single A4 sheet so the operator can
         staple it to the works order. Nothing above this block is
         altered — detection is by presence of per-part sampled data,
         which is only ever written for the Type III hard-anodise path.
         ============================================================ -->
    <%
      nadcap_measurements =
        if @release_note.has_thickness_measurements?
          (@release_note.measured_thicknesses['measurements'] || []).filter_map do |m|
            sample_batches = (m['batches'].is_a?(Array) ? m['batches'] : [])
                               .select { |b| b['parts'].is_a?(Array) && b['parts'].any? }
            next if sample_batches.empty?
            {
              'display_name' => m['display_name'] || m['process_type'].to_s.humanize.titleize,
              'batches'      => sample_batches
            }
          end
        else
          []
        end
    %>
    <% if nadcap_measurements.any? %>
      <div class="nadcap-operator-copy" id="nadcap-operator-copy">
        <div class="nadcap-operator-fit" id="nadcap-operator-fit">

          <div class="nadcap-staple-banner">
            &#9986; &nbsp; OPERATOR COPY &mdash; STAPLE TO WORKS ORDER WO<%= @release_note.works_order.number %> &nbsp; &#9986;
          </div>

          <h1 style="margin-top: 0;">MIL-PRF-8625F Type III &mdash; Sample Plan Readings</h1>

          <table class="detail-table" style="table-layout: fixed;">
            <colgroup>
              <col style="width: 20%;">
              <col style="width: 30%;">
              <col style="width: 20%;">
              <col style="width: 30%;">
            </colgroup>
            <tbody>
              <tr>
                <th>Release Note</th>
                <td>RN<%= @release_note.number %></td>
                <th>Works Order</th>
                <td>WO<%= @release_note.works_order.number %></td>
              </tr>
              <tr>
                <th>Part Number</th>
                <td><%= @release_note.works_order.part_number %></td>
                <th>Issue</th>
                <td><%= @release_note.works_order.part_issue %></td>
              </tr>
              <tr>
                <th>Specification</th>
                <td colspan="3"><%= @release_note.specification %></td>
              </tr>
              <tr>
                <th>Date</th>
                <td><%= @release_note.date.strftime("%d/%m/%Y") %></td>
                <th>Qty Accepted</th>
                <td><%= @release_note.quantity_accepted %></td>
              </tr>
              <tr>
                <%# Operation number = one past the last route operation, so this
                    inspection/release sheet slots in as the next operation. Uses
                    the WO accessor (nil/error-guarded) so locked and unlocked
                    parts both resolve; degrades to 1 if no ops are configured. %>
                <th>Operation No.</th>
                <td><%= @release_note.works_order.operations_with_auto_ops.count + 1 %></td>
                <th>Released By</th>
                <td><%= @release_note.issued_by.display_name %></td>
              </tr>
            </tbody>
          </table>

          <% nadcap_measurements.each do |measurement| %>
            <%
              batches      = measurement['batches']
              all_readings = batches.flat_map { |b| (b['parts'] || []).flat_map { |p| p['readings'] || [] } }
              total_parts  = batches.sum { |b| (b['parts'] || []).count }
            %>

            <div class="thickness-group-header"><%= measurement['display_name'] %></div>

            <% if all_readings.any? %>
              <div class="overall-stats">
                <strong>Overall (<%= batches.count %> batch<%= batches.count == 1 ? '' : 'es' %>):</strong>
                Mean: <strong><%= (all_readings.sum / all_readings.count.to_f).round(1) %> µm</strong> |
                Min: <%= all_readings.min %> µm | Max: <%= all_readings.max %> µm |
                Total: <%= all_readings.count %> reading<%= all_readings.count == 1 ? '' : 's' %>
                from <%= total_parts %> sampled part<%= total_parts == 1 ? '' : 's' %>
              </div>
            <% end %>

            <% batches.each do |batch| %>
              <%
                parts          = batch['parts'] || []
                batch_number   = batch['batch_number']
                next if parts.empty?
                batch_readings = parts.flat_map { |p| p['readings'] || [] }
                next if batch_readings.empty?
                bmean          = (batch_readings.sum / batch_readings.count.to_f).round(1)
              %>

              <div class="nadcap-batch-label">
                Batch <%= batch_number %> — <%= parts.count %> sampled part<%= parts.count == 1 ? '' : 's' %>
                <% if batch['parts_per_batch'].present? %>
                  <span class="stat">Lot: <%= batch['parts_per_batch'] %></span>
                <% end %>
                <span class="stat">Mean: <%= bmean %> µm</span>
                <span class="stat">Min: <%= batch_readings.min %> µm</span>
                <span class="stat">Max: <%= batch_readings.max %> µm</span>
              </div>

              <table class="anodic-table">
                <thead>
                  <tr>
                    <th class="stat-col">Part</th>
                    <th class="stat-col">Mean</th>
                    <th class="stat-col">Min</th>
                    <th class="stat-col">Max</th>
                    <% 8.times do |i| %>
                      <th class="reading-col">R<%= i + 1 %></th>
                    <% end %>
                  </tr>
                </thead>
                <tbody>
                  <% parts.each_with_index do |part, idx| %>
                    <%
                      readings = part['readings'] || []
                      next if readings.empty?
                      pmean = (readings.sum / readings.count.to_f).round(1)
                      label = part['part_label'].presence || "B#{batch_number}p#{idx + 1}"
                    %>
                    <tr>
                      <td class="batch-label"><%= label %></td>
                      <td class="stat-mean"><%= pmean %> µm</td>
                      <td><%= readings.min %> µm</td>
                      <td><%= readings.max %> µm</td>
                      <% readings.first(8).each do |r| %>
                        <td><%= r %> µm</td>
                      <% end %>
                      <% (8 - [readings.count, 8].min).times do %><td></td><% end %>
                    </tr>
                  <% end %>
                </tbody>
              </table>
            <% end %>
          <% end %>

        </div><!-- /nadcap-operator-fit -->
      </div><!-- /nadcap-operator-copy -->

      <script>
        /* Scale the operator copy down so it always collapses onto a single
           A4 sheet, however many sampled parts there are. The outer box has a
           fixed one-page height + overflow:hidden, so it can never produce a
           second page; we only ever shrink the inner block to fit it. Runs
           inline (element already parsed) and again on load for safety. */
        (function () {
          function fitNadcapOperatorCopy() {
            var box = document.getElementById('nadcap-operator-copy');
            var fit = document.getElementById('nadcap-operator-fit');
            if (!box || !fit) return;
            fit.style.transform = 'none';
            var availH = box.clientHeight;
            var availW = box.clientWidth;
            var needH  = fit.scrollHeight;
            var needW  = fit.scrollWidth;
            if (!needH || !needW) return;
            var scale = Math.min(1, availH / needH, availW / needW);
            if (scale < 1) {
              fit.style.transform = 'scale(' + scale + ')';
            }
          }
          fitNadcapOperatorCopy();
          if (document.readyState !== 'complete') {
            window.addEventListener('load', fitNadcapOperatorCopy);
          }
        })();
      </script>
    <% end %>
  </body>
</html>
