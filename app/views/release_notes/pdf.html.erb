<!DOCTYPE html>
<html>
  <head>
    <meta charset="utf-8">
    <style>
      body {
        font-family: sans-serif;
        font-size: 9pt;
        margin: 0;
        padding: 1cm;
        --standard-border-width: 1pt;
        --standard-border-color: black;
        --standard-border-style: solid;
        box-sizing: border-box;
      }

      @page {
        size: A4 portrait;
        margin: 1cm;
      }

      /* Advice Note always on right side / odd page, single sided */
      .advice-note {
        page-break-before: right;
        page-break-after: always;
        max-height: calc(100vh - 2cm);
        overflow: hidden;
      }

      /* Certificate starts on next sheet, can use multiple sides */
      .certificate-page {
        page-break-before: right;
      }

      .certificate-content {
        max-height: none;
        overflow: visible;
        padding-bottom: 4.5cm; /* keep readings clear of the fixed footer */
      }

      /* Compressed mode for ENP / Aerospace jobs */
      .certificate-page.compressed .logo-header  { margin-bottom: 0.5rem; }
      .certificate-page.compressed h1            { margin: 0.4rem 0; font-size: 1.2em; }
      .certificate-page.compressed h2            { font-size: 0.9em; margin: 0.5rem 0 0.3rem 0; }
      .certificate-page.compressed table         { margin-bottom: 0.5rem; }
      .certificate-page.compressed .header-table { margin-bottom: 0.5rem; }
      .certificate-page.compressed .addresses    { margin-bottom: 0.5rem; }
      .certificate-page.compressed .detail-table { margin-top: 0.5rem; margin-bottom: 0.5rem; }
      .certificate-page.compressed th,
      .certificate-page.compressed td            { padding: 0.25rem; }
      .certificate-page.compressed .thickness-group   { margin-bottom: 0.4rem; }
      .certificate-page.compressed .thickness-stats   { padding: 0.2rem 0.3rem; margin-bottom: 0.2rem; font-size: 8pt; }
      .certificate-page.compressed .thickness-table   { margin-top: 0.3rem; margin-bottom: 0.4rem; }
      .certificate-page.compressed .thickness-table th,
      .certificate-page.compressed .thickness-table td { padding: 0.2rem; font-size: 8pt; }
      .certificate-page.compressed .statement         { margin: 0.5rem 0; padding: 0.4rem; }
      .certificate-page.compressed .signature-block   { margin-top: 0.75rem; }
      .certificate-page.compressed .company-footer    { margin-top: 0.5rem; font-size: 8pt; line-height: 1.3; }
      .certificate-page.compressed .readings-grid     { gap: 0.15rem; padding: 0.2rem; font-size: 7.5pt; }
      .certificate-page.compressed .reading-value     { padding: 0.15rem; }

      .logo-header         { text-align: left; margin-bottom: 1rem; }
      .logo-header img     { max-width: 250px; height: auto; }

      .company-contact     { text-align: right; font-size: 8pt; color: #555; margin-top: 0.5rem; line-height: 1.2; }
      .company-contact a   { color: #555; text-decoration: none; }

      h1 { text-align: center; margin: 0.75rem 0; font-size: 1.3em; }
      h2 { font-size: 0.95em; margin: 0.75rem 0 0.4rem 0; }

      table { width: 100%; border-collapse: collapse; margin-bottom: 0.75rem; }
      th, td {
        border-color: var(--standard-border-color);
        border-style: var(--standard-border-style);
        border-width: var(--standard-border-width);
        padding: 0.4rem;
        vertical-align: top;
      }
      th { background-color: #f8f9fa; font-weight: bold; text-align: left; width: 30%; }

      .addresses          { table-layout: fixed; margin-bottom: 1rem; }
      .address            { width: 50%; vertical-align: top; padding: 0.4rem; }
      .address h2         { font-size: 0.9em; margin: 0 0 0.4rem 0; text-decoration: underline; }
      .address p          { margin: 0; line-height: 1.3; }

      .header-table       { margin-bottom: 1rem; }
      .detail-table       { margin-top: 0.75rem; margin-bottom: 1rem; }

      .signature-table    { table-layout: fixed; margin-top: 1rem; }
      .signature-table th { width: 25%; }
      .signature-table td { height: 2.5rem; }

      .signature-name {
        font-family: 'Times New Roman', serif;
        font-size: 1.1em;
        font-style: italic;
        font-weight: bold;
      }

      .statement {
        margin: 1rem 0;
        padding: 0.75rem;
        border: 1pt solid #ccc;
        background-color: #f8f9fa;
      }

      .signature-block { margin-top: 1.5rem; text-align: center; }

      /* ---- Thickness / anodic readings ---- */
      .thickness-table              { margin-top: 0.5rem; margin-bottom: 0.75rem; }
      .thickness-table th           { width: auto; }

      .thickness-group              { margin-bottom: 0.75rem; }
      .thickness-group-header {
        background-color: #e9ecef;
        font-weight: bold;
        padding: 0.2rem 0.4rem;
        border-bottom: 2pt solid #ccc;
      }

      /* Overall (combined) stats bar */
      .thickness-stats {
        background-color: #f8f9fa;
        padding: 0.3rem 0.4rem;
        margin-bottom: 0.3rem;
        border: 1pt solid #ddd;
        font-size: 8.5pt;
      }
      .thickness-stats strong { color: #2563eb; }

      /* Per-batch section */
      .batch-section         { margin-bottom: 0.5rem; }
      .batch-header {
        background-color: #eff6ff;
        border: 1pt solid #bfdbfe;
        padding: 0.2rem 0.4rem;
        font-size: 8pt;
        font-weight: bold;
        color: #1d4ed8;
        margin-bottom: 0.2rem;
      }
      .batch-stats {
        background-color: #f8f9fa;
        padding: 0.2rem 0.4rem;
        margin-bottom: 0.2rem;
        border: 1pt solid #e2e8f0;
        font-size: 8pt;
      }

      /* Anodic readings grid */
      .readings-grid {
        display: grid;
        grid-template-columns: repeat(8, 1fr);
        gap: 0.2rem;
        padding: 0.3rem;
        background-color: #ffffff;
        border: 1pt solid #ddd;
        font-size: 8pt;
      }
      .reading-value {
        text-align: center;
        padding: 0.2rem;
        background-color: #eff6ff;
        border: 1pt solid #bfdbfe;
        border-radius: 2pt;
      }

      /* Gauge info box */
      .gauge-info {
        background-color: #fffbeb;
        border: 1pt solid #fbbf24;
        padding: 0.4rem;
        margin-bottom: 0.5rem;
        font-size: 8.5pt;
        line-height: 1.4;
      }
      .gauge-info strong { color: #92400e; }

      /* ENP measurements */
      .enp-table                    { width: 100%; border-collapse: collapse; margin-top: 0.4rem; margin-bottom: 0.5rem; font-size: 8.5pt; }
      .enp-table thead th           { background-color: #e9ecef; font-weight: bold; text-align: center; padding: 0.3rem; border: 1pt solid #adb5bd; }
      .enp-table tbody td           { text-align: center; padding: 0.3rem; border: 1pt solid #dee2e6; }
      .enp-table tbody tr:nth-child(even) { background-color: #f8f9fa; }
      .enp-point                    { font-weight: bold; background-color: #e9ecef; }
      .enp-growth-positive          { color: #16a34a; font-weight: bold; }
      .enp-growth-negative          { color: #dc2626; font-weight: bold; }

      /* Company footer */
      .company-footer {
        margin-top: 1rem;
        text-align: center;
        font-size: 8.5pt;
        color: #555;
        line-height: 1.4;
        border-top: 1pt solid #ddd;
        padding-top: 0.5rem;
      }
      .company-footer a { color: #555; text-decoration: none; }

      /*
       * Fixed footer — repeats on every page of the CofC section.
       * wkhtmltopdf renders position:fixed elements on every page within the
       * @page content area, so the statement/signature/accreditation text
       * will appear at the bottom of every sheet.
       *
       * padding-bottom on .certificate-content must exceed the footer height
       * so batch readings never underlap it (~4.5cm covers statement +
       * signature + NADCAP line with comfortable clearance).
       */
      .cofc-fixed-footer {
        position: fixed;
        bottom: 0;
        left: 0;
        right: 0;
        background-color: #ffffff;
        padding-top: 0.4rem;
        border-top: 2pt solid #ddd;
      }
      .cofc-fixed-footer .statement {
        margin: 0 0 0.4rem 0;
        padding: 0.5rem 0.75rem;
      }
      .cofc-fixed-footer .signature-block {
        margin-top: 0.4rem;
        margin-bottom: 0.3rem;
      }
      .cofc-fixed-footer .company-footer {
        margin-top: 0.3rem;
        border-top: 1pt solid #ddd;
        padding-top: 0.3rem;
      }

      /* Push certificate content clear of the fixed footer — defined above on .certificate-content */

      .customer-reference-row {
        padding: 0.5rem;
        background-color: #f0f9ff;
        border: 1pt solid #bae6fd;
        margin-bottom: 0.75rem;
        font-weight: bold;
        text-align: center;
      }

      .compact { /* table density helper */ }
    </style>
  </head>
  <body>
    <%
      is_special_customer = @release_note.works_order.customer_order.customer.name.include?('Lufthansa')

      has_enp = false
      if @release_note.has_thickness_measurements?
        @release_note.thickness_measurements_by_type.each do |_, measurements|
          measurements.each do |m|
            if @release_note.treatment_is_enp?(m['process_type'])
              has_enp = true
              break
            end
          end
          break if has_enp
        end
      end

      is_aerospace = @release_note.specification.to_s.match?(/AMS|BAC|DTD|DEF STAN|AEROSPACE/i) ||
                     @release_note.works_order.customer_order.customer.name.match?(/AEROSPACE|AIRCRAFT|AVIATION/i)

      use_compressed_mode = has_enp || is_aerospace

      # Extract CS-Order and Serial Number from customer reference
      cs_order  = nil
      serial_no = nil
      if @release_note.works_order.customer_reference.present?
        ref       = @release_note.works_order.customer_reference
        cs_order  = ref.match(/CS-?Order[:\s]+([^\s\/]+)/i)&.captures&.first
        serial_no = ref.match(/(?:S\/N|SerialNo\.)[:\s]+(.+)/i)&.captures&.first&.strip
      end
    %>

    <!-- ================================================================
         Page 1: Advice Note (always right / odd page, single sided)
         ================================================================ -->
    <div class="advice-note">
      <div class="logo-header">
        <%= image_tag("logo-with-company-name.png", alt: "Hard Anodising Surface Treatments Ltd") %>
        <div class="company-contact">
          Firs Industrial Estate, Rickets Close, Kidderminster DY11 7QN<br/>
          Tel: 01562 747100 | <a href="https://www.hard-anodising.co.uk/">www.hard-anodising.co.uk</a>
        </div>
      </div>

      <h1>Advice Note</h1>

      <table class="header-table">
        <tbody>
          <tr><th>Release Note Number</th><td>RN<%= @release_note.number %></td></tr>
          <tr><th>Date</th><td><%= @release_note.date.strftime("%d/%m/%Y") %></td></tr>
        </tbody>
      </table>

      <table class="addresses">
        <tbody>
          <tr>
            <td class="address">
              <h2>Invoice To</h2>
              <p>
                <%= @release_note.works_order.customer_order.customer.display_name %><br/>
                <%= simple_format(@release_note.works_order.customer_order.customer.pdf_address) %>
              </p>
            </td>
            <td class="address">
              <h2>Deliver To</h2>
              <p>
                <%= @release_note.works_order.customer_order.customer.display_name %><br/>
                <%= simple_format(@release_note.works_order.customer_order.customer.pdf_address) %>
              </p>
            </td>
          </tr>
        </tbody>
      </table>

      <table class="detail-table">
        <tbody>
          <tr>
            <th>Customer Order</th>
            <td>
              <%= @release_note.works_order.customer_order.number %>
              <% if @release_note.works_order.respond_to?(:customer_order_line) && @release_note.works_order.customer_order_line.present? %>
                (line <%= @release_note.works_order.customer_order_line %>)
              <% end %>
            </td>
          </tr>
          <% if @release_note.works_order.customer_reference.present? %>
            <tr><th>Customer Reference</th><td><%= @release_note.works_order.customer_reference %></td></tr>
          <% end %>
          <tr><th>Part Number</th><td><%= @release_note.works_order.part_number %></td></tr>
          <tr><th>Issue</th><td><%= @release_note.works_order.part_issue %></td></tr>
          <tr><th>Description</th><td><%= @release_note.works_order.part_description %></td></tr>
          <tr><th>Specification</th><td><%= @release_note.specification %></td></tr>
          <tr><th>Quantity Accepted</th><td><%= @release_note.quantity_accepted %></td></tr>
          <tr><th>Quantity Rejected</th><td><%= @release_note.quantity_rejected %></td></tr>
          <tr><th>Our Works Order Number</th><td>WO<%= @release_note.works_order.number %></td></tr>
        </tbody>
      </table>

      <table class="signature-table">
        <tbody>
          <tr><th>Name</th><td></td></tr>
          <tr><th>Signature</th><td></td></tr>
          <tr><th>Date</th><td></td></tr>
        </tbody>
      </table>
    </div>

    <!-- ================================================================
         Page 2+: Certificate of Conformity
         ================================================================ -->
    <div class="certificate-page <%= 'compressed' if use_compressed_mode %>">
      <div class="certificate-content">
        <div class="logo-header">
          <%= image_tag("logo-with-company-name.png", alt: "Hard Anodising Surface Treatments Ltd") %>
          <div class="company-contact">
            Firs Industrial Estate, Rickets Close, Kidderminster DY11 7QN<br/>
            Tel: 01562 747100 | <a href="https://www.hard-anodising.co.uk/">www.hard-anodising.co.uk</a>
          </div>
        </div>

        <% if @release_note.works_order.part.aerospace_defense? %>
          <h1>Certificate of Conformity - NADCAP Accredited</h1>
        <% else %>
          <h1>Certificate of Conformity</h1>
        <% end %>

        <table class="header-table compact">
          <tbody>
            <tr><th>Release Note Number</th><td>RN<%= @release_note.number %></td></tr>
            <tr><th>Date</th><td><%= @release_note.date.strftime("%d/%m/%Y") %></td></tr>
          </tbody>
        </table>

        <table class="addresses compact">
          <tbody>
            <tr>
              <td class="address">
                <h2>Invoice To</h2>
                <p>
                  <%= @release_note.works_order.customer_order.customer.display_name %><br/>
                  <%= simple_format(@release_note.works_order.customer_order.customer.pdf_address) %>
                </p>
              </td>
              <td class="address">
                <h2>From</h2>
                <p>
                  <strong>Hard Anodising Surface Treatments Ltd</strong><br/>
                  Firs Industrial Estate, Rickets Close<br/>
                  Kidderminster DY11 7QN
                </p>
              </td>
            </tr>
          </tbody>
        </table>

        <% if @release_note.works_order.customer_reference.present? && !is_special_customer %>
          <div class="customer-reference-row">
            <%= @release_note.works_order.customer_reference %>
          </div>
        <% end %>

        <table class="detail-table compact">
          <tbody>
            <tr>
              <th>Customer Order</th>
              <td>
                <%= @release_note.works_order.customer_order.number %>
                <% if @release_note.works_order.respond_to?(:customer_order_line) && @release_note.works_order.customer_order_line.present? %>
                  (line <%= @release_note.works_order.customer_order_line %>)
                <% end %>
                <% if cs_order.present? %>
                  / CS-Order: <%= cs_order %>
                <% end %>
              </td>
            </tr>
            <tr>
              <th>Part Number</th>
              <td>
                <%= @release_note.works_order.part_number %>
                <% if serial_no.present? %>
                  / S/N: <%= serial_no %>
                <% end %>
              </td>
            </tr>
            <% unless is_special_customer %>
              <tr><th>Issue</th><td><%= @release_note.works_order.part_issue %></td></tr>
            <% end %>
            <tr><th>Description</th><td><%= @release_note.works_order.part_description %></td></tr>
            <tr><th>Specification</th><td><%= @release_note.specification %></td></tr>
            <tr><th>Quantity Accepted</th><td><%= @release_note.quantity_accepted %></td></tr>
            <tr><th>Quantity Rejected</th><td><%= @release_note.quantity_rejected %></td></tr>
            <tr><th>Our Works Order Number</th><td>WO<%= @release_note.works_order.number %></td></tr>
          </tbody>
        </table>

        <!-- ============================================================
             Calibrated Thickness Measurements
             Renders per-batch sections when multiple batches are present.
             Falls back cleanly to single-batch / legacy format.
             ============================================================ -->
        <% if @release_note.has_thickness_measurements? %>
          <h2>Calibrated Thickness Measurements</h2>

          <% if is_special_customer %>
            <div class="gauge-info">
              <strong>Gauge Type:</strong> Elcometer 456/4, Serial # BD10146<br/>
              <strong>Probe Type:</strong> N1, Serial # BE23306
            </div>
          <% end %>

          <% measurements_by_type = @release_note.thickness_measurements_by_type %>
          <% measurements_by_type.each do |process_type, measurements| %>
            <div class="thickness-group">
              <div class="thickness-group-header">
                <%= process_type.humanize.gsub('_', ' ').titleize %>
              </div>

              <% measurements.each do |measurement| %>
                <%
                  treatment_id  = measurement['treatment_id']
                  display_name  = measurement['display_name'] || measurement['process_type'].humanize.titleize
                  is_enp        = @release_note.treatment_is_enp?(measurement['process_type'])
                  group_header  = process_type.humanize.gsub('_', ' ').titleize
                  show_name     = display_name != group_header

                  # Resolve batches – support both new format (batches key) and legacy flat format
                  raw_batches   = measurement['batches']
                  has_batches   = raw_batches.is_a?(Array) && raw_batches.any?
                %>

                <div style="margin-bottom: 0.5rem;">
                  <% if show_name %>
                    <div style="font-weight: bold; margin-bottom: 0.3rem; font-size: 9pt;">
                      <%= display_name %>
                    </div>
                  <% end %>

                  <% if is_enp %>
                    <%# ======================================================
                        ENP: show one A-F table per batch.
                        If single batch (legacy or new), no batch label shown.
                        ====================================================== %>
                    <%
                      # Build a unified list of { batch_number, enp_measurements } hashes
                      enp_batches = if has_batches
                        raw_batches.select { |b| b.key?('enp_measurements') }
                      else
                        # Legacy flat format
                        legacy_enp = measurement['enp_measurements'] || []
                        legacy_enp.any? ? [{ 'batch_number' => 1, 'enp_measurements' => legacy_enp }] : []
                      end

                      # Overall combined stats across all batches
                      all_growths = enp_batches.flat_map { |b|
                        (b['enp_measurements'] || []).map { |m| m['growth_um'] }.compact.select { |g| g >= 0 }
                      }
                      multi_batch = enp_batches.count > 1
                    %>

                    <% next if enp_batches.empty? %>

                    <% if multi_batch && all_growths.any? %>
                      <%
                        combined_mean = (all_growths.sum / all_growths.count.to_f).round(1)
                        combined_min  = all_growths.min
                        combined_max  = all_growths.max
                      %>
                      <div class="thickness-stats" style="margin-bottom: 0.4rem;">
                        <strong>Overall (<%= enp_batches.count %> batches):</strong>
                        Mean Growth: <strong><%= combined_mean %> µm</strong> |
                        Min: <%= combined_min %> µm |
                        Max: <%= combined_max %> µm |
                        Total points: <%= all_growths.count %>
                      </div>
                    <% end %>

                    <% enp_batches.each do |batch| %>
                      <%
                        enp_measurements = batch['enp_measurements'] || []
                        batch_number     = batch['batch_number']
                        valid_growths    = enp_measurements.map { |m| m['growth_um'] }.compact.select { |g| g >= 0 }
                        next if enp_measurements.empty?

                        batch_mean  = valid_growths.any? ? (valid_growths.sum / valid_growths.count.to_f).round(1) : nil
                        batch_min   = valid_growths.min
                        batch_max   = valid_growths.max
                      %>

                      <div class="batch-section">
                        <% if multi_batch %>
                          <div class="batch-header">Batch <%= batch_number %></div>
                        <% end %>

                        <% if valid_growths.any? %>
                          <div class="<%= multi_batch ? 'batch-stats' : 'thickness-stats' %>">
                            <strong>Mean Growth: <%= batch_mean %> µm</strong> |
                            Min: <%= batch_min %> µm |
                            Max: <%= batch_max %> µm |
                            Points: <%= valid_growths.count %>/6
                          </div>
                        <% end %>

                        <table class="enp-table" style="margin-top: 0.3rem;">
                          <thead>
                            <tr>
                              <th style="width: 12%; text-align: center;">Point</th>
                              <th style="width: 29%; text-align: center;">Before (mm)</th>
                              <th style="width: 29%; text-align: center;">After (mm)</th>
                              <th style="width: 30%; text-align: center;">Growth (µm)</th>
                            </tr>
                          </thead>
                          <tbody>
                            <% enp_measurements.each do |m| %>
                              <tr>
                                <td style="text-align: center; font-weight: bold;"><%= m['point'] %></td>
                                <td style="text-align: center;"><%= m['start_mm']  ? sprintf('%.3f', m['start_mm'])  : '—' %></td>
                                <td style="text-align: center;"><%= m['finish_mm'] ? sprintf('%.3f', m['finish_mm']) : '—' %></td>
                                <td style="text-align: center; <%= m['growth_um'] && m['growth_um'] < 0 ? 'color: #dc2626; font-weight: bold;' : 'color: #16a34a; font-weight: bold;' %>">
                                  <%= m['growth_um'] ? sprintf('%.1f', m['growth_um']) : '—' %>
                                </td>
                              </tr>
                            <% end %>
                          </tbody>
                        </table>
                      </div>
                    <% end %><!-- /enp_batches.each -->

                  <% else %>
                    <%# ======================================================
                        Anodic: show a readings grid per batch.
                        Single batch → plain grid (existing layout).
                        Multiple batches → labelled sections + combined summary.
                        ====================================================== %>
                    <%
                      anodic_batches = if has_batches
                        raw_batches.select { |b| b.key?('readings') }
                      else
                        # Legacy flat format
                        legacy_readings = measurement['readings'] || []
                        legacy_readings.any? ? [{ 'batch_number' => 1, 'readings' => legacy_readings }] : []
                      end

                      all_readings = anodic_batches.flat_map { |b| b['readings'] || [] }
                      multi_batch  = anodic_batches.count > 1
                    %>

                    <% next if all_readings.empty? %>

                    <% if multi_batch %>
                      <%
                        combined_mean  = (all_readings.sum / all_readings.count.to_f).round(1)
                        combined_min   = all_readings.min
                        combined_max   = all_readings.max
                      %>
                      <div class="thickness-stats" style="margin-bottom: 0.4rem;">
                        <strong>Overall (<%= anodic_batches.count %> batches):</strong>
                        Mean: <strong><%= combined_mean %> µm</strong> |
                        Min: <%= combined_min %> µm |
                        Max: <%= combined_max %> µm |
                        Total readings: <%= all_readings.count %>
                      </div>
                    <% end %>

                    <% anodic_batches.each do |batch| %>
                      <%
                        readings     = batch['readings'] || []
                        batch_number = batch['batch_number']
                        next if readings.empty?

                        batch_mean = (readings.sum / readings.count.to_f).round(1)
                        batch_min  = readings.min
                        batch_max  = readings.max
                      %>

                      <div class="batch-section">
                        <% if multi_batch %>
                          <div class="batch-header">Batch <%= batch_number %></div>
                        <% end %>

                        <div class="<%= multi_batch ? 'batch-stats' : 'thickness-stats' %>">
                          <strong>Mean: <%= batch_mean %> µm</strong> |
                          Min: <%= batch_min %> µm |
                          Max: <%= batch_max %> µm |
                          Count: <%= readings.count %> readings
                        </div>

                        <div class="readings-grid">
                          <% readings.each do |reading| %>
                            <div class="reading-value"><%= reading %> µm</div>
                          <% end %>
                        </div>
                      </div>
                    <% end %><!-- /anodic_batches.each -->

                  <% end %><!-- /is_enp else -->
                </div>
              <% end %><!-- /measurements.each -->
            </div>
          <% end %><!-- /measurements_by_type.each -->
        <% end %><!-- /has_thickness_measurements? -->

      </div>
    </div>

    <!--
      Fixed footer — rendered by wkhtmltopdf at the bottom of every page of
      the CofC section.  Keeping statement + signature + accreditation here
      ensures every sheet of a multi-page certificate is fully self-certifying
      for NADCAP audit purposes.
    -->
    <div class="cofc-fixed-footer">
      <h2 style="margin: 0 0 0.3rem 0; font-size: 0.9em;">Statement</h2>
      <div class="statement">
        <p style="margin:0;">Certificate of conformity &ndash; We certify that the above work has been processed and inspected according to the terms of your order.<% if @release_note.remarks.present? %> <%= @release_note.remarks %><% end %></p>
      </div>
      <div class="signature-block">
        <p style="margin:0;">
          <span class="signature-name"><%= @release_note.issued_by.display_name %></span><br/>
          For and on behalf of Hard Anodising Surface Treatments Ltd
        </p>
      </div>
      <div class="company-footer">
        <strong>HARD ANODISING SURFACE TREATMENTS LTD</strong> has been assessed and registered by NQA against the provisions of: AS9100D &amp; BS EN ISO 9001:2015. Certificate No: 22732<br/>
        Hard Anodising Surface Treatments Limited has NADCAP accreditation for Chemical Processing Certificate Number 7426237911
      </div>
    </div>
  </body>
</html>
