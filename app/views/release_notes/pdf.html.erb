<!DOCTYPE html>
<html>
  <head>
    <meta charset="utf-8">
    <style>
      body {
        font-family: sans-serif;
        font-size: 9pt;
        margin: 0;
        padding: 0;
        --standard-border-width: 1pt;
        --standard-border-color: black;
        --standard-border-style: solid;
        box-sizing: border-box;
      }

      @page {
        size: A4 portrait;
        margin: 1.2cm 1cm 1cm 1cm;
      }

      /* ----------------------------------------------------------------
         Advice Note — single page, always starts on right/odd side
         ---------------------------------------------------------------- */
      .advice-note {
        page-break-before: right;
        page-break-after: always;
        padding: 0;
      }

      /* ----------------------------------------------------------------
         Certificate — starts on next sheet, pads to match @page margin
         ---------------------------------------------------------------- */
      .certificate-page {
        page-break-before: always;
        padding: 0;
      }

      /* ----------------------------------------------------------------
         General layout
         ---------------------------------------------------------------- */
      .logo-header         { text-align: left; margin-bottom: 0.75rem; }
      .logo-header img     { max-width: 240px; height: auto; }

      .company-contact     { text-align: right; font-size: 7.5pt; color: #555; line-height: 1.2; }
      .company-contact a   { color: #555; text-decoration: none; }

      h1 { text-align: center; margin: 0.6rem 0; font-size: 1.2em; }
      h2 { font-size: 0.9em; margin: 0.6rem 0 0.3rem 0; font-weight: bold; }

      table { width: 100%; border-collapse: collapse; margin-bottom: 0.6rem; }
      th, td {
        border: var(--standard-border-width) var(--standard-border-style) var(--standard-border-color);
        padding: 0.3rem 0.4rem;
        vertical-align: top;
      }
      th { background-color: #f8f9fa; font-weight: bold; text-align: left; width: 30%; }

      .addresses          { table-layout: fixed; margin-bottom: 0.75rem; }
      .address            { width: 50%; vertical-align: top; padding: 0.4rem; }
      .address h2         { font-size: 0.85em; margin: 0 0 0.3rem 0; text-decoration: underline; }
      .address p          { margin: 0; line-height: 1.3; }

      .header-table       { margin-bottom: 0.75rem; }
      .detail-table       { margin-top: 0.5rem; margin-bottom: 0.75rem; }

      .signature-table    { table-layout: fixed; margin-top: 0.75rem; }
      .signature-table th { width: 25%; }
      .signature-table td { height: 2.5rem; }

      .signature-name {
        font-family: 'Times New Roman', serif;
        font-size: 1.1em;
        font-style: italic;
        font-weight: bold;
      }

      /* ----------------------------------------------------------------
         Thickness section header
         ---------------------------------------------------------------- */
      .thickness-group-header {
        background-color: #e9ecef;
        font-weight: bold;
        font-size: 9pt;
        padding: 0.2rem 0.4rem;
        border: 1pt solid #ccc;
        margin-bottom: 0.3rem;
      }

      /* Overall combined stats bar (multi-batch only) */
      .overall-stats {
        background-color: #eff6ff;
        border: 1pt solid #bfdbfe;
        padding: 0.25rem 0.4rem;
        margin-bottom: 0.35rem;
        font-size: 8pt;
        color: #1e40af;
      }
      .overall-stats strong { color: #1d4ed8; }

      /* ----------------------------------------------------------------
         Anodic compact table
         One row per batch: Batch | Mean | Min | Max | R1...R8
         ---------------------------------------------------------------- */
      .anodic-table {
        width: 100%;
        border-collapse: collapse;
        font-size: 8pt;
        margin-bottom: 0.5rem;
      }
      .anodic-table th {
        background-color: #f1f5f9;
        text-align: center;
        padding: 0.25rem 0.2rem;
        border: 1pt solid #94a3b8;
        font-size: 7.5pt;
        width: auto;
      }
      .anodic-table th.stat-col   { width: 6%; }
      .anodic-table th.reading-col { width: 6.5%; }
      .anodic-table td {
        text-align: center;
        padding: 0.25rem 0.2rem;
        border: 1pt solid #cbd5e1;
        vertical-align: middle;
      }
      .anodic-table td.batch-label {
        font-weight: bold;
        background-color: #eff6ff;
        color: #1d4ed8;
        white-space: nowrap;
      }
      .anodic-table td.stat-mean { font-weight: bold; color: #1d4ed8; }

      /* ----------------------------------------------------------------
         ENP compact table (before / after / growth per point, per batch)
         ---------------------------------------------------------------- */
      .enp-batch-label {
        font-size: 8pt;
        font-weight: bold;
        color: #1d4ed8;
        padding: 0.15rem 0;
        margin: 0.3rem 0 0.15rem 0;
      }
      .enp-table {
        width: 100%;
        border-collapse: collapse;
        font-size: 8pt;
        margin-bottom: 0.35rem;
      }
      .enp-table thead th {
        background-color: #f1f5f9;
        font-weight: bold;
        text-align: center;
        padding: 0.25rem 0.3rem;
        border: 1pt solid #94a3b8;
        width: auto;
      }
      .enp-table tbody td {
        text-align: center;
        padding: 0.25rem 0.3rem;
        border: 1pt solid #cbd5e1;
      }
      .enp-table tbody tr:nth-child(even) { background-color: #f8fafc; }
      .enp-growth-positive { color: #16a34a; font-weight: bold; }
      .enp-growth-negative { color: #dc2626; font-weight: bold; }

      /* Gauge info box (Lufthansa) */
      .gauge-info {
        background-color: #fffbeb;
        border: 1pt solid #fbbf24;
        padding: 0.35rem;
        margin-bottom: 0.4rem;
        font-size: 8pt;
        line-height: 1.4;
      }
      .gauge-info strong { color: #92400e; }

      /* Customer reference highlight row */
      .customer-reference-row {
        padding: 0.4rem;
        background-color: #f0f9ff;
        border: 1pt solid #bae6fd;
        margin-bottom: 0.6rem;
        font-weight: bold;
        text-align: center;
        font-size: 8.5pt;
      }

      /* ----------------------------------------------------------------
         Certificate footer — statement + signature + accreditation.
         In normal flow (no fixed positioning).
         page-break-inside: avoid keeps it on one page.
         ---------------------------------------------------------------- */
      .cert-footer {
        margin-top: 0.75rem;
        page-break-inside: avoid;
      }
      .statement {
        padding: 0.6rem 0.75rem;
        border: 1pt solid #ccc;
        background-color: #f8f9fa;
        margin-bottom: 0.5rem;
        font-size: 8.5pt;
      }
      .statement p { margin: 0; }
      .signature-block { text-align: center; margin-top: 0.5rem; margin-bottom: 0.5rem; }
      .company-footer {
        text-align: center;
        font-size: 8pt;
        color: #555;
        line-height: 1.4;
        border-top: 1pt solid #ddd;
        padding-top: 0.4rem;
        margin-top: 0.4rem;
      }
    </style>
  </head>
  <body>
    <%
      is_special_customer = @release_note.works_order.customer_order.customer.name.include?('Lufthansa')

      cs_order  = nil
      serial_no = nil
      if @release_note.works_order.customer_reference.present?
        ref       = @release_note.works_order.customer_reference
        cs_order  = ref.match(/CS-?Order[:\s]+([^\s\/]+)/i)&.captures&.first
        serial_no = ref.match(/(?:S\/N|SerialNo\.)[:\s]+(.+)/i)&.captures&.first&.strip
      end
    %>

    <!-- ================================================================
         Page 1: Advice Note
         ================================================================ -->
    <div class="advice-note">
      <div class="logo-header">
        <%= image_tag("logo-with-company-name.png", alt: "Hard Anodising Surface Treatments Ltd") %>
        <div class="company-contact">
          Firs Industrial Estate, Rickets Close, Kidderminster DY11 7QN<br/>
          Tel: 01562 747100 | <a href="https://www.hard-anodising.co.uk/">www.hard-anodising.co.uk</a>
        </div>
      </div>

      <h1>Advice Note</h1>

      <table class="header-table">
        <tbody>
          <tr><th>Release Note Number</th><td>RN<%= @release_note.number %></td></tr>
          <tr><th>Date</th><td><%= @release_note.date.strftime("%d/%m/%Y") %></td></tr>
        </tbody>
      </table>

      <table class="addresses">
        <tbody>
          <tr>
            <td class="address">
              <h2>Invoice To</h2>
              <p>
                <%= @release_note.works_order.customer_order.customer.display_name %><br/>
                <%= simple_format(@release_note.works_order.customer_order.customer.pdf_address) %>
              </p>
            </td>
            <td class="address">
              <h2>Deliver To</h2>
              <p>
                <%= @release_note.works_order.customer_order.customer.display_name %><br/>
                <%= simple_format(@release_note.works_order.customer_order.customer.pdf_address) %>
              </p>
            </td>
          </tr>
        </tbody>
      </table>

      <table class="detail-table">
        <tbody>
          <tr>
            <th>Customer Order</th>
            <td>
              <%= @release_note.works_order.customer_order.number %>
              <% if @release_note.works_order.respond_to?(:customer_order_line) && @release_note.works_order.customer_order_line.present? %>
                (line <%= @release_note.works_order.customer_order_line %>)
              <% end %>
            </td>
          </tr>
          <% if @release_note.works_order.customer_reference.present? %>
            <tr><th>Customer Reference</th><td><%= @release_note.works_order.customer_reference %></td></tr>
          <% end %>
          <tr><th>Part Number</th><td><%= @release_note.works_order.part_number %></td></tr>
          <tr><th>Issue</th><td><%= @release_note.works_order.part_issue %></td></tr>
          <tr><th>Description</th><td><%= @release_note.works_order.part_description %></td></tr>
          <tr><th>Specification</th><td><%= @release_note.specification %></td></tr>
          <tr><th>Quantity Accepted</th><td><%= @release_note.quantity_accepted %></td></tr>
          <tr><th>Quantity Rejected</th><td><%= @release_note.quantity_rejected %></td></tr>
          <tr><th>Our Works Order Number</th><td>WO<%= @release_note.works_order.number %></td></tr>
        </tbody>
      </table>

      <table class="signature-table">
        <tbody>
          <tr><th>Name</th><td></td></tr>
          <tr><th>Signature</th><td></td></tr>
          <tr><th>Date</th><td></td></tr>
        </tbody>
      </table>
    </div>

    <!-- ================================================================
         Certificate of Conformity
         ================================================================ -->
    <div class="certificate-page">
      <div class="logo-header">
        <%= image_tag("logo-with-company-name.png", alt: "Hard Anodising Surface Treatments Ltd") %>
        <div class="company-contact">
          Firs Industrial Estate, Rickets Close, Kidderminster DY11 7QN<br/>
          Tel: 01562 747100 | <a href="https://www.hard-anodising.co.uk/">www.hard-anodising.co.uk</a>
        </div>
      </div>

      <% if @release_note.works_order.part.aerospace_defense? %>
        <h1>Certificate of Conformity - NADCAP Accredited</h1>
      <% else %>
        <h1>Certificate of Conformity</h1>
      <% end %>

      <table class="header-table">
        <tbody>
          <tr><th>Release Note Number</th><td>RN<%= @release_note.number %></td></tr>
          <tr><th>Date</th><td><%= @release_note.date.strftime("%d/%m/%Y") %></td></tr>
        </tbody>
      </table>

      <table class="addresses">
        <tbody>
          <tr>
            <td class="address">
              <h2>Invoice To</h2>
              <p>
                <%= @release_note.works_order.customer_order.customer.display_name %><br/>
                <%= simple_format(@release_note.works_order.customer_order.customer.pdf_address) %>
              </p>
            </td>
            <td class="address">
              <h2>From</h2>
              <p>
                <strong>Hard Anodising Surface Treatments Ltd</strong><br/>
                Firs Industrial Estate, Rickets Close<br/>
                Kidderminster DY11 7QN
              </p>
            </td>
          </tr>
        </tbody>
      </table>

      <% if @release_note.works_order.customer_reference.present? && !is_special_customer %>
        <div class="customer-reference-row">
          <%= @release_note.works_order.customer_reference %>
        </div>
      <% end %>

      <table class="detail-table">
        <tbody>
          <tr>
            <th>Customer Order</th>
            <td>
              <%= @release_note.works_order.customer_order.number %>
              <% if @release_note.works_order.respond_to?(:customer_order_line) && @release_note.works_order.customer_order_line.present? %>
                (line <%= @release_note.works_order.customer_order_line %>)
              <% end %>
              <% if cs_order.present? %>
                / CS-Order: <%= cs_order %>
              <% end %>
            </td>
          </tr>
          <tr>
            <th>Part Number</th>
            <td>
              <%= @release_note.works_order.part_number %>
              <% if serial_no.present? %>
                / S/N: <%= serial_no %>
              <% end %>
            </td>
          </tr>
          <% unless is_special_customer %>
            <tr><th>Issue</th><td><%= @release_note.works_order.part_issue %></td></tr>
          <% end %>
          <tr><th>Description</th><td><%= @release_note.works_order.part_description %></td></tr>
          <tr><th>Specification</th><td><%= @release_note.specification %></td></tr>
          <tr><th>Quantity Accepted</th><td><%= @release_note.quantity_accepted %></td></tr>
          <tr><th>Quantity Rejected</th><td><%= @release_note.quantity_rejected %></td></tr>
          <tr><th>Our Works Order Number</th><td>WO<%= @release_note.works_order.number %></td></tr>
        </tbody>
      </table>

      <!-- ============================================================
           Calibrated Thickness Measurements
           ============================================================ -->
      <% if @release_note.has_thickness_measurements? %>
        <h2>Calibrated Thickness Measurements</h2>

        <% if is_special_customer %>
          <div class="gauge-info">
            <strong>Gauge Type:</strong> Elcometer 456/4, Serial # BD10146&nbsp;&nbsp;
            <strong>Probe Type:</strong> N1, Serial # BE23306
          </div>
        <% end %>

        <% @release_note.thickness_measurements_by_type.each do |process_type, measurements| %>
          <% measurements.each do |measurement| %>
            <%
              is_enp       = @release_note.treatment_is_enp?(measurement['process_type'])
              display_name = measurement['display_name'] || measurement['process_type'].humanize.titleize
              raw_batches  = measurement['batches']
              has_batches  = raw_batches.is_a?(Array) && raw_batches.any?
            %>

            <div style="margin-bottom: 0.5rem;">
              <div class="thickness-group-header"><%= display_name %></div>

              <% if is_enp %>
                <%# ============================================================
                    ENP: one compact A-F table per batch.
                    ============================================================ %>
                <%
                  enp_batches = if has_batches
                    raw_batches.select { |b| b.key?('enp_measurements') }
                  else
                    legacy = measurement['enp_measurements'] || []
                    legacy.any? ? [{ 'batch_number' => 1, 'enp_measurements' => legacy }] : []
                  end
                  next if enp_batches.empty?
                  multi_batch = enp_batches.count > 1
                  all_growths = enp_batches.flat_map { |b|
                    (b['enp_measurements'] || []).map { |m| m['growth_um'] }.compact.select { |g| g >= 0 }
                  }
                %>

                <% if multi_batch && all_growths.any? %>
                  <div class="overall-stats">
                    <strong>Overall (<%= enp_batches.count %> batches):</strong>
                    Mean growth: <strong><%= (all_growths.sum / all_growths.count.to_f).round(1) %> µm</strong> |
                    Min: <%= all_growths.min %> µm | Max: <%= all_growths.max %> µm |
                    Total points: <%= all_growths.count %>
                  </div>
                <% end %>

                <% enp_batches.each do |batch| %>
                  <%
                    enp_measurements = batch['enp_measurements'] || []
                    batch_number     = batch['batch_number']
                    next if enp_measurements.empty?
                  %>
                  <% if multi_batch %>
                    <div class="enp-batch-label">Batch <%= batch_number %></div>
                  <% end %>
                  <table class="enp-table">
                    <thead>
                      <tr>
                        <th style="width:10%;">Point</th>
                        <th style="width:30%;">Before (mm)</th>
                        <th style="width:30%;">After (mm)</th>
                        <th style="width:30%;">Growth (µm)</th>
                      </tr>
                    </thead>
                    <tbody>
                      <% enp_measurements.each do |m| %>
                        <tr>
                          <td style="font-weight:bold;"><%= m['point'] %></td>
                          <td><%= m['start_mm']  ? sprintf('%.3f', m['start_mm'])  : '—' %></td>
                          <td><%= m['finish_mm'] ? sprintf('%.3f', m['finish_mm']) : '—' %></td>
                          <td class="<%= m['growth_um'] && m['growth_um'] < 0 ? 'enp-growth-negative' : 'enp-growth-positive' %>">
                            <%= m['growth_um'] ? sprintf('%.1f', m['growth_um']) : '—' %>
                          </td>
                        </tr>
                      <% end %>
                    </tbody>
                  </table>
                <% end %><!-- /enp_batches.each -->

              <% else %>
                <%# ============================================================
                    Anodic: compact table — one row per batch.
                    Columns: [Batch] | Mean | Min | Max | R1 | R2 | ... | Rn
                    ============================================================ %>
                <%
                  anodic_batches = if has_batches
                    raw_batches.select { |b| b.key?('readings') }
                  else
                    legacy = measurement['readings'] || []
                    legacy.any? ? [{ 'batch_number' => 1, 'readings' => legacy }] : []
                  end
                  next if anodic_batches.empty?
                  multi_batch  = anodic_batches.count > 1
                  all_readings = anodic_batches.flat_map { |b| b['readings'] || [] }
                  max_readings = anodic_batches.map { |b| (b['readings'] || []).count }.max
                %>

                <% if multi_batch %>
                  <div class="overall-stats">
                    <strong>Overall (<%= anodic_batches.count %> batches):</strong>
                    Mean: <strong><%= (all_readings.sum / all_readings.count.to_f).round(1) %> µm</strong> |
                    Min: <%= all_readings.min %> µm | Max: <%= all_readings.max %> µm |
                    Total: <%= all_readings.count %> readings
                  </div>
                <% end %>

                <table class="anodic-table">
                  <thead>
                    <tr>
                      <% if multi_batch %><th class="stat-col">Batch</th><% end %>
                      <th class="stat-col">Mean</th>
                      <th class="stat-col">Min</th>
                      <th class="stat-col">Max</th>
                      <% max_readings.times do |i| %>
                        <th class="reading-col">R<%= i + 1 %></th>
                      <% end %>
                    </tr>
                  </thead>
                  <tbody>
                    <% anodic_batches.each do |batch| %>
                      <%
                        readings     = batch['readings'] || []
                        batch_number = batch['batch_number']
                        next if readings.empty?
                        bmean = (readings.sum / readings.count.to_f).round(1)
                      %>
                      <tr>
                        <% if multi_batch %>
                          <td class="batch-label">B<%= batch_number %></td>
                        <% end %>
                        <td class="stat-mean"><%= bmean %> µm</td>
                        <td><%= readings.min %> µm</td>
                        <td><%= readings.max %> µm</td>
                        <% readings.each do |r| %>
                          <td><%= r %> µm</td>
                        <% end %>
                        <% (max_readings - readings.count).times do %><td></td><% end %>
                      </tr>
                    <% end %>
                  </tbody>
                </table>

              <% end %><!-- /is_enp else -->
            </div>
          <% end %><!-- /measurements.each -->
        <% end %><!-- /measurements_by_type.each -->
      <% end %><!-- /has_thickness_measurements? -->

      <!-- ============================================================
           Statement / Signature / Accreditation
           page-break-inside: avoid keeps this block together.
           ============================================================ -->
      <div class="cert-footer">
        <h2>Statement</h2>
        <div class="statement">
          <p>Certificate of conformity &ndash; We certify that the above work has been processed and inspected according to the terms of your order.<% if @release_note.remarks.present? %> <%= @release_note.remarks %><% end %></p>
        </div>
        <div class="signature-block">
          <span class="signature-name"><%= @release_note.issued_by.display_name %></span><br/>
          For and on behalf of Hard Anodising Surface Treatments Ltd
        </div>
        <div class="company-footer">
          <strong>HARD ANODISING SURFACE TREATMENTS LTD</strong> has been assessed and registered by NQA against the provisions of: AS9100D &amp; BS EN ISO 9001:2015. Certificate No: 22732<br/>
          Hard Anodising Surface Treatments Limited has NADCAP accreditation for Chemical Processing Certificate Number 7426237911
        </div>
      </div>

    </div><!-- /certificate-page -->
  </body>
</html>
