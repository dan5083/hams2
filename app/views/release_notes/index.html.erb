<div class="container mx-auto px-4 py-6">
  <div class="flex justify-between items-center mb-6">
    <h1 class="text-3xl font-bold text-gray-900">Release Notes</h1>
  </div>

  <!-- Filters -->
  <div class="bg-white p-4 rounded-lg shadow mb-6">
    <%= form_with url: release_notes_path, method: :get, local: true, class: "flex flex-wrap gap-4 items-end" do |form| %>
      <div>
        <%= form.label :search, "RN Number", class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= form.text_field :search,
            value: params[:search],
            placeholder: "Search RN number...",
            class: "border border-gray-300 rounded-md px-3 py-2 w-32" %>
      </div>

      <!-- Customer autocomplete -->
      <div class="relative" data-customer-autocomplete>
        <%= form.label :customer_id, "Customer", class: "block text-sm font-medium text-gray-700 mb-1" %>
        <input type="text"
               id="customer_search"
               autocomplete="off"
               placeholder="Type a customer..."
               value="<%= @customers.find { |c| c.id.to_s == params[:customer_id] }&.name %>"
               class="border border-gray-300 rounded-md px-3 py-2 w-64" />
        <%= form.hidden_field :customer_id, id: "customer_id_field", value: params[:customer_id] %>
        <ul id="customer_options"
            class="absolute z-10 hidden w-64 mt-1 bg-white border border-gray-300 rounded-md shadow-lg max-h-60 overflow-auto"></ul>
      </div>

      <div>
        <%= form.submit "Filter", class: "bg-gray-500 hover:bg-gray-700 text-white font-bold py-2 px-4 rounded" %>
        <%= link_to "Clear", release_notes_path, class: "bg-gray-300 hover:bg-gray-400 text-gray-800 font-bold py-2 px-4 rounded ml-2" %>
      </div>
    <% end %>
  </div>

  <!-- Customer data for the autocomplete (rendered server-side) -->
  <script type="application/json" id="customer_data"><%= raw @customers.map { |c| { id: c.id, name: c.name } }.to_json %></script>

  <!-- Results Summary -->
  <div class="mb-4">
    <p class="text-sm text-gray-600">
      Showing <%= @release_notes.count %> of <%= @release_notes.total_count %> release notes
      <% if params[:search].present? %>
        matching "<%= params[:search] %>"
      <% end %>
      <% if params[:customer_id].present? %>
        for <%= @customers.find { |c| c.id.to_s == params[:customer_id] }&.name %>
      <% end %>
      <% if params[:status].present? %>
        with status "<%= params[:status].humanize %>"
      <% end %>
    </p>
  </div>

  <!-- Release Notes Table -->
  <div class="bg-white shadow overflow-x-auto sm:rounded-lg">
    <table class="min-w-full divide-y divide-gray-200">
      <thead class="bg-gray-50">
        <tr>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
            RN Number
          </th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
            Date
          </th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
            Works Order
          </th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
            Customer Order
          </th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
            Part
          </th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
            Customer
          </th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
            Quantities
          </th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
            Issued By
          </th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
            Actions
          </th>
        </tr>
      </thead>
      <tbody class="bg-white divide-y divide-gray-200">
        <% @release_notes.each do |release_note| %>
          <% wo = release_note.works_order %>
          <tr class="hover:bg-gray-50">
            <td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-gray-900">
              <%= link_to "RN#{release_note.number}", release_note, class: "text-blue-600 hover:text-blue-900" %>
            </td>
            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">
              <%= release_note.date.strftime("%d/%m/%Y") %>
            </td>
            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">
              <%= link_to "WO#{wo.number}", wo, class: "text-blue-600 hover:text-blue-900" %>
            </td>
            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">
              <% co = wo.customer_order %>
              <% if co %>
                <%= link_to (co.respond_to?(:number) ? "CO#{co.number}" : co.to_s), co,
                    class: "text-blue-600 hover:text-blue-900" %>
              <% else %>
                <span class="text-gray-400">&mdash;</span>
              <% end %>
            </td>
            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">
              <% part = wo.part %>
              <% part_label = "#{wo.part_number}-#{wo.part_issue}" %>
              <% if part %>
                <%= link_to part_label, part, class: "text-blue-600 hover:text-blue-900" %>
              <% else %>
                <%= part_label %>
              <% end %>
            </td>
            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">
              <%= release_note.customer.name %>
            </td>
            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">
              <%= release_note.quantity_summary %>
            </td>
            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">
              <%= release_note.issued_by.display_name %>
            </td>
            <td class="px-6 py-4 whitespace-nowrap text-sm font-medium">
              <div class="flex space-x-2">
                <%= link_to "View", release_note, class: "text-blue-600 hover:text-blue-900" %>
                <%= link_to "PDF", pdf_release_note_path(release_note),
                    class: "text-green-600 hover:text-green-900", target: "_blank" %>
                <% if release_note.can_be_edited? %>
                  <%= link_to "Edit", edit_release_note_path(release_note),
                      class: "text-yellow-600 hover:text-yellow-900",
                      title: release_note.invoiced? ? "Edit (invoiced - changes won't affect invoice)" : "Edit" %>
                <% end %>
              </div>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>

    <% if @release_notes.empty? %>
      <div class="text-center py-8">
        <p class="text-gray-500">No release notes found.</p>
        <% if params[:search].present? || params[:status].present? || params[:customer_id].present? %>
          <p class="text-sm text-gray-400 mt-2">
            Try adjusting your search or filters.
          </p>
        <% end %>
      </div>
    <% end %>
  </div>

  <!-- Pagination -->
  <% if @release_notes.respond_to?(:total_pages) && @release_notes.total_pages > 1 %>
    <div class="flex justify-center mt-6">
      <nav class="inline-flex rounded-md shadow-sm -space-x-px" aria-label="Pagination">

        <!-- Previous Page -->
        <% if @release_notes.prev_page %>
          <%= link_to release_notes_path(params.permit(:search, :status, :customer_id, :page).merge(page: @release_notes.prev_page)),
              class: "relative inline-flex items-center px-2 py-2 rounded-l-md border border-gray-300 bg-white text-sm font-medium text-gray-500 hover:bg-gray-50" do %>
            <svg class="h-5 w-5" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor">
              <path fill-rule="evenodd" d="M12.707 5.293a1 1 0 010 1.414L9.414 10l3.293 3.293a1 1 0 01-1.414 1.414l-4-4a1 1 0 010-1.414l4-4a1 1 0 011.414 0z" clip-rule="evenodd" />
            </svg>
            <span class="sr-only">Previous</span>
          <% end %>
        <% else %>
          <span class="relative inline-flex items-center px-2 py-2 rounded-l-md border border-gray-300 bg-gray-100 text-sm font-medium text-gray-400">
            <svg class="h-5 w-5" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor">
              <path fill-rule="evenodd" d="M12.707 5.293a1 1 0 010 1.414L9.414 10l3.293 3.293a1 1 0 01-1.414 1.414l-4-4a1 1 0 010-1.414l4-4a1 1 0 011.414 0z" clip-rule="evenodd" />
            </svg>
            <span class="sr-only">Previous</span>
          </span>
        <% end %>

        <!-- Page Numbers -->
        <% page_range = [[@release_notes.current_page - 2, 1].max, [@release_notes.current_page + 2, @release_notes.total_pages].min] %>

        <% if page_range[0] > 1 %>
          <%= link_to release_notes_path(params.permit(:search, :status, :customer_id, :page).merge(page: 1)),
              class: "relative inline-flex items-center px-4 py-2 border border-gray-300 bg-white text-sm font-medium text-gray-700 hover:bg-gray-50" do %>
            1
          <% end %>
          <% if page_range[0] > 2 %>
            <span class="relative inline-flex items-center px-4 py-2 border border-gray-300 bg-white text-sm font-medium text-gray-700">
              ...
            </span>
          <% end %>
        <% end %>

        <% (page_range[0]..page_range[1]).each do |page| %>
          <% if page == @release_notes.current_page %>
            <span class="relative inline-flex items-center px-4 py-2 border border-gray-300 bg-blue-50 text-sm font-medium text-blue-600">
              <%= page %>
            </span>
          <% else %>
            <%= link_to release_notes_path(params.permit(:search, :status, :customer_id, :page).merge(page: page)),
                class: "relative inline-flex items-center px-4 py-2 border border-gray-300 bg-white text-sm font-medium text-gray-700 hover:bg-gray-50" do %>
              <%= page %>
            <% end %>
          <% end %>
        <% end %>

        <% if page_range[1] < @release_notes.total_pages %>
          <% if page_range[1] < @release_notes.total_pages - 1 %>
            <span class="relative inline-flex items-center px-4 py-2 border border-gray-300 bg-white text-sm font-medium text-gray-700">
              ...
            </span>
          <% end %>
          <%= link_to release_notes_path(params.permit(:search, :status, :customer_id, :page).merge(page: @release_notes.total_pages)),
              class: "relative inline-flex items-center px-4 py-2 border border-gray-300 bg-white text-sm font-medium text-gray-700 hover:bg-gray-50" do %>
            <%= @release_notes.total_pages %>
          <% end %>
        <% end %>

        <!-- Next Page -->
        <% if @release_notes.next_page %>
          <%= link_to release_notes_path(params.permit(:search, :status, :customer_id, :page).merge(page: @release_notes.next_page)),
              class: "relative inline-flex items-center px-2 py-2 rounded-r-md border border-gray-300 bg-white text-sm font-medium text-gray-500 hover:bg-gray-50" do %>
            <span class="sr-only">Next</span>
            <svg class="h-5 w-5" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor">
              <path fill-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z" clip-rule="evenodd" />
            </svg>
          <% end %>
        <% else %>
          <span class="relative inline-flex items-center px-2 py-2 rounded-r-md border border-gray-300 bg-gray-100 text-sm font-medium text-gray-400">
            <span class="sr-only">Next</span>
            <svg class="h-5 w-5" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor">
              <path fill-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z" clip-rule="evenodd" />
            </svg>
          </span>
        <% end %>

      </nav>
    </div>

    <!-- Pagination Info -->
    <div class="text-center mt-4">
      <p class="text-sm text-gray-600">
        Page <%= @release_notes.current_page %> of <%= @release_notes.total_pages %>
        (<%= @release_notes.total_count %> total release notes)
      </p>
    </div>
  <% end %>

  <!-- Summary Stats -->
  <div class="grid grid-cols-1 md:grid-cols-4 gap-4 mt-6">
    <div class="bg-white p-4 rounded-lg shadow">
      <h3 class="text-sm font-medium text-gray-500">Total Release Notes</h3>
      <p class="text-2xl font-bold text-gray-900"><%= ReleaseNote.count %></p>
    </div>
    <div class="bg-white p-4 rounded-lg shadow">
      <h3 class="text-sm font-medium text-gray-500">Pending Invoice</h3>
      <p class="text-2xl font-bold text-orange-600">
        <%= ReleaseNote.requires_invoicing.count %>
      </p>
    </div>
    <div class="bg-white p-4 rounded-lg shadow">
      <h3 class="text-sm font-medium text-gray-500">Invoiced</h3>
      <p class="text-2xl font-bold text-blue-600">
        <%= ReleaseNote.joins(:invoice_item).count %>
      </p>
    </div>
    <div class="bg-white p-4 rounded-lg shadow">
      <h3 class="text-sm font-medium text-gray-500">Voided</h3>
      <p class="text-2xl font-bold text-red-600">
        <%= ReleaseNote.voided.count %>
      </p>
    </div>
  </div>

  <!-- Information Panel about Post-Invoice Editing -->
  <div class="mt-6 bg-blue-50 border border-blue-200 rounded-lg p-4">
    <div class="flex">
      <div class="flex-shrink-0">
        <svg class="h-5 w-5 text-blue-400" viewBox="0 0 20 20" fill="currentColor">
          <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7-4a1 1 0 11-2 0 1 1 0 012 0zM9 9a1 1 0 000 2v3a1 1 0 001 1h1a1 1 0 100-2v-3a1 1 0 00-1-1H9z" clip-rule="evenodd" />
        </svg>
      </div>
      <div class="ml-3 flex-1">
        <h3 class="text-sm font-medium text-blue-800">Post-Invoice Editing</h3>
        <div class="mt-2 text-sm text-blue-700">
          <p><strong>Invoiced release notes can now be edited</strong> for record accuracy and updated delivery documentation:</p>
          <ul class="mt-2 list-disc list-inside">
            <li><strong>Quantities:</strong> Can be updated but won't affect existing invoices</li>
            <li><strong>Remarks:</strong> Can be freely updated and will appear in new PDFs</li>
            <li><strong>Specifications &amp; Details:</strong> Auto-update from part records when PDFs are regenerated</li>
          </ul>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
  (function () {
    function initCustomerAutocomplete() {
      var wrapper = document.querySelector('[data-customer-autocomplete]');
      if (!wrapper || wrapper.dataset.acInit === 'true') return;
      wrapper.dataset.acInit = 'true';

      var search = wrapper.querySelector('#customer_search');
      var hidden = wrapper.querySelector('#customer_id_field');
      var list   = wrapper.querySelector('#customer_options');
      var dataEl = document.getElementById('customer_data');

      var customers = [];
      try { customers = JSON.parse(dataEl.textContent) || []; } catch (e) { customers = []; }

      var filtered = [];
      var activeIndex = -1;

      function closeList() {
        list.classList.add('hidden');
        list.innerHTML = '';
        activeIndex = -1;
      }

      function selectCustomer(c) {
        hidden.value = c ? c.id : '';
        search.value = c ? c.name : '';
        closeList();
      }

      function renderList(items) {
        list.innerHTML = '';
        if (!items.length) { closeList(); return; }
        items.forEach(function (c, i) {
          var li = document.createElement('li');
          li.textContent = c.name;
          li.className = 'px-3 py-2 text-sm cursor-pointer hover:bg-gray-100';
          li.dataset.index = i;
          li.addEventListener('mousedown', function (ev) { ev.preventDefault(); selectCustomer(c); });
          list.appendChild(li);
        });
        list.classList.remove('hidden');
      }

      function filter(term) {
        var t = (term || '').trim().toLowerCase();
        if (!t) {
          filtered = customers.slice(0, 50);
        } else {
          filtered = customers.filter(function (c) {
            return c.name.toLowerCase().indexOf(t) !== -1;
          }).slice(0, 50);
        }
        activeIndex = -1;
        renderList(filtered);
      }

      function highlight() {
        Array.prototype.forEach.call(list.children, function (li, i) {
          li.classList.toggle('bg-gray-100', i === activeIndex);
        });
      }

      search.addEventListener('input', function () {
        hidden.value = ''; // typing invalidates a prior selection until reselected/resolved
        filter(search.value);
      });

      search.addEventListener('focus', function () { filter(search.value); });

      search.addEventListener('keydown', function (e) {
        if (list.classList.contains('hidden')) return;
        if (e.key === 'ArrowDown') {
          e.preventDefault();
          activeIndex = Math.min(activeIndex + 1, filtered.length - 1);
          highlight();
        } else if (e.key === 'ArrowUp') {
          e.preventDefault();
          activeIndex = Math.max(activeIndex - 1, 0);
          highlight();
        } else if (e.key === 'Enter') {
          if (activeIndex >= 0 && filtered[activeIndex]) {
            e.preventDefault();
            selectCustomer(filtered[activeIndex]);
          }
        } else if (e.key === 'Escape') {
          closeList();
        }
      });

      document.addEventListener('click', function (e) {
        if (!wrapper.contains(e.target)) closeList();
      });

      // Be forgiving on submit: resolve typed text -> id if it's an exact name
      // match or an unambiguous substring match. Empty box = All Customers.
      var form = search.closest('form');
      if (form) {
        form.addEventListener('submit', function () {
          if (hidden.value) return;
          var t = search.value.trim().toLowerCase();
          if (!t) { hidden.value = ''; return; }
          var match = customers.filter(function (c) { return c.name.toLowerCase() === t; })[0];
          if (!match) {
            var subs = customers.filter(function (c) { return c.name.toLowerCase().indexOf(t) !== -1; });
            if (subs.length === 1) match = subs[0];
          }
          if (match) { hidden.value = match.id; search.value = match.name; }
        });
      }
    }

    document.addEventListener('DOMContentLoaded', initCustomerAutocomplete);
    document.addEventListener('turbo:load', initCustomerAutocomplete);
    initCustomerAutocomplete();
  })();
</script>
