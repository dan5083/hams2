<div class="max-w-6xl mx-auto p-6">
  <h1 class="text-3xl font-bold text-gray-900 mb-8">Dashboard</h1>

  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
    <!-- Xero Integration Card (Xero gates access its own side) -->
      <div class="bg-white rounded-lg shadow-md p-6">
        <h2 class="text-xl font-semibold text-gray-800 mb-4">Xero Integration</h2>
        <p class="text-gray-600 mb-4">Connect to your Xero account to sync data.</p>

        <div class="space-y-3">
          <%= link_to auth_xero_path,
              class: "inline-block bg-blue-600 hover:bg-blue-700 text-white font-bold py-2 px-4 rounded text-sm" do %>
            🔗 Connect to Xero
          <% end %>

          <div class="text-sm text-gray-600">
            <strong>Last Sync:</strong>
            <% if XeroContact.any? %>
              <%= time_ago_in_words(XeroContact.maximum(:last_synced_at)) %> ago
            <% else %>
              Never
            <% end %>
          </div>

          <!-- DEBUG: Show connection status -->
          <div class="text-xs text-gray-500">
            Connection: <%= @xero_connected ? "✅ Connected" : "❌ Not Connected" %>
            <% if session[:xero_tenant_name] %>
              <br>Tenant: <%= session[:xero_tenant_name] %>
            <% end %>
          </div>
        </div>
      </div>

    <!-- Revenue Pending Card -->
    <% if @total_revenue_pending %>
      <div class="bg-white rounded-lg shadow-md p-6">
        <h2 class="text-xl font-semibold text-gray-800 mb-4">Revenue Pending</h2>
        <div class="text-3xl font-bold text-green-600">£<%= sprintf("%.0f", @total_revenue_pending) %></div>
        <div class="text-sm text-gray-600">Awaiting Xero sync</div>
      </div>
    <% end %>
  </div>

  <!-- Invoice Management Section (Xero gates access its own side) -->
    <% if @pending_invoices.any? %>
      <div class="mt-8">
        <h2 class="text-2xl font-bold text-gray-900 mb-4">Staged Invoices - Ready for Xero</h2>

        <%= form_with url: push_selected_to_xero_invoices_path, method: :post, local: true, class: "bg-white rounded-lg shadow overflow-hidden" do |form| %>
          <div class="px-6 py-4 bg-gray-50 border-b border-gray-200">
            <div class="flex justify-between items-center">
              <div>
                <p class="text-sm text-gray-600">
                  <%= pluralize(@pending_invoices.count, 'invoice') %> ready to push to Xero
                </p>
              </div>
              <div class="flex space-x-3">
                <%= form.submit "Push Selected to Xero",
                    class: "bg-orange-600 hover:bg-orange-700 text-white font-bold py-2 px-4 rounded text-sm #{'opacity-50 cursor-not-allowed' unless @xero_connected}",
                    id: "push-button",
                    disabled: !@xero_connected %>

                <% unless @xero_connected %>
                  <%= link_to "Connect to Xero First", auth_xero_path,
                      class: "bg-blue-600 hover:bg-blue-700 text-white font-bold py-2 px-4 rounded text-sm" %>
                <% end %>

                <button type="button"
                        onclick="toggleAllInvoices()"
                        class="bg-gray-500 hover:bg-gray-600 text-white font-bold py-2 px-4 rounded text-sm"
                        <%= 'disabled' unless @xero_connected %>>
                  Select All
                </button>
              </div>
            </div>

            <!-- Show connection warning if not connected -->
            <% unless @xero_connected %>
              <div class="mt-2 text-sm text-red-600">
                ⚠️ Connect to Xero first to push invoices
              </div>
            <% end %>
          </div>

          <table class="min-w-full divide-y divide-gray-200">
            <thead class="bg-gray-50">
              <tr>
                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">
                  Select
                </th>
                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Invoice</th>
                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Customer</th>
                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Date</th>
                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Amount</th>
                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Status</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-gray-200">
              <% @pending_invoices.each do |invoice| %>
                <tr class="hover:bg-gray-50">
                  <td class="px-6 py-4 whitespace-nowrap">
                    <%= check_box_tag "invoice_ids[]", invoice.id, false,
                        class: "invoice-checkbox h-4 w-4 text-orange-600 focus:ring-orange-500 border-gray-300 rounded",
                        onchange: "updatePushButton()" %>
                  </td>
                  <td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-gray-900">
                    INV<%= invoice.number %>
                  </td>
                  <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">
                    <%= invoice.customer.name %>
                  </td>
                  <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
                    <%= invoice.date.strftime("%d/%m/%Y") %>
                  </td>
                  <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">
                    £<%= sprintf("%.2f", invoice.total_inc_tax) %>
                  </td>
                  <td class="px-6 py-4 whitespace-nowrap">
                    <span class="inline-flex px-2 py-1 text-xs font-semibold rounded-full bg-orange-100 text-orange-800">
                      Staged
                    </span>
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
        <% end %>
      </div>
    <% elsif Invoice.any? %>
      <div class="mt-8">
        <div class="bg-white rounded-lg shadow p-6 text-center">
          <h2 class="text-xl font-semibold text-gray-900 mb-2">All Invoices Synced</h2>
          <p class="text-gray-600">
            ✅ No invoices waiting to be synced to Xero.
            Create more invoices by staging them from works orders.
          </p>
        </div>
      </div>
    <% else %>
      <div class="mt-8">
        <div class="bg-white rounded-lg shadow p-6 text-center">
          <h2 class="text-xl font-semibold text-gray-900 mb-2">No Invoices Yet</h2>
          <p class="text-gray-600 mb-4">
            Start by creating customer orders and works orders, then stage invoices for completed work.
          </p>
          <%= link_to "Create Customer Order", new_customer_order_path,
              class: "bg-green-600 hover:bg-green-700 text-white font-bold py-2 px-4 rounded" %>
        </div>
      </div>
    <% end %>

  <!-- On-Time Delivery (last 30 days) - below staged invoices -->
    <% otd = @otd %>
    <div class="bg-white rounded-lg shadow-md p-6 mt-8">
      <h3 class="text-lg font-semibold text-gray-800 mb-4">On-Time Delivery &middot; last 30 days</h3>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-6">
        <div class="border border-gray-100 rounded-lg p-4">
          <div class="flex items-center justify-between">
            <span class="text-sm font-medium text-gray-600">Aerospace <span class="text-gray-400">(&le;15 wd)</span></span>
            <span class="text-2xl font-bold <%= otd_color_class(otd[:aerospace][:pct]) %>">
              <%= otd[:aerospace][:pct] ? "#{otd[:aerospace][:pct]}%" : "—" %>
            </span>
          </div>
          <div class="text-sm text-gray-500 mt-1">
            <%= otd[:aerospace][:met] %>/<%= otd[:aerospace][:total] %> on time &middot;
            avg <%= otd[:aerospace][:avg] || "—" %> working days
          </div>
        </div>
        <div class="border border-gray-100 rounded-lg p-4">
          <div class="flex items-center justify-between">
            <span class="text-sm font-medium text-gray-600">Commercial <span class="text-gray-400">(&le;10 wd)</span></span>
            <span class="text-2xl font-bold <%= otd_color_class(otd[:commercial][:pct]) %>">
              <%= otd[:commercial][:pct] ? "#{otd[:commercial][:pct]}%" : "—" %>
            </span>
          </div>
          <div class="text-sm text-gray-500 mt-1">
            <%= otd[:commercial][:met] %>/<%= otd[:commercial][:total] %> on time &middot;
            avg <%= otd[:commercial][:avg] || "—" %> working days
          </div>
        </div>
      </div>

      <% if otd[:laggards].any? %>
        <h4 class="text-xs font-semibold text-gray-500 uppercase mb-2">Lagging orders (<%= otd[:laggards].size %>)</h4>
        <div class="overflow-x-auto">
          <table class="min-w-full divide-y divide-gray-200">
            <thead class="bg-gray-50">
              <tr>
                <th class="px-3 py-2 text-left text-xs font-medium text-gray-500 uppercase">Order</th>
                <th class="px-3 py-2 text-left text-xs font-medium text-gray-500 uppercase">Customer</th>
                <th class="px-3 py-2 text-left text-xs font-medium text-gray-500 uppercase">Type</th>
                <th class="px-3 py-2 text-right text-xs font-medium text-gray-500 uppercase">Working Days</th>
                <th class="px-3 py-2 text-right text-xs font-medium text-gray-500 uppercase">Target</th>
                <th class="px-3 py-2 text-right text-xs font-medium text-gray-500 uppercase">Over By</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-gray-100">
              <% otd[:laggards].each do |lag| %>
                <tr class="hover:bg-gray-50">
                  <td class="px-3 py-2 whitespace-nowrap text-sm font-medium">
                    <%= link_to lag[:order].number, customer_order_path(lag[:order]),
                        class: "text-blue-600 hover:text-blue-800 hover:underline" %>
                  </td>
                  <td class="px-3 py-2 whitespace-nowrap text-sm text-gray-900"><%= lag[:customer_name] %></td>
                  <td class="px-3 py-2 whitespace-nowrap text-sm">
                    <span class="inline-flex px-2 py-0.5 text-xs font-semibold rounded-full <%= lag[:aerospace] ? 'bg-indigo-100 text-indigo-800' : 'bg-gray-100 text-gray-700' %>">
                      <%= lag[:aerospace] ? 'Aero' : 'Comm' %>
                    </span>
                  </td>
                  <td class="px-3 py-2 whitespace-nowrap text-sm text-gray-900 text-right"><%= lag[:duration] %></td>
                  <td class="px-3 py-2 whitespace-nowrap text-sm text-gray-500 text-right"><%= lag[:target] %></td>
                  <td class="px-3 py-2 whitespace-nowrap text-sm text-right text-red-600 font-semibold">+<%= lag[:over_by] %></td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      <% else %>
        <p class="text-sm text-gray-500">✅ No orders over target in the last 30 days.</p>
      <% end %>
    </div>

  <!-- Released but Uninvoiced (shown to all) -->
    <% uninvoiced_rows = @uninvoiced_rows %>
    <div class="mt-8">
      <div class="flex items-baseline justify-between mb-4">
        <div>
          <h2 class="text-2xl font-bold text-gray-900">Released but Uninvoiced</h2>
          <p class="text-xs text-gray-500 mt-1">
            The invoice customer order to date button 🐓, the invoice WO to date button 🐤
          </p>
        </div>
        <% if uninvoiced_rows.any? %>
          <p class="text-sm text-gray-600">
            <%= pluralize(uninvoiced_rows.size, 'works order') %> &middot;
            <strong>£<%= sprintf("%.2f", uninvoiced_rows.sum { |r| r[:value] }) %></strong> uninvoiced
          </p>
        <% end %>
      </div>

      <% if uninvoiced_rows.any? %>
        <div class="bg-white rounded-lg shadow overflow-x-auto">
          <table class="min-w-full divide-y divide-gray-200">
            <thead class="bg-gray-50">
              <tr>
                <th class="px-3 py-2 text-left text-xs font-medium text-gray-500 uppercase">Works Order</th>
                <th class="px-3 py-2 text-left text-xs font-medium text-gray-500 uppercase">Part</th>
                <th class="px-3 py-2 text-right text-xs font-medium text-gray-500 uppercase">Rel. Uninv.</th>
                <th class="px-3 py-2 text-right text-xs font-medium text-gray-500 uppercase">Rem.</th>
                <th class="px-3 py-2 text-right text-xs font-medium text-gray-500 uppercase">Value £</th>
                <th class="px-3 py-2 text-right text-xs font-medium text-gray-500 uppercase">Days</th>
                <th class="px-3 py-2 text-right text-xs font-medium text-gray-500 uppercase">Actions</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-gray-200">
              <% uninvoiced_rows.group_by { |r| r[:customer_order] }.each do |customer_order, rows| %>
                <% group_value = rows.sum { |r| r[:value] } %>
                <tr class="bg-gray-100">
                  <td colspan="6" class="px-3 py-2 text-sm">
                    <span class="font-semibold text-gray-900">
                      <%= link_to customer_order.number, customer_order_path(customer_order),
                          class: "text-blue-700 hover:underline" %>
                    </span>
                    <span class="text-gray-600">
                      &middot; <%= rows.first[:customer_name] %>
                      &middot; <%= pluralize(rows.size, 'WO') %>
                      &middot; <strong>£<%= sprintf("%.2f", group_value) %></strong>
                    </span>
                  </td>
                  <td class="px-3 py-2 text-right">
                    <%= button_to "🐓",
                        invoice_to_date_customer_order_path(customer_order),
                        method: :patch,
                        class: "bg-orange-600 hover:bg-orange-700 text-white text-base font-semibold py-1 px-3 rounded",
                        title: "Invoice customer order to date",
                        data: { confirm: "Stage an invoice for everything released to date on order #{customer_order.number} (#{pluralize(rows.size, 'WO')}, £#{sprintf('%.2f', group_value)})?" } %>
                  </td>
                </tr>
                <% rows.each do |row| %>
                  <tr class="hover:bg-gray-50">
                    <td class="px-3 py-2 whitespace-nowrap text-sm font-medium">
                      <%= link_to row[:works_order].number, works_order_path(row[:works_order]),
                          class: "text-blue-600 hover:text-blue-800 hover:underline" %>
                    </td>
                    <td class="px-3 py-2 whitespace-nowrap text-sm text-gray-500"><%= row[:part] %></td>
                    <td class="px-3 py-2 whitespace-nowrap text-sm text-gray-900 text-right"><%= row[:qty_uninvoiced] %></td>
                    <td class="px-3 py-2 whitespace-nowrap text-sm text-gray-500 text-right"><%= row[:remaining] %></td>
                    <td class="px-3 py-2 whitespace-nowrap text-sm text-gray-900 text-right">£<%= sprintf("%.2f", row[:value]) %></td>
                    <td class="px-3 py-2 whitespace-nowrap text-sm text-right">
                      <span class="<%= row[:days_since].to_i > 14 ? 'text-red-600 font-semibold' : 'text-gray-500' %>">
                        <%= row[:days_since] || '—' %>
                      </span>
                    </td>
                    <td class="px-3 py-2 whitespace-nowrap text-right">
                      <%= button_to "🐤",
                          invoice_to_date_works_order_path(row[:works_order]),
                          method: :patch,
                          class: "bg-blue-600 hover:bg-blue-700 text-white text-base font-semibold py-1 px-3 rounded",
                          title: "Invoice WO to date",
                          data: { confirm: "Stage an invoice for WO#{row[:works_order].number} only — #{row[:qty_uninvoiced]} parts, £#{sprintf('%.2f', row[:value])}?" } %>
                    </td>
                  </tr>
                <% end %>
              <% end %>
            </tbody>
          </table>
        </div>
      <% else %>
        <div class="bg-white rounded-lg shadow p-6 text-center">
          <p class="text-gray-600">✅ Nothing released and waiting to be invoiced.</p>
        </div>
      <% end %>
    </div>
</div>

<script>
function updatePushButton() {
  const checkboxes = document.querySelectorAll('.invoice-checkbox:checked');
  const pushButton = document.getElementById('push-button');

  if (pushButton) {
    const hasSelections = checkboxes.length > 0;
    pushButton.disabled = !hasSelections;
    pushButton.textContent = hasSelections
      ? `Push ${checkboxes.length} Selected to Xero`
      : 'Push Selected to Xero';
  }
}

function toggleAllInvoices() {
  const checkboxes = document.querySelectorAll('.invoice-checkbox');
  const allChecked = Array.from(checkboxes).every(cb => cb.checked);

  checkboxes.forEach(checkbox => {
    checkbox.checked = !allChecked;
  });

  updatePushButton();

  const toggleButton = event.target;
  toggleButton.textContent = allChecked ? 'Select All' : 'Deselect All';
}

document.addEventListener('DOMContentLoaded', function() {
  updatePushButton();
});
</script>
