.dropdown-item:hover {
  background-color: #dbeafe !important;
}

.border-green-500 {
  border-color: #10b981 !important;
  box-shadow: 0 0 0 1px #10b981 !important;
}

.border-red-500 {
  border-color: #ef4444 !important;
  box-shadow: 0 0 0 1px #ef4444 !important;
}
