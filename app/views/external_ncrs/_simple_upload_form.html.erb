<%# app/views/external_ncrs/_simple_upload_form.html.erb %>
<div class="max-w-2xl mx-auto px-4 sm:px-6 lg:px-8">
  <div class="mb-6">
    <h2 class="text-2xl font-bold leading-7 text-gray-900 sm:text-3xl">Upload Customer Reject Note</h2>
    <p class="mt-1 text-sm text-gray-500">
      Upload the document received from the customer. Quality will review and log it formally.
    </p>
  </div>

  <%= form_with(model: @external_ncr, local: true, multipart: true, class: "space-y-6") do |f| %>
    <%= hidden_field_tag :simple_upload, 'true' %>

    <% if @external_ncr.errors.any? %>
      <div class="bg-red-50 border border-red-200 rounded-md p-4">
        <div class="flex">
          <div class="flex-shrink-0">
            <svg class="h-5 w-5 text-red-400" viewBox="0 0 20 20" fill="currentColor">
              <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd" />
            </svg>
          </div>
          <div class="ml-3">
            <h3 class="text-sm font-medium text-red-800">
              <%= pluralize(@external_ncr.errors.count, 'error') %> with your submission:
            </h3>
            <ul class="mt-2 text-sm text-red-700 list-disc pl-5 space-y-1">
              <% @external_ncr.errors.full_messages.each do |message| %>
                <li><%= message %></li>
              <% end %>
            </ul>
          </div>
        </div>
      </div>
    <% end %>

    <div class="bg-white shadow sm:rounded-lg">
      <div class="px-4 py-5 sm:p-6 space-y-6">

        <!-- Document Upload -->
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-2">
            Reject Note Document <span class="text-red-500">*</span>
          </label>
          <%= f.file_field :temp_document,
              accept: ".pdf,.jpg,.jpeg,.png,.tiff,.tif,.doc,.docx",
              required: true,
              class: "block w-full text-sm text-gray-500 file:mr-4 file:py-2 file:px-4 file:rounded-md file:border-0 file:text-sm file:font-medium file:bg-indigo-50 file:text-indigo-700 hover:file:bg-indigo-100" %>
          <p class="mt-1 text-xs text-gray-500">PDF, JPG, PNG, TIFF, DOC or DOCX — max 10MB</p>
        </div>

        <!-- Customer Name -->
        <div>
          <%= f.label :manual_customer_name, "Customer Name", class: "block text-sm font-medium text-gray-700" %>
          <%= f.text_field :manual_customer_name,
              placeholder: "e.g. Eaton Aerospace",
              class: "mt-1 focus:ring-indigo-500 focus:border-indigo-500 block w-full shadow-sm sm:text-sm border-gray-300 rounded-md" %>
        </div>

        <!-- Date -->
        <div>
          <%= f.label :date, "Date Received", class: "block text-sm font-medium text-gray-700" %>
          <%= f.date_field :date,
              value: Date.current,
              class: "mt-1 focus:ring-indigo-500 focus:border-indigo-500 block w-full shadow-sm sm:text-sm border-gray-300 rounded-md" %>
        </div>

        <!-- Customer NCR Reference (optional) -->
        <div>
          <%= f.label :customer_ncr_number, "Customer's Reference No. (optional)", class: "block text-sm font-medium text-gray-700" %>
          <%= f.text_field :customer_ncr_number,
              placeholder: "e.g. NCR-2026-0042",
              class: "mt-1 focus:ring-indigo-500 focus:border-indigo-500 block w-full shadow-sm sm:text-sm border-gray-300 rounded-md" %>
        </div>

      </div>
    </div>

    <div class="flex justify-end space-x-3">
      <%= link_to external_ncrs_path,
          class: "py-2 px-4 border border-gray-300 rounded-md shadow-sm text-sm font-medium text-gray-700 bg-white hover:bg-gray-50" do %>
        Cancel
      <% end %>
      <%= f.submit "Upload Reject Note",
          class: "py-2 px-4 border border-transparent rounded-md shadow-sm text-sm font-medium text-white bg-indigo-600 hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500" %>
    </div>
  <% end %>
</div>

<script>
document.addEventListener('change', function(e) {
  if (e.target && e.target.type === 'file') {
    const file = e.target.files[0];
    if (!file) return;
    if (file.size > 10 * 1024 * 1024) {
      alert('File size must be less than 10MB');
      e.target.value = '';
    }
  }
});
</script>
