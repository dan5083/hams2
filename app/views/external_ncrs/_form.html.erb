<%# app/views/external_ncrs/_form.html.erb %>
<div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
  <div class="mb-6">
    <h2 class="text-2xl font-bold leading-7 text-gray-900 sm:text-3xl">
      <%= @external_ncr.persisted? ? "Edit NCR #{@external_ncr.display_name}" : "New External NCR" %>
    </h2>
  </div>

  <%= form_with(model: @external_ncr, local: true, multipart: true, class: "space-y-6") do |f| %>
    <% if @external_ncr.errors.any? %>
      <div class="bg-red-50 border border-red-200 rounded-md p-4">
        <div class="flex">
          <div class="flex-shrink-0">
            <svg class="h-5 w-5 text-red-400" viewBox="0 0 20 20" fill="currentColor">
              <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd" />
            </svg>
          </div>
          <div class="ml-3">
            <h3 class="text-sm font-medium text-red-800">
              There <%= @external_ncr.errors.count == 1 ? 'was' : 'were' %>
              <%= pluralize(@external_ncr.errors.count, 'error') %> with your submission:
            </h3>
            <div class="mt-2 text-sm text-red-700">
              <ul class="list-disc pl-5 space-y-1">
                <% @external_ncr.errors.full_messages.each do |message| %>
                  <li><%= message %></li>
                <% end %>
              </ul>
            </div>
          </div>
        </div>
      </div>
    <% end %>

    <!-- Document Upload Section -->
    <div class="bg-white shadow sm:rounded-lg">
      <div class="px-4 py-5 sm:p-6">
        <h3 class="text-lg leading-6 font-medium text-gray-900 mb-4">Incoming NCR Document</h3>

        <% if @external_ncr.persisted? && @external_ncr.has_document? %>
          <!-- Existing Document Display -->
          <div class="mb-4 p-4 bg-gray-50 rounded-lg border border-gray-200">
            <div class="flex items-center justify-between">
              <div class="flex items-center">
                <svg class="h-8 w-8 text-red-600" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M4 4a2 2 0 012-2h4.586A2 2 0 0112 2.586L15.414 6A2 2 0 0116 7.414V16a2 2 0 01-2 2H6a2 2 0 01-2-2V4zm2 6a1 1 0 011-1h6a1 1 0 110 2H7a1 1 0 01-1-1zm1 3a1 1 0 100 2h6a1 1 0 100-2H7z" clip-rule="evenodd" />
                </svg>
                <div class="ml-3">
                  <p class="text-sm font-medium text-gray-900"><%= @external_ncr.document_filename %></p>
                  <p class="text-xs text-gray-500">
                    <%= @external_ncr.document_size_formatted %>
                    <% if @external_ncr.document_uploaded_date %>
                      • Uploaded <%= @external_ncr.document_uploaded_date.strftime("%d %b %Y at %H:%M") %>
                    <% end %>
                  </p>
                </div>
              </div>
              <div class="flex items-center space-x-2">
                <%= link_to download_document_external_ncr_path(@external_ncr),
                    target: "_blank",
                    class: "inline-flex items-center px-3 py-1 border border-gray-300 rounded-md text-xs font-medium text-gray-700 bg-white hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500" do %>
                  <svg class="-ml-1 mr-1 h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                  </svg>
                  Download
                <% end %>
              </div>
            </div>
          </div>

          <% if @external_ncr.can_replace_document? %>
            <div class="mb-4">
              <label class="block text-sm font-medium text-gray-700 mb-2">
                Replace Document
                <span class="text-xs text-gray-500">(Optional - only for draft NCRs)</span>
              </label>
              <%= f.file_field :temp_document,
                  accept: ".pdf,.jpg,.jpeg,.png,.tiff,.tif,.doc,.docx",
                  class: "block w-full text-sm text-gray-500 file:mr-4 file:py-2 file:px-4 file:rounded-md file:border-0 file:text-sm file:font-medium file:bg-indigo-50 file:text-indigo-700 hover:file:bg-indigo-100" %>
              <p class="mt-1 text-xs text-gray-500">
                Upload a new document to replace the existing one. Accepted formats: PDF, JPG, PNG, TIFF, DOC, DOCX (max 10MB)
              </p>
            </div>
          <% end %>
        <% else %>
          <!-- New Document Upload -->
          <div class="mb-4">
            <label class="block text-sm font-medium text-gray-700 mb-2">
              Upload Incoming NCR Document
              <span class="text-red-500">*</span>
            </label>
            <%= f.file_field :temp_document,
                accept: ".pdf,.jpg,.jpeg,.png,.tiff,.tif,.doc,.docx",
                required: true,
                class: "block w-full text-sm text-gray-500 file:mr-4 file:py-2 file:px-4 file:rounded-md file:border-0 file:text-sm file:font-medium file:bg-indigo-50 file:text-indigo-700 hover:file:bg-indigo-100" %>
            <p class="mt-1 text-xs text-gray-500">
              Required. Upload the NCR document received from the customer. Accepted formats: PDF, JPG, PNG, TIFF, DOC, DOCX (max 10MB)
            </p>
          </div>
        <% end %>
      </div>
    </div>

    <!-- Basic Information -->
    <div class="bg-white shadow sm:rounded-lg">
      <div class="px-4 py-5 sm:p-6">
        <h3 class="text-lg leading-6 font-medium text-gray-900 mb-4">Basic Information</h3>

        <div class="grid grid-cols-1 gap-y-6 gap-x-4 sm:grid-cols-2">
          <!-- Release Notes Selection (Multi) -->
          <div class="sm:col-span-2">
            <label class="block text-sm font-medium text-gray-700">
              Release Notes <span class="text-red-500">*</span>
            </label>

            <% if @external_ncr.persisted? && @external_ncr.status != 'draft' %>
              <!-- Read-only display for non-draft NCRs -->
              <div class="mt-1 space-y-2">
                <% @external_ncr.release_notes.includes(works_order: [:customer_order, :part]).each do |rn| %>
                  <div class="p-3 bg-gray-50 rounded-md">
                    <p class="text-sm text-gray-900">
                      <%= link_to "RN#{rn.number}", rn, class: "text-indigo-600 hover:text-indigo-900 font-medium" %>
                      - <%= rn.works_order.customer_name %> -
                      <%= rn.works_order.part_number || 'N/A' %>-<%= rn.works_order.part_issue || 'N/A' %>
                    </p>
                  </div>
                <% end %>
              </div>
            <% else %>
              <!-- Editable release note list -->
              <div id="selected_release_notes_container" class="mt-2 space-y-2">
                <%# Pre-populate with existing release notes (edit) or preselected (new from RN) %>
                <% selected_rns = @external_ncr.persisted? ? @external_ncr.release_notes.includes(works_order: [:customer_order, :part]) : [] %>
                <% if !@external_ncr.persisted? && defined?(@preselected_release_note) && @preselected_release_note %>
                  <% selected_rns = [@preselected_release_note] %>
                <% end %>

                <% selected_rns.each do |rn| %>
                  <div class="flex items-center justify-between p-3 bg-green-50 border border-green-200 rounded-md release-note-item" data-rn-id="<%= rn.id %>">
                    <input type="hidden" name="external_ncr[release_note_ids][]" value="<%= rn.id %>">
                    <span class="text-sm text-gray-900">
                      RN<%= rn.number %> - <%= rn.works_order.customer_name %> - <%= rn.works_order.part_number %>-<%= rn.works_order.part_issue %>
                    </span>
                    <button type="button" class="remove-release-note text-red-600 hover:text-red-800 text-sm font-medium ml-3">
                      Remove
                    </button>
                  </div>
                <% end %>
              </div>

              <!-- Search input for adding release notes -->
              <div class="relative mt-2">
                <input type="text"
                       id="release_note_search_input"
                       placeholder="Search by RN number, works order, customer, or part number..."
                       autocomplete="off"
                       class="block w-full pl-3 pr-10 py-2 text-base border-gray-300 focus:outline-none focus:ring-indigo-500 focus:border-indigo-500 sm:text-sm rounded-md">

                <!-- Search results dropdown -->
                <div id="release_note_results"
                     class="hidden absolute z-10 mt-1 w-full bg-white shadow-lg max-h-60 rounded-md py-1 text-base ring-1 ring-black ring-opacity-5 overflow-auto focus:outline-none sm:text-sm">
                </div>

                <!-- Loading indicator -->
                <div id="release_note_loading" class="hidden absolute right-3 top-1/2 transform -translate-y-1/2">
                  <svg class="animate-spin h-5 w-5 text-indigo-500" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                    <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                    <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
                  </svg>
                </div>
              </div>
              <p class="mt-1 text-xs text-gray-500">
                Search and add one or more release notes. You can search by RN number, works order number, customer name, or part number.
              </p>
            <% end %>
          </div>

          <!-- Date -->
          <div>
            <%= f.label :date, class: "block text-sm font-medium text-gray-700" %>
            <%= f.date_field :date,
                class: "mt-1 focus:ring-indigo-500 focus:border-indigo-500 block w-full shadow-sm sm:text-sm border-gray-300 rounded-md" %>
          </div>

          <!-- Handled by (Auto-assigned, Read-only) -->
          <div>
            <label class="block text-sm font-medium text-gray-700">Handled by</label>
            <div class="mt-1 p-3 bg-gray-50 rounded-md">
              <p class="text-sm text-gray-900">
                <%= @external_ncr.persisted? ? @external_ncr.respondent&.full_name : Current.user.full_name %>
                <span class="text-xs text-gray-500">(Auto-assigned)</span>
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Reference Numbers -->
    <div class="bg-white shadow sm:rounded-lg">
      <div class="px-4 py-5 sm:p-6">
        <h3 class="text-lg leading-6 font-medium text-gray-900 mb-4">Reference Numbers & Costs</h3>

        <div class="grid grid-cols-1 gap-y-6 gap-x-4 sm:grid-cols-2">
          <div>
            <%= f.label :concession_number, "Concession No. (Optional)", class: "block text-sm font-medium text-gray-700" %>
            <%= f.text_field :concession_number,
                class: "mt-1 focus:ring-indigo-500 focus:border-indigo-500 block w-full shadow-sm sm:text-sm border-gray-300 rounded-md" %>
          </div>

          <div>
            <%= f.label :customer_ncr_number, "Customer NCR No.", class: "block text-sm font-medium text-gray-700" %>
            <%= f.text_field :customer_ncr_number,
                class: "mt-1 focus:ring-indigo-500 focus:border-indigo-500 block w-full shadow-sm sm:text-sm border-gray-300 rounded-md" %>
          </div>

          <div class="sm:col-span-2">
            <%= f.label :estimated_cost, "Estimated Cost (£)", class: "block text-sm font-medium text-gray-700" %>
            <%= f.number_field :estimated_cost,
                min: 0, step: 0.01,
                placeholder: "e.g. 150.00",
                class: "mt-1 focus:ring-indigo-500 focus:border-indigo-500 block w-full shadow-sm sm:text-sm border-gray-300 rounded-md" %>
            <p class="mt-1 text-xs text-gray-500">
              Estimated cost to resolve this non-conformance (optional)
            </p>
          </div>
        </div>
      </div>
    </div>

    <!-- Quantities -->
    <div class="bg-white shadow sm:rounded-lg">
      <div class="px-4 py-5 sm:p-6">
        <h3 class="text-lg leading-6 font-medium text-gray-900 mb-4">Quantities</h3>

        <div class="grid grid-cols-1 gap-y-6 gap-x-4 sm:grid-cols-2">
          <!-- Aggregated batch quantity (read-only) -->
          <div>
            <label class="block text-sm font-medium text-gray-700">Batch Qty. (from Release Notes)</label>
            <div class="mt-1 p-3 bg-gray-50 rounded-md">
              <p class="text-sm text-gray-900 batch-qty-display">
                <% if @external_ncr.release_notes.any? %>
                  <%= @external_ncr.batch_quantity_from_release_notes %>
                  <span class="text-xs text-gray-500">
                    (across <%= pluralize(@external_ncr.release_notes.size, 'release note') %>)
                  </span>
                <% else %>
                  <span class="text-gray-400">Add release notes to see batch quantity</span>
                <% end %>
              </p>
            </div>
          </div>

          <!-- Aggregated customer PO (read-only) -->
          <div>
            <label class="block text-sm font-medium text-gray-700">Customer P/O No. (from Works Orders)</label>
            <div class="mt-1 p-3 bg-gray-50 rounded-md">
              <p class="text-sm text-gray-900 customer-po-display">
                <% if @external_ncr.release_notes.any? %>
                  <%= @external_ncr.customer_po_number_from_works_order || "Not specified" %>
                <% else %>
                  <span class="text-gray-400">Add release notes to see customer P/O</span>
                <% end %>
              </p>
            </div>
          </div>

          <div class="sm:col-span-2">
            <%= f.label :reject_quantity, "NCR Reject Qty.", class: "block text-sm font-medium text-gray-700" %>
            <%= f.number_field :reject_quantity,
                min: 0,
                class: "mt-1 focus:ring-indigo-500 focus:border-indigo-500 block w-full shadow-sm sm:text-sm border-gray-300 rounded-md" %>
            <p class="mt-1 text-xs text-gray-500">
              Total quantity being rejected in this NCR
            </p>
          </div>
        </div>
      </div>
    </div>

    <!-- NCR Content -->
    <div class="bg-white shadow sm:rounded-lg">
      <div class="px-4 py-5 sm:p-6">
        <h3 class="text-lg leading-6 font-medium text-gray-900 mb-4">NCR Content</h3>

        <div class="space-y-6">
          <!-- 1. Description of Non-Conformance -->
          <div>
            <%= f.label :description_of_non_conformance, "Description of Non-Conformance",
                class: "block text-sm font-medium text-gray-700" %>
            <p class="mt-1 text-xs text-gray-500 mb-2">
              Required to advance from draft status
            </p>
            <%= f.text_area :description_of_non_conformance,
                rows: 4,
                class: "mt-1 focus:ring-indigo-500 focus:border-indigo-500 block w-full shadow-sm sm:text-sm border-gray-300 rounded-md" %>
          </div>

          <!-- 2. Containment (if required) -->
          <div>
            <%= f.label :containment_action, "Containment (if required)",
                class: "block text-sm font-medium text-gray-700" %>
            <p class="mt-1 text-xs text-gray-500 mb-2">
              Has customer requested containment? Y/N. Check WIP for similar parts for customer
            </p>
            <%= f.text_area :containment_action,
                rows: 4,
                class: "mt-1 focus:ring-indigo-500 focus:border-indigo-500 block w-full shadow-sm sm:text-sm border-gray-300 rounded-md" %>
          </div>

          <!-- 3. Root Cause Analysis -->
          <div>
            <%= f.label :root_cause_analysis, "Root Cause Analysis",
                class: "block text-sm font-medium text-gray-700" %>
            <p class="mt-1 text-xs text-gray-500 mb-2">
              Review the reasons for non-conformity
            </p>
            <%= f.text_area :root_cause_analysis,
                rows: 4,
                class: "mt-1 focus:ring-indigo-500 focus:border-indigo-500 block w-full shadow-sm sm:text-sm border-gray-300 rounded-md" %>
          </div>

          <!-- 4. Corrective Actions -->
          <div>
            <%= f.label :corrective_action, "Corrective Actions",
                class: "block text-sm font-medium text-gray-700" %>
            <p class="mt-1 text-xs text-gray-500 mb-2">
              Actions to correct part [rework] if applicable. Required to advance from in-progress to completed status
            </p>
            <%= f.text_area :corrective_action,
                rows: 4,
                class: "mt-1 focus:ring-indigo-500 focus:border-indigo-500 block w-full shadow-sm sm:text-sm border-gray-300 rounded-md" %>
          </div>

          <!-- 5. Preventive Action -->
          <div>
            <%= f.label :preventive_action, "Preventive Action",
                class: "block text-sm font-medium text-gray-700" %>
            <p class="mt-1 text-xs text-gray-500 mb-2">
              Required to advance from in-progress to completed status
            </p>
            <%= f.text_area :preventive_action,
                rows: 4,
                class: "mt-1 focus:ring-indigo-500 focus:border-indigo-500 block w-full shadow-sm sm:text-sm border-gray-300 rounded-md" %>
          </div>
        </div>
      </div>
    </div>

    <!-- Form Actions -->
    <div class="flex justify-end space-x-3">
      <%= link_to (@external_ncr.persisted? ? @external_ncr : external_ncrs_path),
          class: "py-2 px-4 border border-gray-300 rounded-md shadow-sm text-sm font-medium text-gray-700 bg-white hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500" do %>
        Cancel
      <% end %>

      <%= f.submit (@external_ncr.persisted? ? "Update NCR" : "Create NCR"),
          class: "py-2 px-4 border border-transparent rounded-md shadow-sm text-sm font-medium text-white bg-indigo-600 hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500" %>
    </div>
  <% end %>
</div>

<script>
// Multi Release Note Search & Selection
(function() {
  const searchInput = document.getElementById('release_note_search_input');
  const resultsDiv = document.getElementById('release_note_results');
  const loadingDiv = document.getElementById('release_note_loading');
  const container = document.getElementById('selected_release_notes_container');

  if (!searchInput) return; // Exit if search input doesn't exist (e.g., read-only on non-draft edit)

  let searchTimeout;

  // Get currently selected release note IDs
  function getSelectedIds() {
    const items = container.querySelectorAll('.release-note-item');
    return Array.from(items).map(item => item.dataset.rnId);
  }

  // Search for release notes
  function searchReleaseNotes(query) {
    loadingDiv.classList.remove('hidden');

    fetch(`/external_ncrs/search_release_notes?q=${encodeURIComponent(query)}`, {
      method: 'GET',
      headers: {
        'Accept': 'application/json',
        'X-Requested-With': 'XMLHttpRequest'
      }
    })
    .then(response => response.json())
    .then(results => {
      loadingDiv.classList.add('hidden');
      displayResults(results);
    })
    .catch(error => {
      console.error('Error searching release notes:', error);
      loadingDiv.classList.add('hidden');
    });
  }

  // Display search results (filtering out already-selected ones)
  function displayResults(results) {
    resultsDiv.innerHTML = '';
    const selectedIds = getSelectedIds();

    // Filter out already selected
    const available = results.filter(r => !selectedIds.includes(r.id));

    if (available.length === 0) {
      const msg = results.length > 0 ? 'All matching release notes already added' : 'No release notes found';
      resultsDiv.innerHTML = `<div class="px-4 py-3 text-sm text-gray-500">${msg}</div>`;
      resultsDiv.classList.remove('hidden');
      return;
    }

    available.forEach(result => {
      const div = document.createElement('div');
      div.className = 'px-4 py-2 hover:bg-gray-100 cursor-pointer text-sm';
      div.textContent = result.display_text;
      div.addEventListener('click', function() {
        addReleaseNote(result);
      });
      resultsDiv.appendChild(div);
    });

    resultsDiv.classList.remove('hidden');
  }

  // Add a release note to the selection
  function addReleaseNote(releaseNote) {
    const item = document.createElement('div');
    item.className = 'flex items-center justify-between p-3 bg-green-50 border border-green-200 rounded-md release-note-item';
    item.dataset.rnId = releaseNote.id;
    item.innerHTML = `
      <input type="hidden" name="external_ncr[release_note_ids][]" value="${releaseNote.id}">
      <span class="text-sm text-gray-900">${releaseNote.display_text}</span>
      <button type="button" class="remove-release-note text-red-600 hover:text-red-800 text-sm font-medium ml-3">
        Remove
      </button>
    `;

    container.appendChild(item);

    // Clear search and hide results
    searchInput.value = '';
    resultsDiv.classList.add('hidden');

    // Update aggregated displays
    updateAggregatedDisplays();
  }

  // Remove a release note from the selection
  function removeReleaseNote(item) {
    item.remove();
    updateAggregatedDisplays();
  }

  // Fetch details for all selected RNs and update batch qty / PO displays
  function updateAggregatedDisplays() {
    const selectedIds = getSelectedIds();
    const batchQtyDisplay = document.querySelector('.batch-qty-display');
    const poDisplay = document.querySelector('.customer-po-display');

    if (selectedIds.length === 0) {
      if (batchQtyDisplay) {
        batchQtyDisplay.innerHTML = '<span class="text-gray-400">Add release notes to see batch quantity</span>';
      }
      if (poDisplay) {
        poDisplay.innerHTML = '<span class="text-gray-400">Add release notes to see customer P/O</span>';
      }
      return;
    }

    // Fetch details for each selected RN
    let totalBatchQty = 0;
    let poNumbers = [];
    let completed = 0;

    selectedIds.forEach(rnId => {
      fetch(`/external_ncrs/release_note_details?release_note_id=${rnId}`, {
        method: 'GET',
        headers: {
          'Accept': 'application/json',
          'X-Requested-With': 'XMLHttpRequest'
        }
      })
      .then(response => response.json())
      .then(data => {
        totalBatchQty += (data.batch_quantity || 0);
        if (data.customer_po_number && !poNumbers.includes(data.customer_po_number)) {
          poNumbers.push(data.customer_po_number);
        }
        completed++;

        // Update displays when all fetches complete
        if (completed === selectedIds.length) {
          if (batchQtyDisplay) {
            batchQtyDisplay.innerHTML = `
              ${totalBatchQty}
              <span class="text-xs text-gray-500">
                (across ${selectedIds.length} release note${selectedIds.length > 1 ? 's' : ''})
              </span>
            `;
          }
          if (poDisplay) {
            poDisplay.textContent = poNumbers.join(', ') || 'Not specified';
            poDisplay.className = 'text-sm text-gray-900 customer-po-display';
          }
        }
      })
      .catch(error => {
        console.error('Error fetching release note details:', error);
        completed++;
      });
    });
  }

  // Event: search input with debounce
  searchInput.addEventListener('input', function(e) {
    const query = e.target.value.trim();
    clearTimeout(searchTimeout);

    if (query.length < 2) {
      resultsDiv.classList.add('hidden');
      return;
    }

    searchTimeout = setTimeout(() => {
      searchReleaseNotes(query);
    }, 300);
  });

  // Event: close results when clicking outside
  document.addEventListener('click', function(e) {
    if (!searchInput.contains(e.target) && !resultsDiv.contains(e.target)) {
      resultsDiv.classList.add('hidden');
    }
  });

  // Event: show recent results on focus if empty
  searchInput.addEventListener('focus', function() {
    if (searchInput.value.trim().length === 0) {
      searchReleaseNotes('');
    }
  });

  // Event delegation: remove buttons
  container.addEventListener('click', function(e) {
    if (e.target.classList.contains('remove-release-note')) {
      removeReleaseNote(e.target.closest('.release-note-item'));
    }
  });
})();

// Handle file input changes (validation)
document.addEventListener('change', function(e) {
  if (e.target && e.target.type === 'file') {
    const file = e.target.files[0];
    if (file) {
      if (file.size > 10 * 1024 * 1024) {
        alert('File size must be less than 10MB');
        e.target.value = '';
        return;
      }

      const allowedTypes = [
        'application/pdf',
        'image/jpeg',
        'image/jpg',
        'image/png',
        'image/tiff',
        'image/tif',
        'application/msword',
        'application/vnd.openxmlformats-officedocument.wordprocessingml.document'
      ];

      if (!allowedTypes.includes(file.type)) {
        alert('Please upload a valid file type: PDF, JPG, PNG, TIFF, DOC, or DOCX');
        e.target.value = '';
        return;
      }
    }
  }
});
</script>
