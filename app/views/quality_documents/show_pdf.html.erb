<!-- app/views/quality_documents/show_pdf.html.erb -->
<!DOCTYPE html>
<html>
<head>
  <meta charset="utf-8">
  <title><%= @document.full_code %> - <%= @document.title %></title>
  <style>
    body { font-family: Arial, sans-serif; margin: 20px; color: #000; font-size: 12pt; line-height: 1.5; -webkit-print-color-adjust: exact !important; print-color-adjust: exact !important; color-adjust: exact !important; }
    .print-bar { position: fixed; top: 0; left: 0; right: 0; background: #2d2d2d; padding: 10px 20px; display: flex; align-items: center; gap: 12px; z-index: 1000; box-shadow: 0 2px 8px rgba(0,0,0,0.3); }
    .print-bar button { background: #7c3aed; color: #fff; border: none; padding: 8px 20px; font-size: 14px; font-weight: 600; border-radius: 4px; cursor: pointer; }
    .print-bar button:hover { background: #6d28d9; }
    .print-bar .back-link { color: #ccc; text-decoration: none; font-size: 13px; margin-left: auto; }
    .print-bar .back-link:hover { color: #fff; }
    .print-bar .doc-title { color: #aaa; font-size: 13px; }
    .document-body { margin-top: 50px; }
    .document-header { border-bottom: 2px solid #000; padding-bottom: 10px; margin-bottom: 20px; }
    .document-header h1 { margin: 0 0 10px 0; font-size: 22pt; }
    .metadata { font-size: 10pt; } .metadata p { margin: 4px 0; }
    .metadata .issue-history { margin-top: 10px; padding-top: 10px; border-top: 1px solid #ccc; }
    .section { margin-bottom: 24px; }
    .section h2 { font-size: 14pt; font-weight: bold; border-bottom: 1px solid #999; padding-bottom: 4px; margin-bottom: 8px; page-break-after: avoid; }
    .content { line-height: 1.6; font-size: 11pt; }
    .content p { margin: 0.4em 0; }
    .content ul, .content ol { margin: 0.5em 0 0.5em 24px; }
    .content ul { list-style-type: disc; } .content ol { list-style-type: decimal; }
    .content li { margin: 0.2em 0; }
    .content strong, .content b { font-weight: bold; }
    .content em, .content i { font-style: italic; }
    .content table { border-collapse: collapse; width: 100%; margin: 10px 0; font-size: 10pt; page-break-inside: avoid; }
    .content td, .content th { border: 1px solid #000; padding: 4px 6px; text-align: left; vertical-align: top; }
    .content th { background-color: #e8e8e8; font-weight: bold; }

    /* ── Testing Matrix styles ── */
    .matrix-section { margin-bottom: 18px; page-break-inside: avoid; }
    .matrix-section-header { background: #1e293b; color: #fff; padding: 5px 10px; font-weight: bold; font-size: 10pt; }
    .matrix-section-header .not-active-note { color: #f87171; font-style: italic; }
    .matrix-table { width: 100%; border-collapse: collapse; font-size: 8.5pt; line-height: 1.3; }
    .matrix-table thead th { background: #d4a843; color: #1e293b; font-weight: bold; font-size: 7.5pt; text-transform: uppercase; letter-spacing: 0.03em; padding: 4px 5px; border: 1px solid #b8922e; text-align: center; vertical-align: middle; }
    .matrix-table tbody td { padding: 3px 5px; border: 1px solid #c9b88a; vertical-align: top; }
    .matrix-table tbody tr { background: #fffdf7; }
    .matrix-table tbody tr:nth-child(even) { background: #faf6ed; }
    .matrix-table .col-method { font-weight: bold; }
    .matrix-table .col-criteria, .matrix-table .col-parts, .matrix-table .col-frequency, .matrix-table .col-location { text-align: center; }
    .matrix-table .nadcap-note { color: #dc2626; font-weight: bold; font-style: italic; font-size: 7.5pt; }
    .matrix-table .ref-row td { background: #f1ead6; font-style: italic; font-weight: bold; color: #78716c; text-align: center; }
    .matrix-table .span-cell { text-align: center; font-weight: bold; color: #44403c; background: #faf5e8; }

    /* ── Skills Matrix styles ── */
    .skills-legend { margin-bottom: 10px; font-size: 9pt; }
    .skills-legend span { margin-right: 16px; }
    .skills-legend .swatch { display: inline-block; width: 14px; height: 14px; vertical-align: middle; margin-right: 3px; border: 1px solid #999; text-align: center; font-weight: bold; font-size: 8pt; line-height: 14px; }
    .skills-grid { border-collapse: collapse; font-size: 7pt; line-height: 1.2; }
    .skills-grid th, .skills-grid td { border: 1px solid #999; padding: 2px; }
    .skills-grid thead th { font-weight: bold; text-align: center; vertical-align: bottom; }
    .skills-grid thead th.skill-header { height: 120px; width: 22px; min-width: 22px; max-width: 22px; overflow: visible; vertical-align: bottom; padding: 0; position: relative; background: transparent !important; border: none; }
    .skills-grid thead th.skill-header .skill-bg { position: absolute; top: 0; bottom: 0; left: -1px; right: -1px; transform: skew(-35deg, 0); transform-origin: bottom left; border: 1px solid rgba(0,0,0,0.12); z-index: 0; }
    .skills-grid thead th.skill-header .rotated { position: absolute; z-index: 1; bottom: 8px; left: 4px; transform: rotate(-55deg); transform-origin: 0% 100%; white-space: nowrap; font-size: 7pt; font-family: Arial, Helvetica, sans-serif; -webkit-font-smoothing: antialiased; -moz-osx-font-smoothing: grayscale; }
    .skills-grid thead th.name-header { text-align: left; padding: 3px 4px; min-width: 90px; background: #e5e7eb; }
    .skills-grid thead th.title-header { text-align: left; padding: 3px 4px; min-width: 70px; background: #e5e7eb; }
    .sg-green { background: #4ade80 !important; }
    .sg-yellow { background: #facc15 !important; }
    .sg-blue { background: #60a5fa !important; }
    .sg-violet { background: #c084fc !important; }
    .sg-red { background: #f87171 !important; }
    .sg-salmon { background: #fda4af !important; }
    .sg-orange { background: #fb923c !important; }
    .skills-grid tbody td { text-align: center; vertical-align: middle; width: 22px; min-width: 22px; max-width: 22px; height: 16px; font-weight: bold; font-size: 7pt; }
    .skills-grid tbody td.staff-name { text-align: left; font-weight: bold; white-space: nowrap; padding: 2px 4px; min-width: 90px; }
    .skills-grid tbody td.staff-title { text-align: left; font-size: 6.5pt; color: #555; white-space: nowrap; padding: 2px 4px; }
    .skills-grid tbody tr:nth-child(even) { background: #f5f5f0; }
    .skill-l1 { background: #fee2e2 !important; color: #991b1b; }
    .skill-l2 { background: #fef3c7 !important; color: #92400e; }
    .skill-l3 { background: #d1fae5 !important; color: #065f46; }
    .skill-lt { background: #dbeafe !important; color: #1e40af; }
    .skills-grid tfoot td { font-size: 5.5pt; text-align: center; vertical-align: top; padding: 2px 1px; color: #44403c; font-weight: bold; background: #f5f5f0; }
    .skills-grid tfoot td.training-label { text-align: left; padding: 2px 4px; font-size: 6pt; }
    .skills-legend-groups { margin-bottom: 6px; font-size: 8pt; }
    .skills-legend-groups .swatch { display: inline-block; width: 10px; height: 10px; vertical-align: middle; margin-right: 2px; border: 1px solid #999; }
    .skills-legend-groups span { margin-right: 10px; }

    .references { margin-top: 24px; padding-top: 16px; border-top: 1px solid #999; }
    .references h2 { font-size: 13pt; font-weight: bold; margin-bottom: 8px; }
    .references ul { margin-left: 20px; list-style-type: disc; }
    .references li { margin: 3px 0; font-size: 10pt; }
    .document-footer { margin-top: 30px; padding-top: 10px; border-top: 1px solid #ccc; font-size: 9pt; color: #666; text-align: center; }

    * { -webkit-print-color-adjust: exact !important; print-color-adjust: exact !important; color-adjust: exact !important; }

    @media print {
      .print-bar { display: none !important; }
      .document-body { margin-top: 0; }
      body { margin: 0; font-size: 11pt; }
      h2, h3, h4 { page-break-after: avoid; }
      .matrix-section { page-break-inside: avoid; }
      .content table { page-break-inside: avoid; }
      .document-footer { margin-top: 30px; }
    }

    /* ── Skills matrix print: A3 landscape one-page ── */
    body.skills-matrix-print { font-size: 7pt; margin: 5px; }
    body.skills-matrix-print .document-header { border-bottom: 1px solid #000; padding-bottom: 3px; margin-bottom: 4px; }
    body.skills-matrix-print .document-header h1 { font-size: 11pt; margin: 0; display: inline; }
    body.skills-matrix-print .compact-meta { display: inline; font-size: 7pt; margin-left: 12px; color: #333; }
    body.skills-matrix-print .compact-meta span { margin-right: 10px; }
    body.skills-matrix-print .skills-legend { font-size: 6pt; margin-bottom: 2px; }
    body.skills-matrix-print .skills-legend .swatch { width: 10px; height: 10px; font-size: 6pt; line-height: 10px; }
    body.skills-matrix-print .skills-legend span { margin-right: 8px; }
    body.skills-matrix-print .skills-legend-groups { font-size: 6pt; margin-bottom: 3px; }
    body.skills-matrix-print .skills-legend-groups .swatch { width: 8px; height: 8px; }
    body.skills-matrix-print .skills-legend-groups span { margin-right: 6px; }
    body.skills-matrix-print .skills-grid { font-size: 6pt; }
    body.skills-matrix-print .skills-grid th, body.skills-matrix-print .skills-grid td { border: 1px solid #aaa; padding: 1px; }
    body.skills-matrix-print .skills-grid thead th.skill-header { height: 100px; width: 18px; min-width: 18px; max-width: 18px; }
    body.skills-matrix-print .skills-grid thead th.skill-header .rotated { font-size: 5.5pt; bottom: 5px; left: 3px; }
    body.skills-matrix-print .skills-grid thead th.skill-header .skill-bg { left: -1px; right: -1px; }
    body.skills-matrix-print .skills-grid thead th.name-header { min-width: 75px; padding: 1px 3px; font-size: 6pt; }
    body.skills-matrix-print .skills-grid thead th.title-header { min-width: 55px; padding: 1px 3px; font-size: 6pt; }
    body.skills-matrix-print .skills-grid tbody td { width: 18px; min-width: 18px; max-width: 18px; height: 13px; font-size: 6pt; }
    body.skills-matrix-print .skills-grid tbody td.staff-name { font-size: 6pt; min-width: 75px; padding: 1px 3px; }
    body.skills-matrix-print .skills-grid tbody td.staff-title { font-size: 5.5pt; min-width: 55px; padding: 1px 3px; }
    body.skills-matrix-print .skills-grid tfoot td { font-size: 4.5pt; padding: 1px; }
    body.skills-matrix-print .document-footer { display: none; }

    @media print {
      body.skills-matrix-print {
        margin: 0;
      }
      body.skills-matrix-print .document-body { margin-top: 0; }
    }
    <% if @document.content['skills_matrix'] %>
      @media print { @page { size: A3 landscape; margin: 5mm; } }
    <% end %>
  </style>
</head>
<body class="<%= 'skills-matrix-print' if @document.content['skills_matrix'] %>">
  <div class="print-bar">
    <button onclick="window.print()">🖨️ Print / Save PDF</button>
    <span class="doc-title"><%= @document.full_code %> - <%= @document.title %></span>
    <%= link_to '← Back to document', quality_document_path(@document), class: 'back-link' %>
  </div>

  <div class="document-body">
    <div class="document-header">
      <% if @document.content['skills_matrix'] %>
        <h1><%= @document.full_code %> - <%= @document.title %></h1>
        <span class="compact-meta">
          <span>Issue: <%= @document.current_issue_number %></span>
          <span>Approved: <%= @document.approved_by %></span>
          <span>Date: <%= @document.updated_at.strftime('%d/%m/%Y') %></span>
        </span>
      <% else %>
        <h1><%= @document.full_code %> - <%= @document.title %></h1>
        <div class="metadata">
          <p><strong>Document Type:</strong> <%= @document.type_description %></p>
          <p><strong>Issue:</strong> <%= @document.current_issue_number %></p>
          <p><strong>Approved by:</strong> <%= @document.approved_by %></p>
          <p><strong>Date:</strong> <%= @document.updated_at.strftime('%d/%m/%Y') %></p>
          <% if @document.content['issue_history'].present? %>
            <div class="issue-history">
              <strong>Issue History:</strong><br>
              <% @document.content['issue_history'].each do |history| %>
                Issue <%= history['issue'] %>: <%= Date.parse(history['date']).strftime('%d/%m/%Y') rescue history['date'] %><br>
              <% end %>
            </div>
          <% end %>
        </div>
      <% end %>
    </div>

    <% if @document.content['skills_matrix'] %>
      <%# ── Skills Matrix ── %>
      <% legend = @document.content['legend'] || {} %>
      <% level_colors = { '1' => ['#fee2e2','#991b1b'], '2' => ['#fef3c7','#92400e'], '3' => ['#d1fae5','#065f46'], 'T' => ['#dbeafe','#1e40af'] } %>
      <div class="skills-legend">
        <% level_colors.each do |code, (bg, fg)| %>
          <span><span class="swatch" style="background-color: <%= bg %>; color: <%= fg %>; font-weight: bold;"><%= code %></span> <%= legend[code] || code %></span>
        <% end %>
      </div>

      <% skill_groups = @document.content['skill_groups'] || {} %>
      <% group_colors = { 'green' => '#4ade80', 'yellow' => '#facc15', 'blue' => '#60a5fa', 'violet' => '#c084fc', 'red' => '#f87171', 'salmon' => '#fda4af', 'orange' => '#fb923c' } %>
      <div class="skills-legend-groups">
        <% skill_groups.each do |key, label| %>
          <span><span class="swatch" style="background-color: <%= group_colors[key] %>;"></span> <%= label %></span>
        <% end %>
      </div>

      <% skills = @document.content['skills'] || [] %>
      <% staff = @document.content['staff'] || [] %>

      <table class="skills-grid">
        <thead>
          <tr>
            <th class="name-header">Name</th>
            <th class="title-header">Job Title</th>
            <% skills.each do |skill| %>
              <th class="skill-header"><div class="skill-bg" style="background-color: <%= group_colors[skill['group']] %>;"></div><div class="rotated"><%= skill['name'] %></div></th>
            <% end %>
          </tr>
        </thead>
        <tbody>
          <% staff.each do |person| %>
            <tr>
              <td class="staff-name"><%= person['name'] %></td>
              <td class="staff-title"><%= person['job_title'] %></td>
              <% skills.each_with_index do |skill, i| %>
                <% level = person['levels']&.dig(i.to_s) %>
                <% if level.present? %>
                  <% bg, fg = case level; when '1' then ['#fee2e2','#991b1b']; when '2' then ['#fef3c7','#92400e']; when '3' then ['#d1fae5','#065f46']; when 'T' then ['#dbeafe','#1e40af']; else ['',''] end %>
                  <td style="background-color: <%= bg %>; color: <%= fg %>; font-weight: bold; text-align: center;"><%= level %></td>
                <% else %>
                  <td></td>
                <% end %>
              <% end %>
            </tr>
          <% end %>
        </tbody>
        <% if skills.any? { |s| s['training_ref'].present? } %>
          <tfoot>
            <tr>
              <td class="training-label" colspan="2">Training / Evaluation Method</td>
              <% skills.each do |skill| %>
                <td><%= skill['training_ref'] %></td>
              <% end %>
            </tr>
          </tfoot>
        <% end %>
      </table>

    <% elsif @document.document_type == 'M' %>
      <%# ── Testing Matrix ── %>
      <% (@document.content['sections'] || []).each do |section| %>
        <div class="matrix-section">
          <div class="matrix-section-header">
            <% heading_text = section['heading'].to_s %>
            <% if heading_text =~ /\(Not currently processed\)/i %>
              <%= heading_text.sub(/\s*\(Not currently processed\)\s*/i, ' ') %>
              <span class="not-active-note">(Not currently processed)</span>
            <% else %><%= heading_text %><% end %>
          </div>
          <% if section['rows'].present? %>
            <table class="matrix-table">
              <thead><tr>
                <th>Method / Specification</th><th>Test Criteria</th><th>No. of Parts / Test Pieces</th>
                <th>Material / Dimensions</th><th>Frequency</th><th>Test Location</th><th>Details</th>
              </tr></thead>
              <tbody>
                <% section['rows'].each do |row| %>
                  <% if row.is_a?(Hash) %>
                    <% cols = row['cols'] || [] %>
                    <% span_text = row['span'].to_s %>
                    <% note = row['note'].to_s %>
                    <% col_classes = ['col-method','col-criteria','col-parts','col-material','col-frequency','col-location','col-details'] %>
                    <% remaining = 7 - cols.length - (note.present? ? 1 : 0) %>
                    <tr>
                      <% cols.each_with_index do |cell, i| %><td class="<%= col_classes[i] %>"><%= cell %></td><% end %>
                      <td class="span-cell" colspan="<%= remaining %>"><%= span_text %></td>
                      <% if note.present? %><td class="col-details"><span class="nadcap-note"><%= note %></span></td><% end %>
                    </tr>
                  <% elsif row.is_a?(Array) && row.length == 1 %>
                    <tr class="ref-row"><td colspan="7"><%= row[0] %></td></tr>
                  <% elsif row.is_a?(Array) %>
                    <tr>
                      <td class="col-method"><%= row[0] %></td>
                      <td class="col-criteria"><%= row[1] %></td>
                      <td class="col-parts"><%= row[2] %></td>
                      <td class="col-material"><%= row[3] %></td>
                      <td class="col-frequency"><%= row[4] %></td>
                      <td class="col-location"><% loc = row[5].to_s %><% if loc.include?('NADCAP') || loc.include?('Not approved') %><span class="nadcap-note"><%= loc %></span><% else %><%= loc %><% end %></td>
                      <td class="col-details"><% detail = row[6].to_s %><% if detail.include?('NADCAP') || detail.include?('Not approved') || detail.include?('Not currently processed') %><span class="nadcap-note"><%= detail %></span><% else %><%= detail %><% end %></td>
                    </tr>
                  <% end %>
                <% end %>
              </tbody>
            </table>
          <% elsif section['content'].present? %>
            <div class="content" style="padding: 8px;"><%= raw section['content'] %></div>
          <% end %>
        </div>
      <% end %>
    <% else %>
      <%# ── Standard documents ── %>
      <% (@document.content['sections'] || []).each do |section| %>
        <div class="section">
          <h2><%= section['heading'] %></h2>
          <div class="content"><%= raw section['content'] %></div>
        </div>
      <% end %>
    <% end %>

    <% if @document.content['references'].present? && @document.content['references'].any? %>
      <div class="references">
        <h2>References</h2>
        <ul><% @document.content['references'].each do |ref| %><li><%= ref %></li><% end %></ul>
      </div>
    <% end %>

    <div class="document-footer">
      <%= @document.full_code %> - <%= @document.title %> | Issue <%= @document.current_issue_number %> | <%= @document.updated_at.strftime('%d/%m/%Y') %>
    </div>
  </div>
</body>
</html>
